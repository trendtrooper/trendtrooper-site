---
import LogoutBar from "../components/LogoutBar.astro";
import TradingViewAdvancedChart from "../components/TradingViewAdvancedChart.astro";

const symbolParam = Astro.url.searchParams.get("symbol");
const initialSymbol = (symbolParam && symbolParam.trim())
  ? symbolParam.trim().toUpperCase()
  : "TSX:FTS";
---

<html lang="en">
<head>
<script>if(localStorage.getItem("tt_dev_access")!=="tt-ironclad-2026"&&!localStorage.getItem("tt_sub_token")){sessionStorage.setItem("tt_redirect",location.pathname);location.replace("/subscribe");}</script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>TrendTrooper — Full Chart</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #060a0f;
      --bg2: #0b1118;
      --bg3: #0f1923;
      --border: #1a2535;
      --border2: #223044;
      --green: #00ff88;
      --blue: #38bdf8;
      --amber: #f59e0b;
      --text: #e5e7eb;
      --muted: #6b7280;
      --muted2: #9ca3af;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      height: 100dvh;
      display: flex;
      flex-direction: column;
    }

    /* ── STANDARD HEADER ── */
    header{position:sticky;top:0;z-index:100;height:70px;background:rgba(2,5,20,.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);display:flex;align-items:center;justify-content:space-between;padding:0 32px;flex-shrink:0;}
    .tt-brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:#e8eeff;}
    .tt-logo{width:42px;height:42px;border-radius:10px;background:linear-gradient(135deg,#7040ff,#00cfff);display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-weight:900;font-size:14px;color:#fff;flex-shrink:0;box-shadow:0 0 20px rgba(112,64,255,.4);}
    .tt-name{font-family:'Orbitron',monospace;font-size:16px;font-weight:900;letter-spacing:2px;background:linear-gradient(90deg,#fff,#00cfff,#7040ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
    .tt-tag{font-size:9px;color:#00cfff;font-weight:600;letter-spacing:3px;text-transform:uppercase;display:block;opacity:.8;}
    .tt-nav{display:flex;align-items:center;gap:1px;white-space:nowrap;}
    .tt-nav a{color:#c8d8f0;padding:6px 9px;border-radius:8px;text-decoration:none;font-weight:800;font-size:11.5px;letter-spacing:.8px;text-transform:uppercase;transition:color .15s,background .15s;}
    .tt-nav a:hover{color:#e8eeff;background:rgba(0,200,255,.06);}
    .tt-nav a.cur{color:#00cfff;}
    .tt-cta{background:linear-gradient(135deg,#00cfff,#7040ff)!important;color:#fff!important;font-weight:800!important;padding:8px 14px!important;border-radius:8px!important;box-shadow:0 0 20px rgba(0,200,255,.2)!important;}
    .tt-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
    .tt-burger span{width:22px;height:2px;background:#e8eeff;border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
    .tt-burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .tt-burger.open span:nth-child(2){opacity:0;}
    .tt-burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .tt-mob{display:none;flex-direction:column;position:sticky;top:70px;z-index:99;background:rgba(2,5,20,.97);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);padding:8px 24px 16px;}
    .tt-mob.open{display:flex;}
    .tt-mob a{color:#c8d8f0;padding:10px 0;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:1px;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.04);}
    .tt-mob a:hover{color:#e8eeff;}
    @media(max-width:900px){.tt-nav{display:none;}.tt-burger{display:flex;}}

    /* ── CHART TOOLBAR ── */
    .chart-toolbar {
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 0 16px;
      height: 54px;
      flex-shrink: 0;
      flex-wrap: wrap;
    }

    .back-link {
      display: flex;
      align-items: center;
      gap: 6px;
      color: var(--muted2);
      text-decoration: none;
      font-size: 13px;
      font-weight: 700;
      padding: 6px 10px;
      border-radius: 8px;
      border: 1px solid var(--border2);
      transition: all .15s;
      flex-shrink: 0;
    }

    .back-link:hover { color: var(--green); border-color: var(--green); }

    .logo {
      width: 32px;
      height: 32px;
      border-radius: 9px;
      background: linear-gradient(135deg, var(--green), var(--blue));
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      font-size: 12px;
      color: #020617;
      flex-shrink: 0;
    }

    .brand {
      font-size: 15px;
      font-weight: 900;
      flex-shrink: 0;
    }

    /* ── SEARCH BAR ── */
    .search-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      flex: 1;
      min-width: 0;
    }

    .search-input-block {
      display: flex;
      flex-direction: column;
      gap: 2px;
      flex: 1;
      min-width: 0;
    }

    .exchange-select {
      background: var(--bg);
      border: 1px solid var(--border2);
      color: var(--text);
      padding: 8px 10px;
      border-radius: 9px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      outline: none;
      flex-shrink: 0;
    }

    .exchange-select:focus { border-color: var(--green); }

    .symbol-input {
      background: var(--bg);
      border: 1px solid var(--border2);
      color: var(--text);
      padding: 8px 14px;
      border-radius: 9px;
      font-size: 14px;
      font-weight: 700;
      width: 100%;
      min-width: 120px;
      max-width: 240px;
      outline: none;
      font-family: monospace;
      transition: border-color .15s;
    }

    .symbol-input:focus { border-color: var(--green); }

    .input-hint {
      font-size: 10px;
      color: var(--muted);
      font-style: italic;
      padding-left: 2px;
      white-space: nowrap;
    }

    .go-btn {
      background: linear-gradient(135deg, var(--green), var(--blue));
      color: #020617;
      border: none;
      padding: 8px 16px;
      border-radius: 9px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      flex-shrink: 0;
      transition: opacity .15s;
    }

    .go-btn:hover { opacity: .9; }

    /* ── TOOLBAR ACTION BUTTONS ── */
    .toolbar-btn {
      background: var(--bg);
      border: 1px solid var(--border2);
      color: var(--muted2);
      padding: 7px 12px;
      border-radius: 9px;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      flex-shrink: 0;
      transition: all .15s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      white-space: nowrap;
    }

    .toolbar-btn:hover {
      color: var(--green);
      border-color: var(--green);
    }

    .delay-note {
      font-size: 10px;
      color: var(--amber);
      opacity: 0.7;
      white-space: nowrap;
      flex-shrink: 0;
      font-style: italic;
    }

    /* ── QUICK PICKS ── */
    .quickpicks-wrapper {
      position: relative;
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .quickpicks {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 8px 16px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .quickpicks::-webkit-scrollbar { display: none; }

    /* Fade gradient on right edge (mobile) */
    @media (max-width: 600px) {
      .quickpicks-wrapper::after {
        content: '';
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 40px;
        background: linear-gradient(to right, transparent, var(--bg2));
        pointer-events: none;
      }
    }

    .qp-label {
      font-size: 11px;
      font-weight: 800;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-right: 4px;
      flex-shrink: 0;
      scroll-snap-align: start;
    }

    .qp-group {
      display: flex;
      gap: 5px;
      align-items: center;
    }

    .qp-divider {
      width: 1px;
      height: 18px;
      background: var(--border2);
      margin: 0 4px;
      flex-shrink: 0;
    }

    .qp {
      background: var(--bg);
      border: 1px solid var(--border2);
      color: var(--muted2);
      padding: 5px 10px;
      border-radius: 7px;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all .12s;
      font-family: monospace;
      white-space: nowrap;
      flex-shrink: 0;
      scroll-snap-align: start;
    }

    .qp:hover, .qp.active {
      background: var(--green);
      color: #020617;
      border-color: var(--green);
    }

    /* ── CHART ── */
    .chart-container {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
    }

    .chart-container > div {
      flex: 1;
      min-height: 0;
    }

    /* ── STATUS BAR ── */
    .statusbar {
      height: 32px;
      background: var(--bg2);
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 20px;
      flex-shrink: 0;
    }

    .status-item {
      font-size: 11px;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--green);
      animation: pulse 1.8s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: .4; }
    }

    .status-sym {
      font-weight: 800;
      color: var(--text);
      font-family: monospace;
      font-size: 12px;
    }

    /* ── TOAST ── */
    #toast {
      position: fixed;
      bottom: 48px;
      left: 50%;
      transform: translateX(-50%) translateY(20px);
      background: var(--green);
      color: #020617;
      font-size: 13px;
      font-weight: 800;
      padding: 8px 20px;
      border-radius: 20px;
      pointer-events: none;
      opacity: 0;
      transition: opacity .2s, transform .2s;
      z-index: 9999;
    }

    #toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    /* ── MOBILE TOOLBAR ── */
    @media (max-width: 600px) {
      .chart-toolbar {
        height: auto;
        padding: 10px 12px;
        gap: 8px;
        flex-direction: column;
        align-items: stretch;
      }

      .search-wrap {
        flex-direction: column;
        align-items: stretch;
        gap: 6px;
      }

      .exchange-select {
        width: 100%;
        order: 1;
      }

      .search-input-block {
        order: 2;
      }

      .symbol-input {
        max-width: 100%;
        width: 100%;
      }

      .go-btn {
        order: 3;
        width: 100%;
        padding: 10px;
        font-size: 14px;
      }

      .toolbar-actions {
        display: flex;
        gap: 8px;
        order: 4;
      }

      .delay-note {
        display: none;
      }
    }
  </style>
</head>

<body>

<!-- HEADER -->
<header>
  <a class="tt-brand" href="/">
    <div class="tt-logo">TT</div>
    <div><div class="tt-name">TRENDTROOPER</div><span class="tt-tag">Signal Service</span></div>
  </a>
  <nav class="tt-nav">
    <a href="/#features">Features</a>
    <a href="/chart" class="cur">Live Chart</a>
    <a href="/#markets">Markets</a>
    <a href="/#pricing">Pricing</a>
    <a href="/analysis">Analysis</a>
    <a href="/screener">Screener</a>
    <a href="/academy">Academy</a>
    <a href="/tools">Tools</a>
    <a href="https://bot.trendtrooper.com/" target="_blank">Live Bot Trading</a>
    <a href="/#pricing" class="tt-cta">Get Started</a>
  </nav>
  <button class="tt-burger" id="ttBurger" onclick="this.classList.toggle('open');document.getElementById('ttMob').classList.toggle('open')" aria-label="Menu"><span></span><span></span><span></span></button>
</header>
<div class="tt-mob" id="ttMob">
  <a href="/#features">Features</a>
  <a href="/chart">Live Chart</a>
  <a href="/#markets">Markets</a>
  <a href="/#pricing">Pricing</a>
  <a href="/analysis">Analysis</a>
  <a href="/screener">Screener</a>
  <a href="/academy">Academy</a>
  <a href="/tools">Tools</a>
  <a href="https://bot.trendtrooper.com/" target="_blank">Live Bot Trading</a>
  <a href="/#pricing">Get Started</a>
</div>

<!-- CHART TOOLBAR -->
<div class="chart-toolbar">
  <div class="search-wrap">
    <select class="exchange-select" id="exchangeSelect">
      <option value="">Auto</option>
      <optgroup label="Canadian">
        <option value="TSX">TSX</option>
        <option value="TSXV">TSXV</option>
        <option value="CSE">CSE</option>
      </optgroup>
      <optgroup label="US">
        <option value="NYSE">NYSE</option>
        <option value="NASDAQ">NASDAQ</option>
        <option value="AMEX">AMEX</option>
        <option value="CBOE">CBOE</option>
      </optgroup>
    </select>

    <div class="search-input-block">
      <input
        id="symbolInput"
        class="symbol-input"
        value={initialSymbol}
        placeholder="TSX:FTS, NVDA, SOXL…"
        autocomplete="off"
        spellcheck="false"
      />
      <span class="input-hint">e.g. NVDA, TSX:FTS, NASDAQ:AAPL</span>
    </div>

    <button class="go-btn" id="goBtn" title="Press Enter to load chart">Go</button>
  </div>

  <div class="toolbar-actions" style="display:flex;gap:8px;align-items:center;flex-shrink:0;">
    <button class="toolbar-btn" id="shareBtn">&#128279; Share</button>
    <a class="toolbar-btn" id="analyzeBtn" href={`/analysis?t=${initialSymbol}`}>&#128269; Analyze</a>
    <span class="delay-note">TradingView data may be 15-min delayed for free accounts</span>
  </div>
</div>

<!-- QUICK PICKS -->
<div class="quickpicks-wrapper">
  <div class="quickpicks">
    <span class="qp-label">CA</span>
    <div class="qp-group">
      <button class="qp" data-sym="TSX:FTS">FTS</button>
      <button class="qp" data-sym="TSX:CNQ">CNQ</button>
      <button class="qp" data-sym="TSX:CNQ.TO">CNQ.TO</button>
      <button class="qp" data-sym="TSX:HIVE">HIVE</button>
      <button class="qp" data-sym="TSX:SU">SU</button>
      <button class="qp" data-sym="TSX:RY">RY</button>
      <button class="qp" data-sym="TSX:RY.TO">RY.TO</button>
      <button class="qp" data-sym="TSX:TD.TO">TD.TO</button>
      <button class="qp" data-sym="TSX:ENB">ENB</button>
      <button class="qp" data-sym="TSX:ENB.TO">ENB.TO</button>
      <button class="qp" data-sym="TSX:SHOP">SHOP</button>
      <button class="qp" data-sym="TSX:SHOP.TO">SHOP.TO</button>
      <button class="qp" data-sym="TSXV:NFG">NFG</button>
    </div>

    <div class="qp-divider"></div>
    <span class="qp-label">US</span>
    <div class="qp-group">
      <button class="qp" data-sym="AMEX:SPY">SPY</button>
      <button class="qp" data-sym="NASDAQ:QQQ">QQQ</button>
      <button class="qp" data-sym="NASDAQ:NVDA">NVDA</button>
      <button class="qp" data-sym="NASDAQ:SOXL">SOXL</button>
      <button class="qp" data-sym="NASDAQ:TSLA">TSLA</button>
      <button class="qp" data-sym="NASDAQ:AMD">AMD</button>
      <button class="qp" data-sym="NASDAQ:META">META</button>
      <button class="qp" data-sym="NASDAQ:MSFT">MSFT</button>
      <button class="qp" data-sym="NASDAQ:AAPL">AAPL</button>
      <button class="qp" data-sym="NASDAQ:AMZN">AMZN</button>
      <button class="qp" data-sym="NASDAQ:GOOGL">GOOGL</button>
      <button class="qp" data-sym="NASDAQ:COIN">COIN</button>
      <button class="qp" data-sym="NASDAQ:MSTR">MSTR</button>
      <button class="qp" data-sym="NASDAQ:TQQQ">TQQQ</button>
      <button class="qp" data-sym="NASDAQ:SQQQ">SQQQ</button>
      <button class="qp" data-sym="AMEX:IWM">IWM</button>
      <button class="qp" data-sym="NYSE:XOM">XOM</button>
      <button class="qp" data-sym="NYSE:CVX">CVX</button>
      <button class="qp" data-sym="NYSE:JPM">JPM</button>
      <button class="qp" data-sym="NYSE:V">V</button>
      <button class="qp" data-sym="NYSE:WMT">WMT</button>
      <button class="qp" data-sym="NASDAQ:BTC">BTC</button>
    </div>
  </div>
</div>

<!-- CHART -->
<div class="chart-container">
  <TradingViewAdvancedChart
    symbol={initialSymbol}
    interval="5"
    theme="dark"
    height={720}
    autosize={true}
  />
</div>

<!-- STATUS BAR -->
<div class="statusbar">
  <div class="status-item"><div class="dot"></div> Bot online</div>
  <div class="status-item">Symbol: <span class="status-sym" id="activeSym">{initialSymbol}</span></div>
  <div class="status-item">Interval: <span style="color: var(--text); font-weight:700;">5m</span></div>
  <div class="status-item" style="margin-left:auto;">
    Shareable: <code id="shareLink" style="font-size:11px; background:var(--bg); padding:2px 8px; border-radius:5px; color:var(--muted2);"></code>
  </div>
</div>

<!-- TOAST -->
<div id="toast">Link copied!</div>

<script is:inline>
(function () {
  const KNOWN = {
    FTS: "TSX:FTS", CNQ: "TSX:CNQ", HIVE: "TSX:HIVE", SU: "TSX:SU",
    RY: "TSX:RY", TD: "TSX:TD", ENB: "TSX:ENB", BCE: "TSX:BCE",
    SHOP: "TSX:SHOP", NFG: "TSXV:NFG",
    SPY: "AMEX:SPY", QQQ: "NASDAQ:QQQ", NVDA: "NASDAQ:NVDA",
    SOXL: "NASDAQ:SOXL", TSLA: "NASDAQ:TSLA", AMD: "NASDAQ:AMD",
    META: "NASDAQ:META", MSFT: "NASDAQ:MSFT", AAPL: "NASDAQ:AAPL",
    AMZN: "NASDAQ:AMZN", GOOGL: "NASDAQ:GOOGL", COIN: "NASDAQ:COIN",
    MSTR: "NASDAQ:MSTR", IWM: "AMEX:IWM", DIA: "AMEX:DIA",
    TQQQ: "NASDAQ:TQQQ", SQQQ: "NASDAQ:SQQQ",
    XOM: "NYSE:XOM", CVX: "NYSE:CVX", JPM: "NYSE:JPM",
    V: "NYSE:V", WMT: "NYSE:WMT", BTC: "NASDAQ:BTC",
  };

  const input = document.getElementById("symbolInput");
  const btn = document.getElementById("goBtn");
  const exchSel = document.getElementById("exchangeSelect");
  const activeSym = document.getElementById("activeSym");
  const shareLink = document.getElementById("shareLink");
  const shareBtn = document.getElementById("shareBtn");
  const analyzeBtn = document.getElementById("analyzeBtn");
  const toast = document.getElementById("toast");

  function normalizeSymbol(raw, exchOverride) {
    let s = (raw || "").trim().toUpperCase().replace(/\s+/g, "");
    if (!s) return "TSX:FTS";
    if (s.includes(":")) return s;
    if (exchOverride) return exchOverride + ":" + s;
    // Use selected exchange as default, falling back to KNOWN lookup then TSX
    const selectedExch = exchSel.value;
    if (selectedExch) return selectedExch + ":" + s;
    return KNOWN[s] || "TSX:" + s;
  }

  function setSymbol(sym) {
    const symbol = normalizeSymbol(sym, null);
    if (!symbol) return;

    input.value = symbol;
    if (activeSym) activeSym.textContent = symbol;

    document.querySelectorAll(".qp").forEach(b => {
      b.classList.toggle("active", b.dataset.sym === symbol);
    });

    if (shareLink) {
      shareLink.textContent = "/chart?symbol=" + encodeURIComponent(symbol);
    }

    // Update analyze button href dynamically
    if (analyzeBtn) {
      analyzeBtn.href = "/analysis?t=" + encodeURIComponent(symbol);
    }

    const url = new URL(window.location.href);
    url.searchParams.set("symbol", symbol);
    window.history.replaceState({}, "", url.toString());

    window.dispatchEvent(new CustomEvent("tt:setSymbol", { detail: { symbol } }));
  }

  // Exchange dropdown auto-reload
  exchSel.addEventListener("change", () => {
    const sym = input.value.trim().toUpperCase();
    if (sym) setSymbol(sym);
  });

  btn.addEventListener("click", () => setSymbol(input.value));
  input.addEventListener("keydown", (e) => { if (e.key === "Enter") setSymbol(input.value); });
  document.querySelectorAll(".qp").forEach((b) => {
    b.addEventListener("click", () => setSymbol(b.dataset.sym));
  });

  // Share button — copy URL to clipboard
  if (shareBtn) {
    shareBtn.addEventListener("click", () => {
      const url = window.location.href;
      navigator.clipboard.writeText(url).then(() => {
        if (toast) {
          toast.classList.add("show");
          setTimeout(() => toast.classList.remove("show"), 2000);
        }
      }).catch(() => {
        // Fallback for older browsers
        const ta = document.createElement("textarea");
        ta.value = url;
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        document.body.removeChild(ta);
        if (toast) {
          toast.classList.add("show");
          setTimeout(() => toast.classList.remove("show"), 2000);
        }
      });
    });
  }

  // Burger menu close on link click
  document.querySelectorAll("#ttMob a").forEach(a => {
    a.addEventListener("click", () => {
      document.getElementById("ttMob").classList.remove("open");
      document.getElementById("ttBurger").classList.remove("open");
    });
  });

  // Set initial state
  const initSym = input.value;
  if (activeSym) activeSym.textContent = initSym;
  if (shareLink) shareLink.textContent = "/chart?symbol=" + encodeURIComponent(initSym);
  if (analyzeBtn) analyzeBtn.href = "/analysis?t=" + encodeURIComponent(initSym);
  document.querySelectorAll(".qp").forEach(b => {
    b.classList.toggle("active", b.dataset.sym === initSym);
  });
})();
</script>
