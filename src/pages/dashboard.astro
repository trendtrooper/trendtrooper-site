---
// TrendTrooper — Market Dashboard src/pages/dashboard.astro
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>TrendTrooper — Market Dashboard</title>
  <meta name="description" content="Live-style market dashboard. Indices, leveraged ETFs, and signal summaries." />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root{
      --bg:#070e1c;--card:#0f1b33;--card2:#111e38;
      --muted:#7a96bb;--muted2:#4a6490;
      --text:#ddeeff;--text2:#b8d0ee;
      --accent:#6ee7ff;--accent2:#a78bfa;
      --green:#22d673;--red:#ff5c6a;--amber:#f59e0b;
      --border2:rgba(255,255,255,.06);--r:16px;--max:1160px;
      --mono:'JetBrains Mono',monospace;--sans:'Space Grotesk',sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);color:var(--text);background:var(--bg);min-height:100vh}
    a{color:inherit;text-decoration:none}
    header{position:sticky;top:0;z-index:100;background:rgba(7,14,28,.9);backdrop-filter:blur(16px);border-bottom:1px solid var(--border2)}
    .nav{max-width:var(--max);margin:0 auto;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;gap:20px}
    .brand{display:flex;align-items:center;gap:12px;font-weight:900;font-size:13px;font-family:'Orbitron',monospace;letter-spacing:.5px;}
    .logo{width:34px;height:34px;border-radius:10px;flex:0 0 auto;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-weight:900;font-size:11px;color:#fff;letter-spacing:.5px;box-shadow:0 0 16px rgba(110,231,255,.25);}
    .brand-sub{font-size:11px;color:var(--muted);font-weight:500}
    .navlinks{display:flex;gap:22px;color:var(--muted);font-size:13.5px;font-weight:500}
    .navlinks a:hover{color:var(--text)}.navlinks a.active{color:var(--accent)}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:9px 18px;border-radius:12px;font-weight:600;font-size:13.5px;border:1px solid var(--border2);background:rgba(255,255,255,.05);color:var(--text);cursor:pointer;transition:.15s;font-family:var(--sans)}
    .btn:hover{background:rgba(255,255,255,.08)}
    .btn.primary{background:linear-gradient(135deg,var(--accent),var(--accent2));border:none;color:#070e1c;font-weight:700}
    .wrap{max-width:var(--max);margin:0 auto;padding:32px 24px}
    .page-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:14px}
    .page-head h1{font-size:24px;font-weight:700}
    .live-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:999px;border:1px solid rgba(34,214,115,.3);background:rgba(34,214,115,.08);color:var(--green);font-size:12px;font-weight:700;font-family:var(--mono)}
    .pulse{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 12px rgba(34,214,115,.6);animation:pulse 2s ease-in-out infinite}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
    /* INDEX GRID */
    .idx-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px}
    .idx-card{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);padding:18px 20px;position:relative;overflow:hidden;cursor:pointer;transition:.2s}
    .idx-card:hover{border-color:rgba(110,231,255,.25);transform:translateY(-2px)}
    .idx-card.up{border-top:2px solid var(--green)}
    .idx-card.dn{border-top:2px solid var(--red)}
    .idx-sym{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.5px;font-family:var(--mono);margin-bottom:6px}
    .idx-name{font-size:12px;color:var(--muted2);margin-bottom:10px}
    .idx-price{font-size:22px;font-weight:700;font-family:var(--mono);margin-bottom:4px}
    .idx-chg{font-size:13px;font-weight:700;font-family:var(--mono)}
    .up-txt{color:var(--green)}.dn-txt{color:var(--red)}
    .idx-spark{height:40px;margin-top:10px}
    /* LEVERAGED ETF SECTION */
    .section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
    .section-head h2{font-size:18px;font-weight:700}
    .section-head span{color:var(--muted);font-size:13px}
    .etf-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:28px}
    .etf-card{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);padding:20px;transition:.2s;cursor:pointer}
    .etf-card:hover{border-color:rgba(110,231,255,.3);transform:translateY(-2px);box-shadow:0 16px 50px rgba(0,0,0,.4)}
    .etf-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
    .etf-sym{font-size:18px;font-weight:700;font-family:var(--mono)}
    .etf-lev{font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px;background:rgba(110,231,255,.1);border:1px solid rgba(110,231,255,.25);color:var(--accent);font-family:var(--mono)}
    .etf-full{font-size:12px;color:var(--muted);margin-bottom:12px}
    .etf-price{font-size:26px;font-weight:700;font-family:var(--mono);margin-bottom:4px}
    .etf-chg{font-size:13px;font-weight:700;font-family:var(--mono);margin-bottom:14px}
    .signal-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
    .sig{font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;font-family:var(--mono)}
    .sig.buy{background:rgba(34,214,115,.12);border:1px solid rgba(34,214,115,.3);color:var(--green)}
    .sig.sell{background:rgba(255,92,106,.12);border:1px solid rgba(255,92,106,.3);color:var(--red)}
    .sig.hold{background:rgba(245,158,11,.10);border:1px solid rgba(245,158,11,.25);color:var(--amber)}
    .sig.neutral{background:rgba(255,255,255,.05);border:1px solid var(--border2);color:var(--muted)}
    .etf-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .etf-stat{background:rgba(255,255,255,.03);border-radius:10px;padding:10px 12px}
    .etf-stat .sl{font-size:10px;color:var(--muted2);font-weight:600;letter-spacing:.3px;margin-bottom:3px}
    .etf-stat .sv{font-size:13px;font-weight:700;font-family:var(--mono)}
    /* TWO COL */
    .two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:28px}
    /* HEATMAP */
    .heatmap-wrap{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);overflow:hidden}
    .panel-head{padding:14px 18px;border-bottom:1px solid var(--border2);display:flex;align-items:center;justify-content:space-between}
    .panel-head h3{font-size:14px;font-weight:700}
    .heatmap-grid{padding:16px;display:grid;grid-template-columns:repeat(5,1fr);gap:6px}
    .hm-cell{border-radius:10px;padding:10px 8px;text-align:center;cursor:pointer;transition:.15s}
    .hm-cell:hover{filter:brightness(1.15)}
    .hm-sym{font-size:11px;font-weight:700;font-family:var(--mono)}
    .hm-chg{font-size:12px;font-weight:700;font-family:var(--mono);margin-top:2px}
    /* SIGNAL TABLE */
    .signal-table-wrap{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);overflow:hidden}
    table{width:100%;border-collapse:collapse}
    th{padding:12px 16px;font-size:11px;font-weight:700;color:var(--muted2);letter-spacing:.5px;text-align:left;border-bottom:1px solid var(--border2);background:rgba(255,255,255,.02)}
    td{padding:12px 16px;font-size:13px;border-bottom:1px solid rgba(255,255,255,.03)}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:rgba(255,255,255,.02)}
    .td-sym{font-family:var(--mono);font-weight:700;color:var(--accent)}
    /* FEAR GREED */
    .fg-wrap{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);padding:20px}
    .fg-meter{position:relative;height:120px;display:flex;align-items:center;justify-content:center;flex-direction:column}
    .fg-num{font-size:52px;font-weight:700;font-family:var(--mono)}
    .fg-label{font-size:13px;color:var(--muted);margin-top:4px;font-weight:600}
    .fg-scale{display:flex;border-radius:999px;overflow:hidden;height:8px;margin-top:16px}
    .fg-scale div{flex:1}
    footer{max-width:var(--max);margin:40px auto 0;padding:24px;border-top:1px solid var(--border2);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;color:var(--muted2);font-size:13px}
    .foot-links{display:flex;gap:18px}
    .foot-links a:hover{color:var(--muted)}
    @media(max-width:900px){.idx-grid{grid-template-columns:repeat(2,1fr)}.etf-grid,.two-col{grid-template-columns:1fr}.navlinks{display:none}.heatmap-grid{grid-template-columns:repeat(3,1fr)}.hamburger{display:flex;}}
    .hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
    .hamburger span{width:20px;height:2px;background:var(--text);border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
    .hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .hamburger.open span:nth-child(2){opacity:0;}
    .hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .inner-mobile-menu{display:none;flex-direction:column;position:sticky;top:61px;z-index:99;background:rgba(7,14,28,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border2);padding:8px 24px 16px;}
    .inner-mobile-menu.open{display:flex;}
    .inner-mobile-menu a{color:var(--muted);text-decoration:none;font-weight:600;font-size:14px;padding:11px 0;border-bottom:1px solid var(--border2);transition:color .15s;}
    .inner-mobile-menu a:last-child{border-bottom:none;}
    .inner-mobile-menu a:hover{color:var(--text);}
  </style>
</head>
<body>
<header>
  <div class="nav">
    <div class="brand">
      <div class="logo">TT</div>
      <div><div>TrendTrooper</div><div class="brand-sub">DASHBOARD</div></div>
    </div>
    <nav class="navlinks">
      <a href="/">Home</a>
      <a href="/dashboard" class="active">Dashboard</a>
      <a href="/screener">Screener</a>
      <a href="/strategy">Strategy</a>
      <a href="/academy">Academy</a>
    </nav>
    <div style="display:flex;gap:10px;align-items:center">
      <a class="btn" href="/">← HQ</a>
      <span class="live-badge"><span class="pulse"></span>SIMULATED DATA</span>
      <button class="hamburger" id="hamburgerBtn" onclick="toggleInnerMenu()" aria-label="Open navigation"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>
<div class="inner-mobile-menu" id="innerMobileMenu">
  <a href="/">Home</a>
  <a href="/dashboard">Dashboard</a>
  <a href="/screener">Screener</a>
  <a href="/strategy">Strategy</a>
  <a href="/academy">Academy</a>
  <a href="https://bot.trendtrooper.com/" target="_blank">Bot Status</a>
</div>

<div class="wrap">
  <div class="page-head">
    <div>
      <h1>Market Dashboard</h1>
      <div style="color:var(--muted);font-size:13px;margin-top:4px">Indices · Leveraged ETFs · Sector signals · Fear & Greed</div>
    </div>
    <div id="clock" style="font-family:var(--mono);font-size:14px;color:var(--muted)"></div>
  </div>

  <!-- MAJOR INDICES -->
  <div class="section-head"><h2>Major Indices</h2><span>15-min delayed • Simulated</span></div>
  <div class="idx-grid" id="idxGrid"></div>

  <!-- LEVERAGED ETFs -->
  <div class="section-head"><h2>Leveraged ETF Watch</h2><span>TrendTrooper auto-switch universe</span></div>
  <div class="etf-grid" id="etfGrid"></div>

  <div class="two-col">
    <!-- SECTOR HEATMAP -->
    <div class="heatmap-wrap">
      <div class="panel-head"><h3>Sector Heatmap</h3><span style="font-size:12px;color:var(--muted)">Today's performance</span></div>
      <div class="heatmap-grid" id="heatGrid"></div>
    </div>

    <!-- FEAR & GREED + SIGNAL TABLE -->
    <div style="display:flex;flex-direction:column;gap:14px">
      <div class="fg-wrap">
        <div class="panel-head" style="padding:0 0 12px"><h3>Fear & Greed Index</h3></div>
        <div class="fg-meter">
          <div class="fg-num" id="fgNum" style="color:var(--amber)">62</div>
          <div class="fg-label" id="fgLbl">GREED</div>
        </div>
        <div class="fg-scale">
          <div style="background:#ff5c6a"></div>
          <div style="background:#f59e0b"></div>
          <div style="background:#6ee7ff"></div>
          <div style="background:#22d673"></div>
          <div style="background:#a78bfa"></div>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:6px;font-size:10px;color:var(--muted2);font-family:var(--mono)">
          <span>EXTREME FEAR</span><span>EXTREME GREED</span>
        </div>
      </div>

      <div class="signal-table-wrap">
        <div class="panel-head"><h3>Active Signals</h3><span style="font-size:12px;color:var(--muted)">Last 24h</span></div>
        <table>
          <thead><tr><th>SYMBOL</th><th>SIGNAL</th><th>ENTRY</th><th>STATUS</th></tr></thead>
          <tbody id="sigTable"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<footer>
  <div>TrendTrooper Dashboard &nbsp;•&nbsp; © <span id="yr"></span> &nbsp;•&nbsp; Simulated data only</div>
  <div class="foot-links"><a href="/">Home</a><a href="/academy">Academy</a><a href="/screener">Screener</a></div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
document.getElementById('yr').textContent = new Date().getFullYear();
function toggleInnerMenu(){
  document.getElementById('innerMobileMenu').classList.toggle('open');
  document.getElementById('hamburgerBtn').classList.toggle('open');
}

// Clock
function tick(){
  const now=new Date();
  document.getElementById('clock').textContent=now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
}
tick(); setInterval(tick,1000);

// Simulated data helpers
function rnd(min,max){return+(Math.random()*(max-min)+min).toFixed(2)}
function pct(){return rnd(-2.5,2.5)}
function spark(){const d=[];let v=100;for(let i=0;i<20;i++){v+=rnd(-2,2);d.push(+v.toFixed(2))}return d}

// INDICES
const indices=[
  {sym:'SPX',name:'S&P 500',price:5280.14},
  {sym:'NDX',name:'NASDAQ 100',price:18420.55},
  {sym:'DJI',name:'Dow Jones',price:39540.20},
  {sym:'VIX',name:'Volatility Index',price:14.82},
];
const idxGrid=document.getElementById('idxGrid');
indices.forEach(idx=>{
  const chg=pct(); const up=chg>=0;
  const d=document.createElement('div');
  d.className='idx-card '+(up?'up':'dn');
  const sd=spark();
  const cid='spark_'+idx.sym;
  d.innerHTML=`<div class="idx-sym">${idx.sym}</div><div class="idx-name">${idx.name}</div><div class="idx-price">${idx.price.toLocaleString()}</div><div class="idx-chg ${up?'up-txt':'dn-txt'}">${up?'+':''}${chg}%</div><canvas id="${cid}" class="idx-spark" role="img" aria-label="${idx.sym} sparkline"></canvas>`;
  idxGrid.appendChild(d);
  setTimeout(()=>{
    new Chart(document.getElementById(cid),{type:'line',data:{labels:sd.map((_,i)=>i),datasets:[{data:sd,borderColor:up?'#22d673':'#ff5c6a',borderWidth:1.5,pointRadius:0,tension:.4,fill:true,backgroundColor:up?'rgba(34,214,115,.08)':'rgba(255,92,106,.08)'}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{enabled:false}},scales:{x:{display:false},y:{display:false}},animation:{duration:800}}});
  },100);
});

// LEVERAGED ETFs
const etfs=[
  {sym:'SPXL',name:'Direxion Daily S&P 500 Bull',lev:'3x Bull',base:98.40,signals:['EMA↑','VWAP+','RSI 58'],sig:'BUY',sigType:'buy'},
  {sym:'SPXS',name:'Direxion Daily S&P 500 Bear',lev:'3x Bear',base:14.22,signals:['EMA↓','Below VWAP','RSI 42'],sig:'SELL',sigType:'sell'},
  {sym:'TQQQ',name:'ProShares Ultra QQQ',lev:'3x Bull',base:62.15,signals:['EMA↑','VWAP+','MACD+'],sig:'BUY',sigType:'buy'},
  {sym:'SQQQ',name:'ProShares UltraPro Short QQQ',lev:'3x Bear',base:8.44,signals:['EMA↓','RSI 38'],sig:'HOLD',sigType:'hold'},
  {sym:'UVXY',name:'ProShares Ultra VIX',lev:'1.5x VIX',base:5.88,signals:['VIX Rising','RSI 55'],sig:'WATCH',sigType:'hold'},
  {sym:'LABU',name:'Direxion Daily S&P Biotech',lev:'3x Bull',base:102.30,signals:['Neutral','RSI 50'],sig:'NEUTRAL',sigType:'neutral'},
];
const etfGrid=document.getElementById('etfGrid');
etfs.forEach(e=>{
  const chg=pct(); const up=chg>=0;
  const price=(e.base*(1+chg/100)).toFixed(2);
  const atr=rnd(0.8,3.2); const vol=rnd(2,8);
  const d=document.createElement('div');
  d.className='etf-card';
  d.innerHTML=`
    <div class="etf-header">
      <div class="etf-sym">${e.sym}</div>
      <div class="etf-lev">${e.lev}</div>
    </div>
    <div class="etf-full">${e.name}</div>
    <div class="etf-price">$${price}</div>
    <div class="etf-chg ${up?'up-txt':'dn-txt'}">${up?'+':''}${chg}% today</div>
    <div class="signal-bar">
      <span class="sig ${e.sigType}">${e.sig}</span>
      ${e.signals.map(s=>`<span class="sig neutral">${s}</span>`).join('')}
    </div>
    <div class="etf-stats">
      <div class="etf-stat"><div class="sl">ATR(14)</div><div class="sv">$${atr.toFixed(2)}</div></div>
      <div class="etf-stat"><div class="sl">VOL ×AVG</div><div class="sv">${vol.toFixed(1)}x</div></div>
      <div class="etf-stat"><div class="sl">STOP EST</div><div class="sv">$${(price-(atr*2)).toFixed(2)}</div></div>
      <div class="etf-stat"><div class="sl">TARGET</div><div class="sv">$${(+price+(atr*3)).toFixed(2)}</div></div>
    </div>`;
  etfGrid.appendChild(d);
});

// SECTOR HEATMAP
const sectors=[
  {name:'Tech',chg:1.8},{name:'Energy',chg:-0.9},{name:'Finance',chg:0.4},
  {name:'Health',chg:-0.2},{name:'Consume',chg:0.7},{name:'Industrials',chg:1.1},
  {name:'Materials',chg:-1.4},{name:'Utilities',chg:0.3},{name:'Real Est',chg:-0.6},
  {name:'Comm',chg:2.1},{name:'Staples',chg:-0.1},
];
const heatGrid=document.getElementById('heatGrid');
sectors.forEach(s=>{
  const intensity=Math.min(Math.abs(s.chg)/3,1);
  const bg=s.chg>=0?`rgba(34,214,115,${0.1+intensity*.4})`:`rgba(255,92,106,${0.1+intensity*.4})`;
  const d=document.createElement('div');
  d.className='hm-cell';
  d.style.background=bg;
  d.innerHTML=`<div class="hm-sym">${s.name}</div><div class="hm-chg" style="color:${s.chg>=0?'#22d673':'#ff5c6a'}">${s.chg>=0?'+':''}${s.chg}%</div>`;
  heatGrid.appendChild(d);
});

// SIGNAL TABLE
const signals=[
  {sym:'SPXL',signal:'Long Entry',entry:'$98.40',status:'OPEN'},
  {sym:'TQQQ',signal:'Long Entry',entry:'$62.15',status:'OPEN'},
  {sym:'SPXS',signal:'Short Closed',entry:'$14.80',status:'CLOSED +2.1%'},
  {sym:'UVXY',signal:'Watching',entry:'—',status:'PENDING'},
];
const tb=document.getElementById('sigTable');
signals.forEach(s=>{
  const isOpen=s.status==='OPEN';
  const isClosed=s.status.includes('CLOSED');
  const tr=document.createElement('tr');
  tr.innerHTML=`<td class="td-sym">${s.sym}</td><td style="color:var(--text2)">${s.signal}</td><td style="font-family:var(--mono)">${s.entry}</td><td><span class="sig ${isOpen?'buy':isClosed?'sell':'neutral'}">${s.status}</span></td>`;
  tb.appendChild(tr);
});

// Fear & Greed random-ish
const fg=Math.round(rnd(25,80));
document.getElementById('fgNum').textContent=fg;
const lbl=fg<25?'EXTREME FEAR':fg<45?'FEAR':fg<55?'NEUTRAL':fg<75?'GREED':'EXTREME GREED';
const col=fg<25?'#ff5c6a':fg<45?'#f59e0b':fg<55?'#6ee7ff':fg<75?'#22d673':'#a78bfa';
document.getElementById('fgNum').style.color=col;
document.getElementById('fgLbl').textContent=lbl;
document.getElementById('fgLbl').style.color=col;
</script>
<script>
  (function(){var t=localStorage.getItem('tt_dev_access'),s=localStorage.getItem('tt_sub_token');if(t!=='tt-ironclad-2026'&&!s){sessionStorage.setItem('tt_redirect',window.location.pathname);window.location.replace('/subscribe');}})();
</script>
</body>
</html>
