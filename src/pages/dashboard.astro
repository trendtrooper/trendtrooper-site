// ── Seeded random (same symbol → same sparkline every refresh) ───────────────
function seededRandom(str, i) {
  var h = 0;
  for (var ci = 0; ci < str.length; ci++) h = ((h << 5) - h) + str.charCodeAt(ci);
  return Math.abs(Math.sin(h + i));
}

// ── Clock + Market Status ────────────────────────────────────────────────────
function getEasternTime() {
  // Determine EDT vs EST: EDT (UTC-4) second Sunday in March → first Sunday in November
  var now = new Date();
  var yr = now.getUTCFullYear();
  // Second Sunday in March
  var marchFirst = new Date(Date.UTC(yr, 2, 1));
  var marchSunday = (7 - marchFirst.getUTCDay()) % 7;
  var dstStart = new Date(Date.UTC(yr, 2, 1 + marchSunday + 7, 2)); // +7 = second Sunday
  // First Sunday in November
  var novFirst = new Date(Date.UTC(yr, 10, 1));
  var novSunday = (7 - novFirst.getUTCDay()) % 7;
  var dstEnd = new Date(Date.UTC(yr, 10, 1 + novSunday, 2));
  var isDST = now >= dstStart && now < dstEnd;
  var offsetHrs = isDST ? -4 : -5;
  var tzLabel = isDST ? 'EDT' : 'EST';
  var et = new Date(now.getTime() + offsetHrs * 3600000);
  return { et: et, tzLabel: tzLabel };
}

function isMarketOpen(et) {
  var day = et.getUTCDay(); // 0=Sun,6=Sat
  if (day === 0 || day === 6) return false;
  var h = et.getUTCHours();
  var m = et.getUTCMinutes();
  var mins = h * 60 + m;
  return mins >= 570 && mins < 960; // 9:30am–4:00pm = 570–960
}

function tick() {
  var info = getEasternTime();
  var et = info.et;
  var tzLabel = info.tzLabel;
  var h = et.getUTCHours();
  var min = et.getUTCMinutes();
  var sec = et.getUTCSeconds();
  var ampm = h >= 12 ? 'PM' : 'AM';
  var h12 = h % 12 || 12;
  function z(n) { return n < 10 ? '0' + n : '' + n; }
  var timeStr = z(h12) + ':' + z(min) + ':' + z(sec) + ' ' + ampm + ' ' + tzLabel;
  document.getElementById('clock').textContent = timeStr;

  var open = isMarketOpen(et);
  var statusEl = document.getElementById('marketStatus');
  var dotEl = document.getElementById('marketDot');
  var txtEl = document.getElementById('marketStatusTxt');
  statusEl.className = 'market-status ' + (open ? 'open' : 'closed');
  dotEl.className = 'market-dot ' + (open ? 'open' : 'closed');
  txtEl.textContent = open ? 'MARKET OPEN' : 'MARKET CLOSED';
}
tick();
setInterval(tick, 1000);

// ── Simulated data helpers ───────────────────────────────────────────────────
function rnd(min, max) { return +(Math.random() * (max - min) + min).toFixed(2); }
function pct() { return rnd(-2.5, 2.5); }
function spark(sym) {
  var d = []; var v = 100;
  for (var i = 0; i < 20; i++) {
    v += (seededRandom(sym, i) * 4 - 2);
    d.push(+v.toFixed(2));
  }
  return d;
}

