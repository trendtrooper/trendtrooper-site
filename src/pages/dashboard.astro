// ── Watchlist helpers ────────────────────────────────────────────────────────
function getWatchlist() {
  try { return JSON.parse(localStorage.getItem('tt_watchlist') || '[]'); } catch(e) { return []; }
}
function saveWatchlist(arr) {
  localStorage.setItem('tt_watchlist', JSON.stringify(arr));
}
function addToWatchlist(sym) {
  var wl = getWatchlist();
  if (wl.indexOf(sym) === -1) wl.push(sym);
  saveWatchlist(wl);
  renderWatchlist();
  // Update button state
  var btn = document.querySelector('[data-save-sym="' + sym + '"]');
  if (btn) { btn.textContent = '★ Saved'; btn.classList.add('saved'); }
}
function removeFromWatchlist(sym) {
  var wl = getWatchlist().filter(function(s) { return s !== sym; });
  saveWatchlist(wl);
  renderWatchlist();
  // Update button state
  var btn = document.querySelector('[data-save-sym="' + sym + '"]');
  if (btn) { btn.textContent = '★ Save'; btn.classList.remove('saved'); }
}
function renderWatchlist() {
  var wl = getWatchlist();
  var container = document.getElementById('watchlistContent');
  if (!wl.length) {
    container.innerHTML = '<div class="watchlist-empty">No saved tickers yet. Click ★ Save on any ETF card to add it here.</div>';
    return;
  }
  var html = '<div class="watchlist-grid">';
  wl.forEach(function(sym) {
    html += '<div class="wl-item">'
      + '<a class="wl-ticker" href="/analysis?t=' + sym + '">' + sym + '</a>'
      + '<button class="wl-remove" onclick="removeFromWatchlist(\'' + sym + '\')" title="Remove">&#10005;</button>'
      + '</div>';
  });
  html += '</div>';
  container.innerHTML = html;
}

