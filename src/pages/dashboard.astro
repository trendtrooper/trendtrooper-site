---
import LogoutBar from "../components/LogoutBar.astro";
// TrendTrooper — Market Dashboard src/pages/dashboard.astro
---
<!doctype html>
<html lang="en">
<head>
<script>if(localStorage.getItem("tt_dev_access")!=="tt-ironclad-2026"&&!localStorage.getItem("tt_sub_token")){sessionStorage.setItem("tt_redirect",location.pathname);location.replace("/subscribe");}</script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>TrendTrooper — Market Dashboard</title>
  <meta name="description" content="Live-style market dashboard. Indices, leveraged ETFs, and signal summaries." />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root{
      --bg:#070e1c;--card:#0f1b33;--card2:#111e38;
      --muted:#7a96bb;--muted2:#4a6490;
      --text:#ddeeff;--text2:#b8d0ee;
      --accent:#6ee7ff;--accent2:#a78bfa;
      --green:#22d673;--red:#ff5c6a;--amber:#f59e0b;
      --border2:rgba(255,255,255,.06);--r:16px;--max:1160px;
      --mono:'JetBrains Mono',monospace;--sans:'Space Grotesk',sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);color:var(--text);background:var(--bg);min-height:100vh}
    a{color:inherit;text-decoration:none}
    header{position:sticky;top:0;z-index:100;height:70px;background:rgba(2,5,20,.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);display:flex;align-items:center;justify-content:space-between;padding:0 32px;}
    .tt-brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:#e8eeff;}
    .tt-logo{width:42px;height:42px;border-radius:10px;background:linear-gradient(135deg,#7040ff,#00cfff);display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-weight:900;font-size:14px;color:#fff;flex-shrink:0;box-shadow:0 0 20px rgba(112,64,255,.4);}
    .tt-name{font-family:'Orbitron',monospace;font-size:16px;font-weight:900;letter-spacing:2px;background:linear-gradient(90deg,#fff,#00cfff,#7040ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
    .tt-tag{font-size:9px;color:#00cfff;font-weight:600;letter-spacing:3px;text-transform:uppercase;display:block;opacity:.8;}
    .tt-nav{display:flex;align-items:center;gap:1px;white-space:nowrap;}
    .tt-nav a{color:#c8d8f0;padding:6px 9px;border-radius:8px;text-decoration:none;font-weight:800;font-size:11.5px;letter-spacing:.8px;text-transform:uppercase;transition:color .15s,background .15s;}
    .tt-nav a:hover{color:#e8eeff;background:rgba(0,200,255,.06);}
    .tt-nav a.cur{color:#00cfff;}
    .tt-cta{background:linear-gradient(135deg,#00cfff,#7040ff)!important;color:#fff!important;font-weight:800!important;padding:8px 14px!important;border-radius:8px!important;box-shadow:0 0 20px rgba(0,200,255,.2)!important;}
    .tt-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
    .tt-burger span{width:22px;height:2px;background:#e8eeff;border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
    .tt-burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .tt-burger.open span:nth-child(2){opacity:0;}
    .tt-burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .tt-mob{display:none;flex-direction:column;position:sticky;top:70px;z-index:99;background:rgba(2,5,20,.97);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);padding:8px 24px 16px;}
    .tt-mob.open{display:flex;}
    .tt-mob a{color:rgba(180,210,255,.65);padding:10px 0;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:1px;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.04);}
    .tt-mob a:hover{color:#e8eeff;}
    @media(max-width:900px){.tt-nav{display:none;}.tt-burger{display:flex;}}
    /* SIMULATED DATA BANNER */
    .sim-banner{width:100%;background:rgba(255,180,0,0.15);border-top:1px solid rgba(255,180,0,0.4);border-bottom:1px solid rgba(255,180,0,0.4);color:#ffb400;text-align:center;padding:10px 16px;font-family:'Orbitron',monospace;font-size:11px;font-weight:700;letter-spacing:1px;}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:9px 18px;border-radius:12px;font-weight:600;font-size:13.5px;border:1px solid var(--border2);background:rgba(255,255,255,.05);color:var(--text);cursor:pointer;transition:.15s;font-family:var(--sans)}
    .btn:hover{background:rgba(255,255,255,.08)}
    .btn.primary{background:linear-gradient(135deg,var(--accent),var(--accent2));border:none;color:#070e1c;font-weight:700}
    .wrap{max-width:var(--max);margin:0 auto;padding:32px 24px}
    .page-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:14px}
    .page-head h1{font-size:24px;font-weight:700}
    .live-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:999px;border:1px solid rgba(34,214,115,.3);background:rgba(34,214,115,.08);color:var(--green);font-size:12px;font-weight:700;font-family:var(--mono)}
    .pulse{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 12px rgba(34,214,115,.6);animation:pulse 2s ease-in-out infinite}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
    /* CLOCK + MARKET STATUS */
    .clock-wrap{display:flex;align-items:center;gap:12px;flex-wrap:wrap;justify-content:flex-end;}
    .clock-time{font-family:var(--mono);font-size:14px;color:var(--muted);}
    .market-status{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;border:1px solid;}
    .market-status.open{color:#22d673;border-color:rgba(34,214,115,.35);background:rgba(34,214,115,.08);}
    .market-status.closed{color:#ff5c6a;border-color:rgba(255,92,106,.35);background:rgba(255,92,106,.08);}
    .market-dot{width:7px;height:7px;border-radius:50%;display:inline-block;flex-shrink:0;}
    .market-dot.open{background:#22d673;box-shadow:0 0 8px rgba(34,214,115,.7);}
    .market-dot.closed{background:#ff5c6a;box-shadow:0 0 8px rgba(255,92,106,.7);}
    @media(max-width:600px){.clock-time{font-size:11px;}.market-status{font-size:10px;padding:3px 8px;}}
    /* INDEX GRID */
    .idx-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px}
    .idx-card{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);padding:18px 20px;position:relative;overflow:hidden;cursor:pointer;transition:.2s}
    .idx-card:hover{border-color:rgba(110,231,255,.25);transform:translateY(-2px)}
    .idx-card.up{border-top:2px solid var(--green)}
    .idx-card.dn{border-top:2px solid var(--red)}
    .idx-sym{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.5px;font-family:var(--mono);margin-bottom:6px}
    .idx-name{font-size:12px;color:var(--muted2);margin-bottom:10px}
    .idx-price{font-size:22px;font-weight:700;font-family:var(--mono);margin-bottom:4px}
    .idx-chg{font-size:13px;font-weight:700;font-family:var(--mono)}
    .up-txt{color:var(--green)}.dn-txt{color:var(--red)}
    .idx-spark{height:40px;margin-top:10px}
    /* LEVERAGED ETF SECTION */
    .section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
    .section-head h2{font-size:18px;font-weight:700}
    .section-head span{color:var(--muted);font-size:13px}
    .etf-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:28px}
    .etf-card{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);padding:20px;transition:.2s;cursor:pointer}
    .etf-card:hover{border-color:rgba(110,231,255,.3);transform:translateY(-2px);box-shadow:0 16px 50px rgba(0,0,0,.4)}
    .etf-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
    .etf-sym{font-size:18px;font-weight:700;font-family:var(--mono)}
    .etf-lev{font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px;background:rgba(110,231,255,.1);border:1px solid rgba(110,231,255,.25);color:var(--accent);font-family:var(--mono)}
    .etf-full{font-size:12px;color:var(--muted);margin-bottom:12px}
    .etf-price{font-size:26px;font-weight:700;font-family:var(--mono);margin-bottom:4px}
    .etf-chg{font-size:13px;font-weight:700;font-family:var(--mono);margin-bottom:14px}
    .signal-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
    .sig{font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;font-family:var(--mono)}
    .sig.buy{background:rgba(34,214,115,.12);border:1px solid rgba(34,214,115,.3);color:var(--green)}
    .sig.sell{background:rgba(255,92,106,.12);border:1px solid rgba(255,92,106,.3);color:var(--red)}
    .sig.hold{background:rgba(245,158,11,.10);border:1px solid rgba(245,158,11,.25);color:var(--amber)}
    .sig.neutral{background:rgba(255,255,255,.05);border:1px solid var(--border2);color:var(--muted)}
    .etf-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .etf-stat{background:rgba(255,255,255,.03);border-radius:10px;padding:10px 12px}
    .etf-stat .sl{font-size:10px;color:var(--muted2);font-weight:600;letter-spacing:.3px;margin-bottom:3px}
    .etf-stat .sv{font-size:13px;font-weight:700;font-family:var(--mono)}
    /* ETF card footer links */
    .etf-foot{display:flex;align-items:center;justify-content:space-between;margin-top:12px;padding-top:10px;border-top:1px solid var(--border2);}
    .etf-link{font-size:11px;font-weight:700;font-family:var(--mono);color:var(--accent);text-decoration:none;padding:3px 8px;border-radius:6px;border:1px solid rgba(110,231,255,.2);background:rgba(110,231,255,.05);transition:.15s;}
    .etf-link:hover{background:rgba(110,231,255,.12);border-color:rgba(110,231,255,.4);}
    .save-btn{font-size:11px;font-weight:700;font-family:var(--mono);color:var(--amber);background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25);padding:3px 8px;border-radius:6px;cursor:pointer;transition:.15s;}
    .save-btn:hover{background:rgba(245,158,11,.18);}
    .save-btn.saved{color:#22d673;background:rgba(34,214,115,.08);border-color:rgba(34,214,115,.3);}
    /* TWO COL */
    .two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:28px}
    /* HEATMAP */
    .heatmap-wrap{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);overflow:hidden}
    .panel-head{padding:14px 18px;border-bottom:1px solid var(--border2);display:flex;align-items:center;justify-content:space-between}
    .panel-head h3{font-size:14px;font-weight:700}
    .heatmap-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch;}
    .heatmap-grid{padding:16px;display:grid;grid-template-columns:repeat(5,1fr);gap:6px;min-width:360px;}
    .hm-cell{border-radius:10px;padding:10px 8px;text-align:center;cursor:pointer;transition:.15s;position:relative;}
    .hm-cell:hover{filter:brightness(1.15)}
    .hm-cell::after{content:attr(title);position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:#0a1830;border:1px solid rgba(110,231,255,.3);color:var(--accent);font-size:10px;font-family:var(--mono);padding:4px 8px;border-radius:6px;white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;z-index:10;}
    .hm-cell:hover::after{opacity:1;}
    .hm-sym{font-size:11px;font-weight:700;font-family:var(--mono)}
    .hm-chg{font-size:12px;font-weight:700;font-family:var(--mono);margin-top:2px}
    /* SIGNAL TABLE */
    .signal-table-wrap{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);overflow:hidden}
    table{width:100%;border-collapse:collapse}
    th{padding:12px 16px;font-size:11px;font-weight:700;color:var(--muted2);letter-spacing:.5px;text-align:left;border-bottom:1px solid var(--border2);background:rgba(255,255,255,.02)}
    td{padding:12px 16px;font-size:13px;border-bottom:1px solid rgba(255,255,255,.03)}
    tr:last-child td{border-bottom:none}
    tr.sig-row{cursor:pointer;}
    tr.sig-row:hover td{background:rgba(110,231,255,.04);}
    .td-sym{font-family:var(--mono);font-weight:700;color:var(--accent)}
    .view-analysis{font-size:10px;font-weight:700;font-family:var(--mono);color:var(--accent2);text-decoration:none;padding:2px 7px;border-radius:5px;border:1px solid rgba(167,139,250,.25);background:rgba(167,139,250,.07);white-space:nowrap;}
    .view-analysis:hover{background:rgba(167,139,250,.15);}
    /* FEAR GREED */
    .fg-wrap{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);padding:20px}
    .fg-meter{position:relative;height:120px;display:flex;align-items:center;justify-content:center;flex-direction:column}
    .fg-num{font-size:52px;font-weight:700;font-family:var(--mono)}
    .fg-label{font-size:13px;color:var(--muted);margin-top:4px;font-weight:600}
    .fg-scale-wrap{position:relative;margin-top:16px;}
    .fg-scale{display:flex;border-radius:999px;overflow:hidden;height:8px;}
    .fg-scale div{flex:1}
    .fg-marker-row{position:relative;height:14px;}
    .fg-marker{position:absolute;top:0;transform:translateX(-50%);font-size:11px;line-height:1;color:#fff;pointer-events:none;}
    /* WATCHLIST */
    .watchlist-section{margin-bottom:28px;}
    .watchlist-section h2{font-size:18px;font-weight:700;margin-bottom:14px;}
    .watchlist-empty{color:var(--muted);font-size:13px;font-family:var(--mono);padding:16px 0;}
    .watchlist-grid{display:flex;flex-wrap:wrap;gap:10px;}
    .wl-item{display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--border2);border-radius:10px;padding:8px 14px;font-family:var(--mono);font-size:13px;}
    .wl-ticker{color:var(--accent);font-weight:700;text-decoration:none;}
    .wl-ticker:hover{color:#fff;}
    .wl-remove{background:none;border:none;color:var(--red);font-size:13px;cursor:pointer;padding:0 2px;line-height:1;opacity:.7;}
    .wl-remove:hover{opacity:1;}
    footer{max-width:var(--max);margin:40px auto 0;padding:24px;border-top:1px solid var(--border2);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;color:var(--muted2);font-size:13px}
    .foot-links{display:flex;gap:18px}
    .foot-links a:hover{color:var(--muted)}
    @media(max-width:900px){
      .idx-grid{grid-template-columns:repeat(2,1fr)}
      .etf-grid{grid-template-columns:repeat(2,1fr)}
      .two-col{grid-template-columns:1fr}
      .navlinks{display:none}
      .hamburger{display:flex;}
    }
    @media(max-width:600px){
      .etf-grid{grid-template-columns:1fr 1fr}
    }
    .hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
    .hamburger span{width:20px;height:2px;background:var(--text);border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
    .hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .hamburger.open span:nth-child(2){opacity:0;}
    .hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .inner-mobile-menu{display:none;flex-direction:column;position:sticky;top:61px;z-index:99;background:rgba(7,14,28,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border2);padding:8px 24px 16px;}
    .inner-mobile-menu.open{display:flex;}
    .inner-mobile-menu a{color:var(--muted);text-decoration:none;font-weight:600;font-size:14px;padding:11px 0;border-bottom:1px solid var(--border2);transition:color .15s;}
    .inner-mobile-menu a:last-child{border-bottom:none;}
    .inner-mobile-menu a:hover{color:var(--text);}
  </style>
</head>
<body>
<header>
  <a class="tt-brand" href="/">
    <div class="tt-logo">TT</div>
    <div><div class="tt-name">TRENDTROOPER</div><span class="tt-tag">Signal Service</span></div>
  </a>
  <nav class="tt-nav">
    <a href="/#features">Features</a>
    <a href="/chart">Live Chart</a>
    <a href="/#markets">Markets</a>
    <a href="/#pricing">Pricing</a>
    <a href="/chart">Full Chart</a>
    <a href="/analysis">Analysis</a>
    <a href="/academy">Academy</a>
    <a href="https://bot.trendtrooper.com/" target="_blank">Bot Status</a>
    <a href="/#pricing" class="tt-cta">Get Started</a>
  </nav>
  <button class="tt-burger" id="ttBurger" onclick="this.classList.toggle('open');document.getElementById('ttMob').classList.toggle('open')" aria-label="Menu"><span></span><span></span><span></span></button>
</header>
<div class="tt-mob" id="ttMob">
  <a href="/#features">Features</a>
  <a href="/chart">Live Chart</a>
  <a href="/#markets">Markets</a>
  <a href="/#pricing">Pricing</a>
  <a href="/chart">Full Chart</a>
  <a href="/analysis">Analysis</a>
  <a href="/academy">Academy</a>
  <a href="https://bot.trendtrooper.com/" target="_blank">Bot Status</a>
  <a href="/#pricing">Get Started</a>
</div>

<!-- SIMULATED DATA BANNER -->
<div class="sim-banner">&#9888; Simulated data for demonstration purposes. Not real-time market data.</div>

<div class="wrap">
  <div class="page-head">
    <div>
      <h1>Market Dashboard</h1>
      <div style="color:var(--muted);font-size:13px;margin-top:4px">Indices · Leveraged ETFs · Sector signals · Fear &amp; Greed</div>
    </div>
    <div class="clock-wrap">
      <div class="clock-time" id="clock"></div>
      <div class="market-status closed" id="marketStatus"><span class="market-dot closed" id="marketDot"></span><span id="marketStatusTxt">MARKET CLOSED</span></div>
    </div>
  </div>

  <!-- MAJOR INDICES -->
  <div class="section-head"><h2>Major Indices</h2><span>15-min delayed • Simulated</span></div>
  <div class="idx-grid" id="idxGrid"></div>

  <!-- LEVERAGED ETFs -->
  <div class="section-head"><h2>Leveraged ETF Watch</h2><span>TrendTrooper auto-switch universe</span></div>
  <div class="etf-grid" id="etfGrid"></div>

  <div class="two-col">
    <!-- SECTOR HEATMAP -->
    <div class="heatmap-wrap">
      <div class="panel-head"><h3>Sector Heatmap</h3><span style="font-size:12px;color:var(--muted)">Today's performance</span></div>
      <div class="heatmap-scroll">
        <div class="heatmap-grid" id="heatGrid"></div>
      </div>
    </div>

    <!-- FEAR & GREED + SIGNAL TABLE -->
    <div style="display:flex;flex-direction:column;gap:14px">
      <div class="fg-wrap">
        <div class="panel-head" style="padding:0 0 12px"><h3>Fear &amp; Greed Index</h3></div>
        <div class="fg-meter">
          <div class="fg-num" id="fgNum" style="color:var(--amber)">62</div>
          <div class="fg-label" id="fgLbl">GREED</div>
        </div>
        <div class="fg-scale-wrap">
          <div class="fg-scale">
            <div style="background:#ff5c6a"></div>
            <div style="background:#f59e0b"></div>
            <div style="background:#6ee7ff"></div>
            <div style="background:#22d673"></div>
            <div style="background:#a78bfa"></div>
          </div>
          <div class="fg-marker-row">
            <div class="fg-marker" id="fgMarker">&#9650;</div>
          </div>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:4px;font-size:10px;color:var(--muted2);font-family:var(--mono)">
          <span>EXTREME FEAR</span><span>EXTREME GREED</span>
        </div>
      </div>

      <div class="signal-table-wrap">
        <div class="panel-head"><h3>Active Signals</h3><span style="font-size:12px;color:var(--muted)">Last 24h</span></div>
        <table>
          <thead><tr><th>SYMBOL</th><th>SIGNAL</th><th>ENTRY</th><th>STATUS</th><th>ACTION</th></tr></thead>
          <tbody id="sigTable"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- MY WATCHLIST -->
  <div class="watchlist-section" id="watchlistSection">
    <div class="section-head"><h2>My Watchlist</h2><span style="color:var(--muted);font-size:13px">Saved to your browser</span></div>
    <div id="watchlistContent"><div class="watchlist-empty">No saved tickers yet. Click &#9733; Save on any ETF card to add it here.</div></div>
  </div>
</div>

<footer>
  <div>TrendTrooper Dashboard &nbsp;&bull;&nbsp; &copy; <span id="yr"></span> &nbsp;&bull;&nbsp; Simulated data only</div>
  <div class="foot-links"><a href="/">Home</a><a href="/academy">Academy</a><a href="/screener">Screener</a></div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
document.getElementById('yr').textContent = new Date().getFullYear();

// ── Burger menu: close on mobile link click ──────────────────────────────────
document.querySelectorAll('#ttMob a').forEach(function(a) {
  a.addEventListener('click', function() {
    document.getElementById('ttMob').classList.remove('open');
