.mobile-bot-dot{
  width:7px;height:7px;border-radius:50%;
  background:var(--muted2);
  display:inline-block;flex-shrink:0;
  animation:pulse 1.8s ease-in-out infinite;
}

/* ── LIVE INDICATOR ── */
.live-indicator{
