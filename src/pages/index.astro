<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TrendTrooper — Algorithmic Trading Signals</title>
<meta name="description" content="Professional algorithmic trading signals for Canadian and US markets. Real-time alerts, live charts, and automated strategy execution.">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

:root{
  --bg:#020510;
  --bg2:rgba(4,8,30,0.85);
  --bg3:rgba(6,12,40,0.6);
  --cyan:#00cfff;
  --cyan-dim:rgba(0,200,255,0.08);
  --cyan-glow:rgba(0,200,255,0.25);
  --green:#00ff88;
  --green-dim:rgba(0,255,136,0.08);
  --purple:#7040ff;
  --purple-dim:rgba(112,64,255,0.15);
  --red:#ff4060;
  --yellow:#ffd060;
  --text:#e8eeff;
  --muted:rgba(220,235,255,0.95);
  --muted2:rgba(180,210,255,0.6);
  --border:rgba(0,200,255,0.1);
  --border2:rgba(0,200,255,0.2);
}

html{scroll-behavior:smooth;}

body{
  background:var(--bg) url('/city-bg.png') center center / cover no-repeat fixed;
  color:var(--text);
  font-family:'Rajdhani',sans-serif;
  line-height:1.6;
  overflow-x:hidden;
}

/* GRID OVERLAY */
body::before{
  content:'';
  position:fixed;
  inset:0;
  background-image:
    linear-gradient(rgba(0,200,255,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,200,255,0.025) 1px,transparent 1px);
  background-size:50px 50px;
  z-index:0;
  pointer-events:none;
}

/* RADIAL GLOW */
body::after{
  content:'';
  position:fixed;
  inset:0;
  background:
    radial-gradient(ellipse at 20% 0%,rgba(112,64,255,0.08) 0%,transparent 50%),
    radial-gradient(ellipse at 80% 100%,rgba(0,200,255,0.06) 0%,transparent 50%);
  z-index:0;
  pointer-events:none;
}

/* ── HEADER ── */
header{
  height:70px;
  background:rgba(2,5,20,0.9);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 32px;
  position:sticky;
  top:0;
  z-index:100;
}

.brand{
  display:flex;
  align-items:center;
  gap:12px;
  text-decoration:none;
  color:var(--text);
}

.logo{
  width:42px;height:42px;
  border-radius:10px;
  background:linear-gradient(135deg,var(--purple),var(--cyan));
  display:flex;align-items:center;justify-content:center;
  font-family:'Orbitron',monospace;
  font-weight:900;font-size:14px;
  color:#fff;
  flex-shrink:0;
  box-shadow:0 0 20px rgba(112,64,255,0.4);
}

.brand-name{
  font-family:'Orbitron',monospace;
  font-size:18px;font-weight:900;
  letter-spacing:2px;
  background:linear-gradient(90deg,#fff,var(--cyan),var(--purple));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}

.brand-tag{
  font-size:9px;color:var(--cyan);
  font-weight:600;letter-spacing:3px;
  text-transform:uppercase;display:block;
  opacity:0.8;
}

nav{display:flex;align-items:center;gap:4px;}

nav a{
  color:var(--muted2);
  padding:7px 14px;border-radius:8px;
  text-decoration:none;font-weight:600;font-size:13px;
  letter-spacing:1px;text-transform:uppercase;
  transition:color .15s,background .15s;
}

nav a:hover{color:var(--text);background:rgba(0,200,255,0.06);}

.nav-cta{
  background:linear-gradient(135deg,var(--cyan),var(--purple)) !important;
  color:#fff !important;font-weight:800 !important;
  padding:8px 20px !important;border-radius:8px;
  letter-spacing:2px;
  box-shadow:0 0 20px rgba(0,200,255,0.2);
}

.nav-cta:hover{opacity:.9 !important;background:linear-gradient(135deg,var(--cyan),var(--purple)) !important;}

/* ── HERO ── */
.hero{
  padding:100px 32px 80px;
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:1fr 420px;
  gap:60px;align-items:center;
  position:relative;z-index:1;
}

.hero-label{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--green-dim);
  border:1px solid rgba(0,255,136,0.25);
  color:var(--green);
  font-size:11px;font-weight:700;
  letter-spacing:3px;text-transform:uppercase;
  padding:6px 16px;border-radius:999px;
  margin-bottom:20px;
}

.test-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(255,208,96,0.08);
  border:1px solid rgba(255,208,96,0.3);
  border-radius:6px;padding:5px 14px;
  font-size:11px;color:var(--yellow);
  font-weight:700;letter-spacing:1px;
  margin-bottom:20px;
}

.pulse{
  width:7px;height:7px;border-radius:50%;
  background:var(--green);
  animation:pulse 1.8s ease-in-out infinite;
  box-shadow:0 0 8px var(--green);
}

@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.3;transform:scale(0.8);}}

h1{
  font-family:'Orbitron',monospace;
  font-size:clamp(36px,4vw,56px);
  font-weight:900;line-height:1.1;
  letter-spacing:-1px;margin-bottom:20px;
}

h1 .accent{
  background:linear-gradient(135deg,var(--cyan),var(--purple));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  display:block;
}

.hero-sub{
  font-size:17px;color:var(--muted2);
  max-width:500px;margin-bottom:36px;line-height:1.7;
}

.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:48px;}

.btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:13px 26px;border-radius:10px;
  font-family:'Rajdhani',sans-serif;
  font-weight:700;font-size:14px;
  letter-spacing:2px;text-transform:uppercase;
  text-decoration:none;cursor:pointer;border:none;
  transition:opacity .15s,transform .1s,box-shadow .15s;
}

.btn:active{transform:scale(.98);}

.btn-primary{
  background:linear-gradient(135deg,var(--cyan),var(--purple));
  color:#fff;
  box-shadow:0 0 25px rgba(0,200,255,0.25);
}

.btn-primary:hover{opacity:.9;box-shadow:0 0 35px rgba(0,200,255,0.4);}

.btn-secondary{
  background:rgba(255,255,255,0.04);
  color:var(--text);
  border:1px solid var(--border2);
}

.btn-secondary:hover{border-color:var(--cyan);color:var(--cyan);background:var(--cyan-dim);}

.hero-stats{display:flex;gap:36px;}

.hero-stat strong{
  display:block;
  font-family:'Orbitron',monospace;
  font-size:22px;font-weight:900;
  color:var(--cyan);
  text-shadow:0 0 15px rgba(0,200,255,0.5);
}

.hero-stat span{
  font-size:10px;color:var(--muted2);
  text-transform:uppercase;letter-spacing:2px;
  font-weight:600;
}

/* HERO PANEL */
.hero-panel{
  background:rgba(4,8,30,0.85);
  border:1px solid var(--border2);
  border-radius:16px;padding:24px;
  position:relative;overflow:hidden;
  backdrop-filter:blur(24px);
}

.hero-panel::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--cyan),var(--purple),transparent);
}

.panel-title{
  font-size:10px;font-weight:700;
  color:var(--cyan);letter-spacing:3px;
  text-transform:uppercase;margin-bottom:16px;
  display:flex;align-items:center;gap:6px;
}

.panel-title::before{
  content:'';width:3px;height:10px;border-radius:2px;
  background:linear-gradient(180deg,var(--cyan),var(--purple));
  display:inline-block;
}

.stat-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:8px;margin-bottom:16px;
}

.stat{
  background:rgba(255,255,255,0.03);
  border:1px solid var(--border);
  border-radius:8px;padding:10px;
}

.stat span{
  display:block;font-size:9px;
  color:var(--muted2);letter-spacing:2px;
  text-transform:uppercase;margin-bottom:4px;
}

.stat strong{
  font-family:'Orbitron',monospace;
  font-size:14px;font-weight:700;
}

.signal-row{
  display:flex;align-items:center;
  justify-content:space-between;
  padding:10px 0;
  border-bottom:1px solid var(--border);
}

.signal-row:last-child{border-bottom:none;}
.signal-name{font-weight:700;font-size:13px;letter-spacing:1px;}
.signal-ticker{font-size:10px;color:var(--muted2);margin-top:2px;letter-spacing:1px;}

.badge{
  font-size:10px;font-weight:800;
  padding:3px 10px;border-radius:6px;
  letter-spacing:1.5px;text-transform:uppercase;
  font-family:'Orbitron',monospace;
}

.badge-long{background:rgba(0,255,136,0.1);border:1px solid rgba(0,255,136,0.3);color:var(--green);}
.badge-wait{background:rgba(255,208,96,0.1);border:1px solid rgba(255,208,96,0.3);color:var(--yellow);}
.badge-short{background:rgba(255,64,96,0.1);border:1px solid rgba(255,64,96,0.3);color:var(--red);}

.panel-footer{
  margin-top:16px;padding-top:14px;
  border-top:1px solid var(--border);
  display:flex;align-items:center;
  justify-content:space-between;
  font-size:11px;color:var(--muted2);
  letter-spacing:1px;
}

.status-dot{
  width:6px;height:6px;background:var(--green);
  border-radius:50%;display:inline-block;
  margin-right:6px;box-shadow:0 0 6px var(--green);
  animation:pulse 1.8s ease-in-out infinite;
}

/* ── SECTIONS ── */
section{padding:80px 32px;position:relative;z-index:1;}
.section-inner{max-width:1200px;margin:0 auto;}

.section-label{
  color:var(--cyan);font-size:10px;
  font-weight:700;letter-spacing:4px;
  text-transform:uppercase;margin-bottom:12px;
  font-family:'Orbitron',monospace;
}

h2{
  font-family:'Orbitron',monospace;
  font-size:clamp(28px,3vw,40px);
  font-weight:900;letter-spacing:-0.5px;
  margin-bottom:16px;
}

.section-sub{
  color:var(--muted2);font-size:16px;
  max-width:560px;line-height:1.7;
  margin-bottom:56px;
}

/* ── FEATURES ── */
.features-bg{
  background:rgba(4,8,30,0.6);
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(10px);
}

.features-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:20px;
}

.feature-card{
  background:rgba(255,255,255,0.025);
  border:1px solid var(--border);
  border-radius:14px;padding:28px;
  position:relative;overflow:hidden;
  transition:border-color .2s,transform .2s;
}

.feature-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--cyan),transparent);
  opacity:0;transition:opacity .3s;
}

.feature-card:hover{border-color:rgba(0,200,255,0.3);transform:translateY(-3px);}
.feature-card:hover::before{opacity:1;}

.feature-icon{
  width:48px;height:48px;border-radius:12px;
  background:var(--cyan-dim);
  border:1px solid var(--border2);
  display:flex;align-items:center;justify-content:center;
  font-size:22px;margin-bottom:18px;
}

.feature-card h3{
  font-family:'Orbitron',monospace;
  font-size:14px;font-weight:700;
  margin-bottom:10px;letter-spacing:1px;
  color:var(--text);
}

.feature-card p{color:var(--muted2);font-size:14px;line-height:1.65;}

/* ── CHART ── */
.chart-section{background:transparent;}

.chart-wrap{
  background:rgba(4,8,30,0.85);
  border:1px solid var(--border2);
  border-radius:16px;overflow:hidden;
  backdrop-filter:blur(20px);
}

.chart-header{
  display:flex;align-items:center;gap:12px;
  padding:16px 20px;border-bottom:1px solid var(--border);
  flex-wrap:wrap;
}

.chart-title{
  font-family:'Orbitron',monospace;
  font-weight:700;font-size:13px;
  letter-spacing:2px;color:var(--cyan);
}

.chart-tools{display:flex;gap:8px;align-items:center;flex:1;flex-wrap:wrap;}

.symbol-input{
  background:#ffffff;
  border:1px solid #00cfff;
  color:#000000;
  padding:8px 14px;border-radius:8px;
  font-size:13px;font-weight:700;
  font-family:'Rajdhani',sans-serif;
  width:200px;outline:none;
  transition:border-color .15s;
  letter-spacing:1px;
}

.symbol-input:focus{border-color:var(--cyan);box-shadow:0 0 10px rgba(0,200,255,0.1);}

.chip{
  background:rgba(255,255,255,0.04);
  border:1px solid var(--border);
  color:var(--muted2);
  padding:6px 12px;border-radius:7px;
  font-size:12px;font-weight:700;
  cursor:pointer;transition:all .15s;
  letter-spacing:1px;
  font-family:'Rajdhani',sans-serif;
}

.chip:hover,.chip.active{
  background:var(--cyan-dim);
  color:var(--cyan);
  border-color:var(--cyan);
  box-shadow:0 0 10px rgba(0,200,255,0.1);
}

#tv_chart{height:560px;width:100%;background:var(--bg);}

/* ── HOW IT WORKS ── */
.hiw-bg{
  background:rgba(4,8,30,0.6);
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
}

.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}

.step{
  padding:30px;
  background:rgba(255,255,255,0.025);
  border:1px solid var(--border);
  border-radius:14px;
  position:relative;overflow:hidden;
}

.step::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--purple),transparent);
}

.step-num{
  width:36px;height:36px;
  background:linear-gradient(135deg,var(--cyan),var(--purple));
  color:#fff;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-family:'Orbitron',monospace;
  font-weight:900;font-size:14px;
  margin-bottom:18px;
  box-shadow:0 0 15px rgba(0,200,255,0.3);
}

.step h3{
  font-family:'Orbitron',monospace;
  font-size:13px;font-weight:700;
  margin-bottom:10px;letter-spacing:1px;
}

.step p{color:var(--muted2);font-size:14px;line-height:1.65;}

/* ── MARKETS ── */
.markets-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-bottom:40px;}

.market-card{
  background:rgba(255,255,255,0.025);
  border:1px solid var(--border);
  border-radius:14px;padding:24px;
  position:relative;overflow:hidden;
}

.market-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--cyan),transparent);
}

.market-card h3{
  font-family:'Orbitron',monospace;
  font-size:12px;font-weight:700;
  margin-bottom:14px;color:var(--cyan);
  letter-spacing:2px;text-transform:uppercase;
}

.ticker-list{display:flex;flex-wrap:wrap;gap:8px;}

.ticker-tag{
  background:rgba(0,200,255,0.05);
  border:1px solid var(--border);
  color:var(--muted2);
  padding:4px 12px;border-radius:6px;
  font-size:12px;font-weight:700;
  font-family:'Rajdhani',monospace;
  letter-spacing:1px;
  transition:all .15s;
}

.ticker-tag:hover{border-color:var(--cyan);color:var(--cyan);}

/* ── PRICING ── */
.pricing-bg{
  background:rgba(4,8,30,0.6);
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
}

.pricing-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:20px;max-width:900px;margin:0 auto;
}

.pricing-card{
  background:rgba(255,255,255,0.025);
  border:1px solid var(--border);
  border-radius:16px;padding:32px 28px;
  position:relative;overflow:hidden;
  transition:border-color .2s;
}

.pricing-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--border2),transparent);
}

.pricing-card.featured{
  border-color:rgba(0,200,255,0.35);
  background:linear-gradient(180deg,rgba(0,200,255,0.06) 0%,rgba(255,255,255,0.025) 100%);
  box-shadow:0 0 40px rgba(0,200,255,0.08);
}

.pricing-card.featured::before{
  background:linear-gradient(90deg,transparent,var(--cyan),transparent);
}

.featured-badge{
  position:absolute;top:-12px;left:50%;transform:translateX(-50%);
  background:linear-gradient(135deg,var(--cyan),var(--purple));
  color:#fff;font-size:9px;font-weight:900;
  letter-spacing:2px;text-transform:uppercase;
  padding:4px 16px;border-radius:999px;
  white-space:nowrap;
  font-family:'Orbitron',monospace;
}

.plan-name{
  font-family:'Orbitron',monospace;
  font-size:11px;font-weight:700;
  color:var(--muted2);text-transform:uppercase;
  letter-spacing:3px;margin-bottom:12px;
}

.plan-price{
  font-family:'Orbitron',monospace;
  font-size:44px;font-weight:900;
  letter-spacing:-2px;margin-bottom:4px;
  color:var(--text);
}

.plan-price sup{font-size:20px;vertical-align:top;margin-top:10px;display:inline-block;}
.plan-price .per{font-size:14px;font-weight:600;color:var(--muted2);letter-spacing:0;font-family:'Rajdhani',sans-serif;}

.plan-desc{color:var(--muted2);font-size:14px;margin-bottom:24px;}

.plan-features{list-style:none;margin-bottom:28px;}
.plan-features li{
  padding:8px 0;border-bottom:1px solid var(--border);
  font-size:14px;color:var(--muted2);
  display:flex;align-items:center;gap:8px;
}
.plan-features li:last-child{border-bottom:none;}
.plan-features li::before{content:'✓';color:var(--cyan);font-weight:900;}

.plan-btn{
  width:100%;padding:12px;border-radius:10px;
  font-family:'Rajdhani',sans-serif;
  font-weight:700;font-size:14px;letter-spacing:2px;
  text-transform:uppercase;
  cursor:pointer;border:1px solid var(--border2);
  background:rgba(255,255,255,0.04);
  color:var(--text);text-align:center;
  transition:all .15s;text-decoration:none;display:block;
}

.plan-btn:hover{border-color:var(--cyan);color:var(--cyan);}

.plan-btn.primary-btn{
  background:linear-gradient(135deg,var(--cyan),var(--purple));
  color:#fff;border:none;
  box-shadow:0 0 20px rgba(0,200,255,0.2);
}

.plan-btn.primary-btn:hover{opacity:.9;box-shadow:0 0 30px rgba(0,200,255,0.35);}

/* ── CTA ── */
.cta-section{background:transparent;}

.cta-banner{
  background:linear-gradient(135deg,rgba(0,200,255,0.08),rgba(112,64,255,0.08));
  border:1px solid var(--border2);
  border-radius:20px;padding:64px 48px;
  text-align:center;position:relative;overflow:hidden;
}

.cta-banner::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--cyan),var(--purple),transparent);
}

.cta-banner h2{font-size:clamp(28px,3vw,44px);margin-bottom:16px;}
.cta-banner p{color:var(--muted2);font-size:17px;max-width:500px;margin:0 auto 36px;}

/* ── FOOTER ── */
footer{
  background:rgba(2,4,16,0.95);
  border-top:1px solid var(--border);
  padding:48px 32px 32px;
  position:relative;z-index:1;
}

.footer-inner{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:2fr 1fr 1fr;
  gap:48px;margin-bottom:40px;
}

.footer-brand .brand-name{
  font-family:'Orbitron',monospace;
  font-size:16px;font-weight:900;margin-bottom:10px;
  letter-spacing:2px;
}

.footer-brand p{color:var(--muted2);font-size:13px;max-width:280px;line-height:1.6;}

.footer-col h4{
  font-family:'Orbitron',monospace;
  font-size:10px;font-weight:700;
  text-transform:uppercase;letter-spacing:3px;
  color:var(--cyan);margin-bottom:16px;
}

.footer-col a{
  display:block;color:var(--muted2);
  font-size:13px;text-decoration:none;
  margin-bottom:10px;transition:color .15s;
  letter-spacing:1px;
}

.footer-col a:hover{color:var(--cyan);}

.footer-bottom{
  max-width:1200px;margin:0 auto;
  padding-top:24px;border-top:1px solid var(--border);
  display:flex;align-items:center;
  justify-content:space-between;
  color:var(--muted2);font-size:12px;letter-spacing:1px;
}

.footer-bottom a{color:var(--muted2);text-decoration:none;}
