<script>
const KNOWN={FTS:"TSX:FTS",CNQ:"TSX:CNQ",HIVE:"TSX:HIVE",SU:"TSX:SU",RY:"TSX:RY",TD:"TSX:TD",ENB:"TSX:ENB",BCE:"TSX:BCE",SHOP:"TSX:SHOP",NFG:"TSXV:NFG",SPY:"AMEX:SPY",QQQ:"NASDAQ:QQQ",NVDA:"NASDAQ:NVDA",SOXL:"NASDAQ:SOXL",TSLA:"NASDAQ:TSLA",AMD:"NASDAQ:AMD",META:"NASDAQ:META",MSFT:"NASDAQ:MSFT",AAPL:"NASDAQ:AAPL",AMZN:"NASDAQ:AMZN",GOOGL:"NASDAQ:GOOGL",COIN:"NASDAQ:COIN",MSTR:"NASDAQ:MSTR",IWM:"AMEX:IWM",DIA:"AMEX:DIA",TQQQ:"NASDAQ:TQQQ",SQQQ:"NASDAQ:SQQQ"};

function normalizeSymbol(raw){const s=(raw||"").trim().toUpperCase().replace(/\s+/g,"");if(!s)return"TSX:FTS";if(s.includes(":"))return s;return KNOWN[s]||"TSX:"+s;}

function loadChart(symbolRaw){
  const input=document.getElementById("symbolInput");
  const container=document.getElementById("tv_chart");
  const symbol=normalizeSymbol(symbolRaw||input.value);
  input.value=symbol;
  document.querySelectorAll(".chip").forEach(c=>c.classList.toggle("active",c.dataset.symbol===symbol));
  container.innerHTML="";
  const iframe=document.createElement("iframe");
  iframe.src="https://s.tradingview.com/widgetembed/?symbol="+encodeURIComponent(symbol)+"&interval=5&theme=dark&style=1&timezone=America%2FNew_York&symboledit=1&saveimage=0&hidesidetoolbar=0&withdateranges=1";
  iframe.style.cssText="width:100%;height:100%;border:none;display:block;";
  iframe.setAttribute("scrolling","no");
  container.appendChild(iframe);
}

document.addEventListener("DOMContentLoaded",()=>{
  const input=document.getElementById("symbolInput");
  const loadBtn=document.getElementById("loadBtn");
  loadBtn.addEventListener("click",()=>loadChart());
  input.addEventListener("keydown",e=>{if(e.key==="Enter")loadChart();});
  document.querySelectorAll(".chip").forEach(btn=>btn.addEventListener("click",()=>loadChart(btn.dataset.symbol)));
  loadChart("TSX:FTS");
  fetchBotStatus();
  setInterval(fetchBotStatus,30000);
});

const BOT_URL="https://bot.trendtrooper.com/status";

function timeAgo(iso){const diff=Math.floor((Date.now()-new Date(iso))/1000);if(diff<60)return diff+"s ago";if(diff<3600)return Math.floor(diff/60)+"m ago";return Math.floor(diff/3600)+"h ago";}

function fetchBotStatus(){fetch(BOT_URL,{cache:"no-store"}).then(r=>r.json()).then(d=>updateBotUI(d)).catch(()=>updateBotUI(null));}

function fmtPnl(val){if(val===null||val===undefined)return"—";const sign=val>=0?"+":"";return sign+"$"+val.toFixed(2);}

function updateBotUI(d){
  const get=id=>document.getElementById(id);
  if(!d){
    if(get("botStatus")){get("botStatus").textContent="Offline";get("botStatus").style.color="var(--red)";}
    if(get("botDot"))get("botDot").style.background="var(--red)";
    if(get("botFooter"))get("botFooter").textContent="Bot offline";
    if(get("lastUpdated"))get("lastUpdated").textContent="Checked "+new Date().toLocaleTimeString();
    if(get("signalBoard"))get("signalBoard").innerHTML='<div class="signal-row" style="color:var(--muted2);font-size:13px;padding:16px 0;">Bot is offline</div>';
    return;
  }
  if(get("botStatus")){get("botStatus").textContent="Online";get("botStatus").style.color="var(--green)";}
  if(get("botDot"))get("botDot").style.background="var(--green)";
  if(get("ibkrStatus")){get("ibkrStatus").textContent=d.ibkr_connected?"Connected":"Disconnected";get("ibkrStatus").style.color=d.ibkr_connected?"var(--green)":"var(--yellow)";}
  if(get("botMode")){get("botMode").textContent=d.mode||"—";get("botMode").style.color="var(--text)";}
  if(get("posCount")){get("posCount").textContent=d.positions||0;get("posCount").style.color="var(--cyan)";}
  if(get("todayTrades")){get("todayTrades").textContent=d.trades??0;get("todayTrades").style.color="var(--cyan)";}
  if(get("dailyPnl")&&d.daily_pnl!==undefined){get("dailyPnl").textContent=fmtPnl(d.daily_pnl);get("dailyPnl").style.color=d.daily_pnl>=0?"var(--green)":"var(--red)";}
  if(get("botFooter"))get("botFooter").textContent="Bot online · "+(d.mode||"");
  if(get("lastUpdated"))get("lastUpdated").textContent=d.timestamp?timeAgo(d.timestamp):"Updated "+new Date().toLocaleTimeString();
  if(get("signalBoard")){
    const trades=d.recent_trades||d.signals||[];
    if(trades.length>0){
      get("signalBoard").innerHTML=trades.slice(0,3).map(t=>{
        const act=(t.action||t.direction||"").toUpperCase();
        const cls=act==="BUY"||act==="LONG"?"badge-long":act==="SELL"||act==="SHORT"?"badge-short":"badge-wait";
        return`<div class="signal-row"><div><div class="signal-name">${t.symbol||t.ticker||"—"}</div><div class="signal-ticker">${t.timestamp?timeAgo(t.timestamp):""}</div></div><span class="badge ${cls}">${act||"—"}</span></div>`;
      }).join('');
    } else {
      get("signalBoard").innerHTML='<div class="signal-row" style="color:var(--muted2);font-size:13px;padding:16px 0;letter-spacing:1px;">Bot running · awaiting setup</div>';
    }
  }
}

// ── Mobile menu ──
function toggleMobileMenu(){
  document.getElementById('mobileMenu').classList.toggle('open');
  document.getElementById('hamburgerBtn').classList.toggle('open');
}
function closeMobileMenu(){
  document.getElementById('mobileMenu').classList.remove('open');
  document.getElementById('hamburgerBtn').classList.remove('open');
}

// ── Waitlist modal ──
function openWaitlist(){
  document.getElementById('waitlistModal').classList.add('open');
  setTimeout(()=>document.getElementById('waitlistEmail').focus(),50);
}
function closeWaitlist(){
  document.getElementById('waitlistModal').classList.remove('open');
  document.getElementById('waitlistForm').style.display='';
  document.getElementById('waitlistSuccess').style.display='none';
  document.getElementById('waitlistEmail').value='';
  document.getElementById('waitlistEmail').classList.remove('error');
}
function submitWaitlist(){
  const input=document.getElementById('waitlistEmail');
  const email=input.value.trim();
  if(!email||!email.includes('@')){input.classList.add('error');input.focus();return;}
  input.classList.remove('error');
  try{localStorage.setItem('tt_waitlist',email);}catch(e){}
  window.open('mailto:chrishicks83@hotmail.com?subject=TrendTrooper%20Waitlist&body=Please%20add%20me%20to%20the%20TrendTrooper%20waitlist.%0AEmail%3A%20'+encodeURIComponent(email),'_blank');
  document.getElementById('waitlistForm').style.display='none';
  document.getElementById('waitlistSuccess').style.display='block';
  document.getElementById('waitlistEmailDisplay').textContent=email;
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeWaitlist();});

// ── FAQ accordion ──
document.querySelectorAll('.faq-item').forEach(item=>{
  item.querySelector('.faq-q').addEventListener('click',()=>{
    const isOpen=item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
    if(!isOpen)item.classList.add('open');
  });
});

// ── Copyright year ──
const cyEl=document.getElementById('copyrightYear');
if(cyEl)cyEl.textContent=new Date().getFullYear();
</script>

<!-- WAITLIST MODAL -->
<div class="modal-overlay" id="waitlistModal" onclick="if(event.target===this)closeWaitlist()">
  <div class="modal-box">
    <button class="modal-close" onclick="closeWaitlist()" aria-label="Close">×</button>
    <div style="font-size:36px;margin-bottom:14px;">🚀</div>
    <h2 style="font-family:'Orbitron',monospace;font-size:20px;font-weight:900;margin-bottom:8px;letter-spacing:1px;">Join the Waitlist</h2>
    <p style="color:var(--muted2);font-size:14px;line-height:1.6;margin-bottom:28px;">TrendTrooper is in private beta. Enter your email and we'll reach out when access opens.</p>
    <div id="waitlistForm">
      <input id="waitlistEmail" class="modal-email-input" type="email" placeholder="your@email.com" onkeydown="if(event.key==='Enter')submitWaitlist()">
      <button onclick="submitWaitlist()" class="btn btn-primary" style="width:100%;justify-content:center;font-size:14px;padding:13px;">Request Access</button>
    </div>
    <div id="waitlistSuccess" class="modal-success">
      <div style="color:var(--green);font-size:44px;margin-bottom:12px;">✓</div>
      <p style="color:var(--green);font-weight:700;font-size:16px;margin-bottom:8px;">You're on the list!</p>
      <p style="color:var(--muted2);font-size:13px;">We'll reach out to <strong id="waitlistEmailDisplay" style="color:var(--text)"></strong> when TrendTrooper opens access.</p>
    </div>
  </div>
</div>

</body>
</html>
