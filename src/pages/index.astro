---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>TrendTrooper</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <nav>
        <div class="brand"><span>TT</span> TrendTrooper</div>
        <div class="links">
          <a href="/">Home</a>
          <a href="/chart">Full Chart</a>
          <a href="https://bot.trendtrooper.com">Bot Status</a>
        </div>
      </nav>

      <section class="dashboard">
        <div class="left">
          <p class="tag">LIVE TRADING DASHBOARD</p>
          <h1>TrendTrooper Command Center</h1>
          <p class="sub">
            Live FTS chart, TradingView alerts, webhook bot status, and trading tools in one clean dashboard.
          </p>

          <div class="actions">
            <a class="primary" href="/chart">Open Full Chart</a>
            <a class="secondary" href="https://bot.trendtrooper.com">Check Bot</a>
          </div>

          <div class="cards">
            <div><small>Symbol</small><b>FTS / NYSE</b></div>
            <div><small>Timeframe</small><b>5 min</b></div>
            <div><small>Mode</small><b>Paper</b></div>
            <div><small>Status</small><b class="green">Online</b></div>
          </div>
        </div>

        <div class="right">
          <div class="panel price-panel">
            <div class="panel-title">Live FTS Price</div>
            <iframe
              src="https://s.tradingview.com/embed-widget/symbol-info/?locale=en#%7B%22symbol%22%3A%22NYSE%3AFTS%22%2C%22width%22%3A%22100%25%22%2C%22height%22%3A%22180%22%2C%22colorTheme%22%3A%22dark%22%2C%22isTransparent%22%3Atrue%7D"
              width="100%"
              height="180"
              frameborder="0"
              scrolling="no">
            </iframe>
          </div>

          <div class="panel log-panel">
            <div class="panel-title">Bot Feed</div>
            <p>&gt; webhook armed</p>
            <p>&gt; bot.trendtrooper.com online</p>
            <p>&gt; waiting for TradingView alert...</p>
          </div>
        </div>
      </section>

      <section class="chart-panel">
        <div class="panel-title">Live TradingView Chart</div>

        <iframe
          src="https://www.tradingview.com/widgetembed/?symbol=NYSE%3AFTS&interval=5&theme=dark&style=1&timezone=America%2FSt_Johns&hide_top_toolbar=false&hide_side_toolbar=false&withdateranges=true&studies=%5B%5D"
          width="100%"
          height="620"
          frameborder="0"
          allowtransparency="true"
          scrolling="no">
        </iframe>
      </section>
    </main>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Inter, Arial, sans-serif;
    background: #050814;
    color: white;
  }

  main {
    min-height: 100vh;
    padding: 22px;
    background:
      radial-gradient(circle at top left, rgba(47, 124, 255, 0.18), transparent 28%),
      radial-gradient(circle at top right, rgba(57, 217, 138, 0.12), transparent 26%),
      #050814;
  }

  nav {
    max-width: 1320px;
    margin: 0 auto 38px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    font-size: 20px;
    font-weight: 900;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .brand span {
    width: 38px;
    height: 38px;
    border-radius: 12px;
    background: linear-gradient(135deg, #2f7cff, #39d98a);
    color: #06101f;
    display: grid;
    place-items: center;
  }

  .links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  a {
    color: white;
    text-decoration: none;
    font-weight: 800;
  }

  .links a,
  .actions a {
    padding: 11px 16px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,.12);
    background: rgba(255,255,255,.05);
  }

  .dashboard {
    max-width: 1320px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    gap: 22px;
    align-items: stretch;
  }

  .left,
  .panel,
  .chart-panel {
    background: rgba(255,255,255,.055);
    border: 1px solid rgba(255,255,255,.11);
    border-radius: 22px;
    box-shadow: 0 18px 70px rgba(0,0,0,.32);
  }

  .left {
    padding: 32px;
  }

  .tag {
    margin: 0 0 12px;
    color: #39d98a;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 2px;
  }

  h1 {
    margin: 0;
    font-size: clamp(34px, 5vw, 62px);
    line-height: 1;
    letter-spacing: -2px;
  }

  .sub {
    max-width: 720px;
    color: #b8c2d8;
    font-size: 18px;
    line-height: 1.45;
    margin: 18px 0 24px;
  }

  .actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 26px;
  }

  .primary {
    background: linear-gradient(135deg, #2f7cff, #0057ff) !important;
    box-shadow: 0 12px 34px rgba(47,124,255,.28);
  }

  .secondary {
    background: rgba(255,255,255,.06);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .cards div {
    padding: 16px;
    border-radius: 16px;
    background: rgba(0,0,0,.26);
    border: 1px solid rgba(255,255,255,.08);
  }

  small {
    display: block;
    color: #8d99b0;
    margin-bottom: 6px;
  }

  b {
    font-size: 17px;
  }

  .green {
    color: #39d98a;
  }

  .right {
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 22px;
  }

  .panel {
    padding: 18px;
    overflow: hidden;
  }

  .panel-title {
    font-size: 14px;
    color: #9facbf;
    font-weight: 900;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .log-panel {
    font-family: monospace;
    color: #9fe7bd;
    font-size: 15px;
  }

  .log-panel p {
    margin: 10px 0;
  }

  .chart-panel {
    max-width: 1320px;
    margin: 22px auto 0;
    padding: 18px;
    overflow: hidden;
  }

  .chart-panel iframe {
    border-radius: 16px;
    background: #07101f;
  }

  @media (max-width: 950px) {
    main {
      padding: 16px;
    }

    nav {
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
      margin-bottom: 22px;
    }

    .dashboard {
      grid-template-columns: 1fr;
    }

    .left {
      padding: 24px;
    }

    .cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .chart-panel iframe {
      height: 520px;
    }
  }

  @media (max-width: 520px) {
    h1 {
      font-size: 36px;
    }

    .sub {
      font-size: 16px;
    }

    .cards {
      grid-template-columns: 1fr;
    }

    .chart-panel iframe {
      height: 460px;
    }
  }
</style>
