  <div class="hero-panel">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
      <div class="panel-title" style="margin-bottom:0;">Live Bot Status</div>
      <span style="background:#f59e0b22;color:#f59e0b;font-size:10px;font-weight:800;letter-spacing:1px;padding:3px 8px;border-radius:4px;border:1px solid #f59e0b55;text-transform:uppercase;">Paper Testing</span>
