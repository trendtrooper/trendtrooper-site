<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TrendTrooper Dashboard</title>

<style>
* { box-sizing: border-box; }

body {
  margin: 0;
  background: #070b10;
  color: #e5e7eb;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto;
}

/* NAV */
header {
  height: 70px;
  background: #0b1118;
  border-bottom: 1px solid #1f2937;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 25px;
}

.logo {
  font-weight: 800;
  font-size: 20px;
}

nav a {
  color: #9ca3af;
  margin-left: 20px;
  text-decoration: none;
}

nav a:hover { color: #00ff88; }

/* LAYOUT */
.dashboard {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 20px;
  padding: 20px;
}

.card {
  background: #0b1118;
  border: 1px solid #1f2937;
  border-radius: 16px;
  padding: 15px;
}

h2 { margin-top: 0; }

/* CHART */
.chart-tools {
  display: flex;
  gap: 10px;
  margin-bottom: 10px;
  flex-wrap: wrap;
}

input {
  background: #070b10;
  border: 1px solid #1f2937;
  color: #fff;
  padding: 8px;
  border-radius: 6px;
}

button {
  background: #111827;
  border: 1px solid #1f2937;
  color: #fff;
  padding: 8px 12px;
  border-radius: 6px;
  cursor: pointer;
}

button:hover {
  background: #00ff88;
  color: #000;
}

/* SIDEBAR */
.side {
  display: grid;
  gap: 20px;
}

.green { color: #00ff88; }
.red { color: #ff4d4d; }
.yellow { color: #facc15; }

.feed {
  font-family: monospace;
  color: #9ca3af;
  font-size: 13px;
}

.signal {
  display: flex;
  justify-content: space-between;
  padding: 6px 0;
  border-bottom: 1px solid #1f2937;
}
</style>
</head>

<body>

<header>
  <div class="logo">TrendTrooper</div>
  <nav>
    <a href="https://www.trendtrooper.com/">Home</a>
    <a href="https://www.trendtrooper.com/chart">Full Chart</a>
    <a href="https://bot.trendtrooper.com/">Bot Status</a>
  </nav>
</header>

<main class="dashboard">

<!-- LEFT SIDE -->
<section class="card">
  <h2>Live TradingView Chart</h2>

  <div class="chart-tools">
    <input id="symbolInput" value="NYSE:FTS">
    <button onclick="loadChart()">Load</button>
    <button onclick="setSymbol('NYSE:FTS')">FTS</button>
    <button onclick="setSymbol('AMEX:SPY')">SPY</button>
    <button onclick="setSymbol('NASDAQ:QQQ')">QQQ</button>
    <button onclick="setSymbol('NASDAQ:AAPL')">AAPL</button>
    <button onclick="setSymbol('NASDAQ:TSLA')">TSLA</button>
  </div>

  <div id="tv_chart" style="height:550px;width:100%;border-radius:10px;overflow:hidden;"></div>
</section>

<!-- RIGHT SIDE -->
<aside class="side">

  <section class="card">
    <h2>System Status</h2>
    <div>Bot: <span class="green">Online</span></div>
    <div>Mode: Paper</div>
    <div>Symbol: <span id="activeSymbol">FTS</span></div>
    <div>Timeframe: 5m</div>
  </section>

  <section class="card">
    <h2>Signal Board</h2>
    <div class="signal">LONG FILTER <span class="green">READY</span></div>
    <div class="signal">PULLBACK <span class="yellow">SCANNING</span></div>
    <div class="signal">RISK <span class="green">CONTROLLED</span></div>
    <div class="signal">CHASE <span class="red">BLOCKED</span></div>
  </section>

  <section class="card">
    <h2>Watchlist</h2>
    <button onclick="setSymbol('NYSE:FTS')">FTS</button>
    <button onclick="setSymbol('AMEX:SPY')">SPY</button>
    <button onclick="setSymbol('NASDAQ:QQQ')">QQQ</button>
    <button onclick="setSymbol('NASDAQ:AAPL')">AAPL</button>
    <button onclick="setSymbol('NASDAQ:TSLA')">TSLA</button>
  </section>

  <section class="card">
    <h2>Bot Feed</h2>
    <div class="feed">
      &gt; webhook armed<br>
      &gt; bot online<br>
      &gt; waiting for alerts<br>
      &gt; paper mode active
    </div>
  </section>

</aside>

</main>

<script>
function shortSymbol(symbol) {
  return symbol.includes(":") ? symbol.split(":")[1] : symbol;
}

function loadChart() {
  const symbol = document.getElementById("symbolInput").value || "NYSE:FTS";

  document.getElementById("activeSymbol").textContent = shortSymbol(symbol);

  document.getElementById("tv_chart").innerHTML = `
    <iframe
      src="https://s.tradingview.com/widgetembed/?symbol=${encodeURIComponent(symbol)}&interval=5&theme=dark&style=1&timezone=America%2FNew_York"
      style="width:100%;height:100%;border:none;">
    </iframe>
  `;
}

function setSymbol(symbol) {
  document.getElementById("symbolInput").value = symbol;
  loadChart();
}

window.onload = loadChart;
</script>

</body>
</html>
