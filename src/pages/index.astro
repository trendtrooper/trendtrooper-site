}
.faq-q:hover{color:var(--cyan);}
.faq-toggle{color:var(--cyan);font-size:22px;font-weight:300;line-height:1;flex-shrink:0;transition:transform .2s;}
.faq-item.open .faq-toggle{transform:rotate(45deg);}
.faq-a{max-height:0;overflow:hidden;color:var(--muted2);font-size:14px;line-height:1.7;transition:max-height .35s ease,padding .35s ease;padding:0 22px;}
