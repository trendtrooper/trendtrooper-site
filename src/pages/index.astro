---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>TrendTrooper</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <div class="grid-bg"></div>

      <nav>
        <div class="brand">
          <span class="mark">TT</span>
          <span>TrendTrooper</span>
        </div>

        <div class="navlinks">
          <a href="/">Home</a>
          <a href="/chart">Chart</a>
          <a href="https://bot.trendtrooper.com">Bot Status</a>
        </div>
      </nav>

      <section class="hero">
        <div class="left">
          <div class="badge">LIVE TRADING COMMAND CENTER</div>

          <h1>
            Trade the pullback.<br />
            Execute with precision.
          </h1>

          <p>
            TrendTrooper connects TradingView alerts, automated webhook execution,
            chart analysis, and bot monitoring into one clean trading command center.
          </p>

          <div class="actions">
            <a class="primary" href="/chart">Launch Trading Chart</a>
            <a class="ghost" href="https://bot.trendtrooper.com">Check Bot Status</a>
          </div>

          <div class="stats">
            <div><b>5m</b><span>Primary setup</span></div>
            <div><b>FTS</b><span>Active symbol</span></div>
            <div><b>Paper</b><span>Execution mode</span></div>
          </div>
        </div>

        <div class="terminal">
          <div class="terminal-top">
            <span></span><span></span><span></span>
            <p>trendtrooper_bot</p>
          </div>

          <div class="price-row">
            <div>
              <small>FTS / NYSE</small>
              <h2>$55.36</h2>
            </div>
            <strong class="online">BOT ONLINE</strong>
          </div>

          <div class="signal buy">LONG FILTER: READY</div>
          <div class="signal wait">PULLBACK: SCANNING</div>
          <div class="signal risk">RISK MODE: CONTROLLED</div>

          <div class="mini-chart">
            <i></i><i></i><i></i><i></i><i></i><i></i><i></i>
          </div>

          <div class="bot-log">
            <p>&gt; webhook armed</p>
            <p>&gt; TradingView connected</p>
            <p>&gt; waiting for clean signal...</p>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Inter, Arial, sans-serif;
    background: #030712;
    color: white;
    overflow-x: hidden;
  }

  main {
    min-height: 100vh;
    position: relative;
    padding: 28px;
    background:
      radial-gradient(circle at 15% 20%, rgba(0,122,255,.35), transparent 28%),
      radial-gradient(circle at 85% 15%, rgba(57,217,138,.25), transparent 25%),
      radial-gradient(circle at 75% 85%, rgba(255,80,80,.18), transparent 24%),
      linear-gradient(135deg, #020617, #070b18 55%, #020617);
  }

  .grid-bg {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(circle, black, transparent 75%);
    pointer-events: none;
  }

  nav {
    position: relative;
    z-index: 2;
    max-width: 1240px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    display: flex;
    gap: 12px;
    align-items: center;
    font-weight: 900;
    font-size: 22px;
  }

  .mark {
    background: linear-gradient(135deg, #2f7cff, #39d98a);
    color: #020617;
    width: 44px;
    height: 44px;
    border-radius: 14px;
    display: grid;
    place-items: center;
    font-weight: 1000;
  }

  .navlinks {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  a {
    color: white;
    text-decoration: none;
    font-weight: 900;
  }

  .navlinks a {
    border: 1px solid rgba(255,255,255,.14);
    padding: 11px 18px;
    border-radius: 999px;
    background: rgba(255,255,255,.05);
  }

  .hero {
    position: relative;
    z-index: 2;
    max-width: 1240px;
    margin: 100px auto 0;
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    gap: 60px;
    align-items: center;
  }

  .badge {
    display: inline-block;
    color: #39d98a;
    background: rgba(57,217,138,.1);
    border: 1px solid rgba(57,217,138,.25);
    padding: 9px 14px;
    border-radius: 999px;
    font-size: 13px;
    letter-spacing: 2px;
    font-weight: 1000;
    margin-bottom: 22px;
  }

  h1 {
    font-size: clamp(52px, 7vw, 104px);
    line-height: .88;
    letter-spacing: -5px;
    margin: 0;
  }

  .left p {
    color: #b9c4da;
    font-size: 22px;
    line-height: 1.55;
    max-width: 680px;
    margin: 28px 0 34px;
  }

  .actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .actions a {
    padding: 16px 24px;
    border-radius: 16px;
  }

  .primary {
    background: linear-gradient(135deg, #2f7cff, #0057ff);
    box-shadow: 0 18px 50px rgba(47,124,255,.42);
  }

  .ghost {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.14);
  }

  .stats {
    margin-top: 42px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    max-width: 620px;
  }

  .stats div {
    padding: 18px;
    border-radius: 20px;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
  }

  .stats b {
    display: block;
    font-size: 28px;
  }

  .stats span {
    color: #8996ad;
    font-size: 13px;
  }

  .terminal {
    border-radius: 30px;
    padding: 26px;
    background: rgba(3,7,18,.72);
    border: 1px solid rgba(255,255,255,.14);
    box-shadow: 0 40px 120px rgba(0,0,0,.55);
    backdrop-filter: blur(18px);
  }

  .terminal-top {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 28px;
  }

  .terminal-top span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #ff5f57;
  }

  .terminal-top span:nth-child(2) {
    background: #ffbd2e;
  }

  .terminal-top span:nth-child(3) {
    background: #28c840;
  }

  .terminal-top p {
    margin: 0 0 0 12px;
    color: #8c98ad;
    font-size: 14px;
  }

  .price-row {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 14px;
  }

  small {
    color: #8c98ad;
    font-weight: 900;
  }

  h2 {
    font-size: 72px;
    letter-spacing: -4px;
    margin: 8px 0 4px;
  }

  .online {
    color: #39d98a;
    background: rgba(57,217,138,.12);
    padding: 10px 13px;
    border-radius: 999px;
    font-size: 12px;
    white-space: nowrap;
  }

  .signal {
    margin-top: 14px;
    padding: 16px;
    border-radius: 16px;
    font-weight: 1000;
    letter-spacing: .5px;
  }

  .buy {
    background: rgba(57,217,138,.12);
    color: #39d98a;
  }

  .wait {
    background: rgba(47,124,255,.12);
    color: #5aa7ff;
  }

  .risk {
    background: rgba(255,190,60,.12);
    color: #ffca63;
  }

  .mini-chart {
    height: 150px;
    display: flex;
    align-items: end;
    gap: 12px;
    margin: 30px 0;
  }

  .mini-chart i {
    flex: 1;
    border-radius: 999px 999px 0 0;
    background: linear-gradient(to top, #2f7cff, #39d98a);
    box-shadow: 0 0 30px rgba(57,217,138,.35);
  }

  .mini-chart i:nth-child(1) { height: 42%; }
  .mini-chart i:nth-child(2) { height: 58%; }
  .mini-chart i:nth-child(3) { height: 36%; }
  .mini-chart i:nth-child(4) { height: 72%; }
  .mini-chart i:nth-child(5) { height: 64%; }
  .mini-chart i:nth-child(6) { height: 88%; }
  .mini-chart i:nth-child(7) { height: 76%; }

  .bot-log {
    background: rgba(0,0,0,.38);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 18px;
    padding: 18px;
    color: #9fe7bd;
    font-family: monospace;
  }

  .bot-log p {
    margin: 8px 0;
  }

  @media (max-width: 900px) {
    main {
      padding: 20px;
    }

    nav {
      align-items: flex-start;
      gap: 18px;
      flex-direction: column;
    }

    .hero {
      grid-template-columns: 1fr;
      margin-top: 64px;
      gap: 36px;
    }

    h1 {
      font-size: clamp(44px, 13vw, 64px);
      letter-spacing: -3px;
    }

    .left p {
      font-size: 18px;
    }

    .stats {
      grid-template-columns: 1fr;
    }

    h2 {
      font-size: 52px;
    }

    .terminal {
      padding: 20px;
    }
  }
</style>
