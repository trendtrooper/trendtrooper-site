      <span><span class="status-dot" id="botDot" style="background:var(--muted)"></span><span id="botFooter">Connecting…</span></span>
      <span id="lastUpdated">—</span>
    </div>
  </div>
</div>

<!-- FEATURES -->
<section class="features-bg" id="features">
  <div class="section-inner">
    <div class="section-label">Why TrendTrooper</div>
    <h2>Built for serious traders</h2>
    <p class="section-sub">Everything you need to trade smarter — real signals, real data, no fluff.</p>

