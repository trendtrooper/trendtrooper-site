<script>
// ── Symbol normalization ──
const KNOWN = {
  // Canadian
  FTS: "TSX:FTS", CNQ: "TSX:CNQ", HIVE: "TSX:HIVE", SU: "TSX:SU",
  RY: "TSX:RY", TD: "TSX:TD", ENB: "TSX:ENB", BCE: "TSX:BCE",
  SHOP: "TSX:SHOP", NFG: "TSXV:NFG",
  // US
  SPY: "AMEX:SPY", QQQ: "NASDAQ:QQQ", NVDA: "NASDAQ:NVDA",
  SOXL: "NASDAQ:SOXL", TSLA: "NASDAQ:TSLA", AMD: "NASDAQ:AMD",
  META: "NASDAQ:META", MSFT: "NASDAQ:MSFT", AAPL: "NASDAQ:AAPL",
  AMZN: "NASDAQ:AMZN", GOOGL: "NASDAQ:GOOGL", COIN: "NASDAQ:COIN",
  MSTR: "NASDAQ:MSTR", IWM: "AMEX:IWM", DIA: "AMEX:DIA",
  TQQQ: "NASDAQ:TQQQ", SQQQ: "NASDAQ:SQQQ",
};

function normalizeSymbol(raw) {
  const s = (raw || "").trim().toUpperCase().replace(/\s+/g, "");
  if (!s) return "TSX:FTS";
  if (s.includes(":")) return s;
  return KNOWN[s] || "TSX:" + s;
}

// ── Chart loader ──
function loadChart(symbolRaw) {
  const input = document.getElementById("symbolInput");
  const container = document.getElementById("tv_chart");
  const symbol = normalizeSymbol(symbolRaw || input.value);

  input.value = symbol;

  // Update active chip
  document.querySelectorAll(".chip").forEach(c => {
    c.classList.toggle("active", c.dataset.symbol === symbol);
  });

  container.innerHTML = "";
  const iframe = document.createElement("iframe");
  iframe.src =
    "https://s.tradingview.com/widgetembed/?" +
    "symbol=" + encodeURIComponent(symbol) +
    "&interval=5&theme=dark&style=1&timezone=America%2FNew_York" +
    "&symboledit=1&saveimage=0&hidesidetoolbar=0&withdateranges=1";
  iframe.style.cssText = "width:100%;height:100%;border:none;display:block;";
  iframe.setAttribute("scrolling", "no");
  container.appendChild(iframe);
}

document.addEventListener("DOMContentLoaded", () => {
  const input = document.getElementById("symbolInput");
  const loadBtn = document.getElementById("loadBtn");

  loadBtn.addEventListener("click", () => loadChart());
  input.addEventListener("keydown", e => { if (e.key === "Enter") loadChart(); });

  document.querySelectorAll(".chip").forEach(btn => {
    btn.addEventListener("click", () => loadChart(btn.dataset.symbol));
  });

  loadChart("TSX:FTS");
  fetchBotStatus();
  setInterval(fetchBotStatus, 30000);
});

// ── Bot status ──
const BOT_URL = "https://bot.trendtrooper.com/status";

function timeAgo(iso) {
  const diff = Math.floor((Date.now() - new Date(iso)) / 1000);
  if (diff < 60) return diff + "s ago";
  if (diff < 3600) return Math.floor(diff / 60) + "m ago";
  return Math.floor(diff / 3600) + "h ago";
}

function fetchBotStatus() {
  fetch(BOT_URL, { cache: "no-store" })
    .then(r => r.json())
    .then(d => updateBotUI(d))
    .catch(() => updateBotUI(null));
}

function fmtPnl(val) {
  if (val === null || val === undefined) return "—";
  const sign = val >= 0 ? "+" : "";
  return sign + "$" + val.toFixed(2);
}

function updateBotUI(d) {
  const botStatus    = document.getElementById("botStatus");
  const ibkrStatus   = document.getElementById("ibkrStatus");
  const botMode      = document.getElementById("botMode");
  const posCount     = document.getElementById("posCount");
  const todayTrades  = document.getElementById("todayTrades");
  const dailyPnl     = document.getElementById("dailyPnl");
  const positionBoard = document.getElementById("positionBoard");
  const signalBoard  = document.getElementById("signalBoard");
  const botFooter    = document.getElementById("botFooter");
  const lastUpdated  = document.getElementById("lastUpdated");
  const botDot       = document.getElementById("botDot");

  if (!d) {
    if (botStatus)  { botStatus.textContent = "Offline"; botStatus.style.color = "var(--red)"; }
    if (ibkrStatus) { ibkrStatus.textContent = "—"; ibkrStatus.style.color = "var(--muted)"; }
    if (botMode)    { botMode.textContent = "—"; }
    if (posCount)   { posCount.textContent = "—"; }
    if (todayTrades){ todayTrades.textContent = "—"; }
    if (dailyPnl)   { dailyPnl.textContent = "—"; dailyPnl.style.color = "var(--muted2)"; }
    if (botFooter)  { botFooter.textContent = "Bot offline"; }
    if (botDot)     { botDot.style.background = "var(--red)"; }
    if (positionBoard) { positionBoard.innerHTML = ""; }
    if (signalBoard) { signalBoard.innerHTML = '<div class="signal-row" style="color:var(--muted);font-size:13px;padding:16px 0;">Bot is offline</div>'; }
    return;
  }

  if (botStatus)  { botStatus.textContent = "Online"; botStatus.style.color = "var(--green)"; }
  if (botDot)     { botDot.style.background = "var(--green)"; }
  if (ibkrStatus) {
    ibkrStatus.textContent = d.ibkr_connected ? "Connected" : "Disconnected";
    ibkrStatus.style.color = d.ibkr_connected ? "var(--green)" : "var(--yellow)";
  }
  if (botMode)     { botMode.textContent = d.mode || "—"; botMode.style.color = "var(--text)"; }
  if (posCount)    { posCount.textContent = (d.positions || []).length; posCount.style.color = "var(--text)"; }
  if (todayTrades) { todayTrades.textContent = d.today_trades ?? "—"; todayTrades.style.color = "var(--text)"; }
  if (dailyPnl && d.daily_pnl !== undefined) {
    dailyPnl.textContent = fmtPnl(d.daily_pnl);
    dailyPnl.style.color = d.daily_pnl >= 0 ? "var(--green)" : "var(--red)";
  }
  if (botFooter)   { botFooter.textContent = "Bot online · " + (d.mode || ""); }
  if (lastUpdated && d.timestamp) { lastUpdated.textContent = timeAgo(d.timestamp); }

  // Open positions detail
  if (positionBoard) {
    const positions = d.positions || [];
    if (positions.length) {
      positionBoard.innerHTML = positions.map(p => {
        const unreal = p.unrealized_pnl;
        const pnlStr = unreal !== null && unreal !== undefined ? fmtPnl(unreal) : "";
        const pnlColor = unreal >= 0 ? "var(--green)" : "var(--red)";
        const lastStr = p.last ? " · $" + p.last.toFixed(2) : "";
        return `<div class="signal-row" style="font-size:12px;">
          <div>
            <div class="signal-name">${p.symbol} · ${p.qty} shares @ $${p.avg_cost}${lastStr}</div>
          </div>
          ${pnlStr ? `<span style="color:${pnlColor};font-weight:700;font-size:12px;">${pnlStr}</span>` : ""}
        </div>`;
      }).join("");
    } else {
      positionBoard.innerHTML = "";
    }
  }

  if (signalBoard) {
    const sigs = d.last_signals || [];
    if (!sigs.length) {
      signalBoard.innerHTML = '<div class="signal-row" style="color:var(--muted);font-size:13px;padding:16px 0;">No signals yet</div>';
      return;
    }
    signalBoard.innerHTML = [...sigs].reverse().map(s => {
      const ticker  = s.ticker || s.symbol || "—";
      const action  = (s.action || "").toUpperCase();
      const price   = s.price ? " · $" + s.price : "";
      const shares  = s.shares ? ` · ${s.shares} shares` : "";
      const time    = s.time ? new Date(s.time).toLocaleTimeString([], {hour:"2-digit", minute:"2-digit"}) : "";
      const badgeClass = action === "BUY" ? "badge-long" : action === "SELL" ? "badge-short" : "badge-wait";
      const label   = action === "BUY" ? "LONG" : action === "SELL" ? "EXIT" : action;
      return `<div class="signal-row">
        <div>
          <div class="signal-name">${ticker}${price}${shares}</div>
          <div class="signal-ticker">${time}</div>
        </div>
        <span class="badge ${badgeClass}">${label}</span>
      </div>`;
    }).join("");
  }
}
</script>

