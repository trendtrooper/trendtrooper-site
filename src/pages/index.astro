<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TrendTrooper — Algorithmic Trading Signals</title>
<meta name="description" content="Professional algorithmic trading signals for Canadian and US markets. Real-time alerts, live charts, and automated strategy execution.">

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #060a0f;
  --bg2: #0b1118;
  --bg3: #0f1923;
  --border: #1a2535;
  --border2: #223044;
  --green: #00ff88;
  --green-dim: rgba(0,255,136,.12);
  --blue: #38bdf8;
  --blue-dim: rgba(56,189,248,.08);
  --red: #ff4d6d;
  --yellow: #facc15;
  --text: #e5e7eb;
  --muted: #6b7280;
  --muted2: #9ca3af;
}

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
  line-height: 1.6;
}

/* ── HEADER ── */
header {
  height: 72px;
  background: rgba(6,10,15,.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32px;
  position: sticky;
  top: 0;
  z-index: 100;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
  color: var(--text);
}

.logo {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: linear-gradient(135deg, var(--green), var(--blue));
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  font-size: 15px;
  color: #020617;
  flex-shrink: 0;
}

.brand-name {
  font-size: 20px;
  font-weight: 900;
  letter-spacing: -.3px;
}

.brand-tag {
  font-size: 11px;
  color: var(--green);
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  display: block;
  line-height: 1;
}

nav {
  display: flex;
  align-items: center;
  gap: 8px;
}

nav a {
  color: var(--muted2);
  padding: 7px 14px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 600;
  font-size: 14px;
  transition: color .15s, background .15s;
}

nav a:hover { color: var(--text); background: var(--bg3); }

.nav-cta {
  background: linear-gradient(135deg, var(--green), var(--blue)) !important;
  color: #020617 !important;
  font-weight: 800 !important;
  padding: 8px 18px !important;
  border-radius: 10px;
}

.nav-cta:hover { opacity: .9; background: linear-gradient(135deg, var(--green), var(--blue)) !important; }

/* ── HERO ── */
.hero {
  padding: 90px 32px 70px;
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 60px;
  align-items: center;
}

.hero-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--green-dim);
  border: 1px solid rgba(0,255,136,.25);
  color: var(--green);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: 100px;
  margin-bottom: 24px;
}

.pulse {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--green);
  animation: pulse 1.8s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(0,255,136,.5); }
  50% { opacity: .7; box-shadow: 0 0 0 6px rgba(0,255,136,0); }
}

h1 {
  font-size: 58px;
  font-weight: 900;
  line-height: 1.08;
  letter-spacing: -1.5px;
  margin-bottom: 22px;
}

h1 .accent {
  background: linear-gradient(135deg, var(--green), var(--blue));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-sub {
  font-size: 18px;
  color: var(--muted2);
  max-width: 520px;
  margin-bottom: 36px;
  line-height: 1.7;
}

.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 48px;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 13px 24px;
  border-radius: 12px;
  font-weight: 800;
  font-size: 15px;
  text-decoration: none;
  cursor: pointer;
  border: none;
  transition: opacity .15s, transform .1s;
}

.btn:active { transform: scale(.98); }

.btn-primary {
  background: linear-gradient(135deg, var(--green), var(--blue));
  color: #020617;
}

.btn-primary:hover { opacity: .92; }

.btn-secondary {
  background: var(--bg3);
  color: var(--text);
  border: 1px solid var(--border2);
}

.btn-secondary:hover { border-color: var(--green); color: var(--green); }

.hero-stats {
  display: flex;
  gap: 32px;
}

.hero-stat strong {
  display: block;
  font-size: 26px;
  font-weight: 900;
  color: var(--text);
}

.hero-stat span {
  font-size: 12px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 700;
}

/* hero right panel */
.hero-panel {
  background: var(--bg2);
  border: 1px solid var(--border2);
  border-radius: 24px;
  padding: 24px;
  position: relative;
  overflow: hidden;
}

.hero-panel::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--green-dim), var(--blue-dim));
  pointer-events: none;
}

.panel-title {
  font-size: 13px;
  font-weight: 800;
  color: var(--muted2);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 16px;
}

.signal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
}

.signal-row:last-child { border-bottom: none; }

.signal-name {
  font-weight: 700;
  font-size: 14px;
}

.signal-ticker {
  font-size: 12px;
  color: var(--muted);
  margin-top: 2px;
}

.badge {
  font-size: 12px;
  font-weight: 800;
  padding: 4px 10px;
  border-radius: 8px;
  letter-spacing: .5px;
}

.badge-long { background: rgba(0,255,136,.15); color: var(--green); }
.badge-wait { background: rgba(250,204,21,.1); color: var(--yellow); }
.badge-short { background: rgba(255,77,109,.12); color: var(--red); }

.panel-footer {
  margin-top: 16px;
  padding-top: 14px;
  border-top: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 12px;
  color: var(--muted);
}

.status-dot {
  width: 6px;
  height: 6px;
  background: var(--green);
  border-radius: 50%;
  display: inline-block;
  margin-right: 6px;
  animation: pulse 1.8s ease-in-out infinite;
}

/* ── SECTIONS ── */
section { padding: 80px 32px; }

.section-inner { max-width: 1200px; margin: 0 auto; }

.section-label {
  color: var(--green);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 12px;
}

h2 {
  font-size: 40px;
  font-weight: 900;
  letter-spacing: -1px;
  margin-bottom: 16px;
}

.section-sub {
  color: var(--muted2);
  font-size: 17px;
  max-width: 560px;
  line-height: 1.7;
  margin-bottom: 56px;
}

/* ── FEATURES ── */
.features-bg { background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.feature-card {
  background: var(--bg);
  border: 1px solid var(--border2);
  border-radius: 20px;
  padding: 28px;
  transition: border-color .2s, transform .2s;
}

.feature-card:hover {
  border-color: var(--green);
  transform: translateY(-3px);
}

.feature-icon {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  background: var(--green-dim);
  border: 1px solid rgba(0,255,136,.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  margin-bottom: 18px;
}

.feature-card h3 {
  font-size: 18px;
  font-weight: 800;
  margin-bottom: 10px;
}

.feature-card p {
  color: var(--muted2);
  font-size: 14px;
  line-height: 1.65;
}

/* ── CHART ── */
.chart-section { background: var(--bg); }

.chart-wrap {
  background: var(--bg2);
  border: 1px solid var(--border2);
  border-radius: 24px;
  overflow: hidden;
}

.chart-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 18px 20px;
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
}

.chart-title { font-weight: 800; font-size: 16px; }

.chart-tools {
  display: flex;
  gap: 8px;
  align-items: center;
  flex: 1;
  flex-wrap: wrap;
}

.symbol-input {
  background: var(--bg);
  border: 1px solid var(--border2);
  color: var(--text);
  padding: 9px 14px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 700;
  width: 200px;
  outline: none;
  transition: border-color .15s;
}

.symbol-input:focus { border-color: var(--green); }

.chip {
  background: var(--bg);
  border: 1px solid var(--border2);
  color: var(--muted2);
  padding: 7px 12px;
  border-radius: 9px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: all .15s;
}

.chip:hover, .chip.active { background: var(--green); color: #020617; border-color: var(--green); }

#tv_chart {
  height: 560px;
  width: 100%;
  background: var(--bg);
}

/* ── HOW IT WORKS ── */
.hiw-bg { background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }

.steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  counter-reset: step;
}

.step {
  position: relative;
  padding: 32px;
  background: var(--bg);
  border: 1px solid var(--border2);
  border-radius: 20px;
}

.step-num {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, var(--green), var(--blue));
  color: #020617;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  font-size: 16px;
  margin-bottom: 18px;
}

.step h3 { font-size: 18px; font-weight: 800; margin-bottom: 10px; }
.step p { color: var(--muted2); font-size: 14px; line-height: 1.65; }

/* ── MARKETS ── */
.markets-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
  margin-bottom: 40px;
}

.market-card {
  background: var(--bg2);
  border: 1px solid var(--border2);
  border-radius: 20px;
  padding: 24px;
}

.market-card h3 { font-size: 16px; font-weight: 800; margin-bottom: 14px; color: var(--green); }

.ticker-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.ticker-tag {
  background: var(--bg);
  border: 1px solid var(--border2);
  color: var(--muted2);
  padding: 5px 12px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
  font-family: monospace;
}

/* ── PRICING ── */
.pricing-bg { background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  max-width: 900px;
  margin: 0 auto;
}

.pricing-card {
  background: var(--bg);
  border: 1px solid var(--border2);
  border-radius: 24px;
  padding: 32px 28px;
  position: relative;
}

.pricing-card.featured {
  border-color: var(--green);
  background: linear-gradient(180deg, rgba(0,255,136,.05) 0%, var(--bg) 100%);
}

.featured-badge {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, var(--green), var(--blue));
  color: #020617;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 4px 14px;
  border-radius: 100px;
  white-space: nowrap;
}

.plan-name { font-size: 14px; font-weight: 800; color: var(--muted2); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px; }

.plan-price {
  font-size: 46px;
  font-weight: 900;
  letter-spacing: -2px;
  margin-bottom: 4px;
}

.plan-price sup { font-size: 22px; vertical-align: top; margin-top: 10px; display: inline-block; }
.plan-price .per { font-size: 16px; font-weight: 600; color: var(--muted); letter-spacing: 0; }

.plan-desc { color: var(--muted2); font-size: 14px; margin-bottom: 24px; }

.plan-features { list-style: none; margin-bottom: 28px; }
.plan-features li {
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
  font-size: 14px;
  color: var(--muted2);
  display: flex;
  align-items: center;
  gap: 8px;
}
.plan-features li:last-child { border-bottom: none; }
.plan-features li::before { content: '✓'; color: var(--green); font-weight: 900; }

.plan-btn {
  width: 100%;
  padding: 13px;
  border-radius: 12px;
  font-weight: 800;
  font-size: 15px;
  cursor: pointer;
  border: 1px solid var(--border2);
  background: var(--bg2);
  color: var(--text);
  text-align: center;
  transition: all .15s;
  text-decoration: none;
  display: block;
}

.plan-btn:hover { border-color: var(--green); color: var(--green); }
.plan-btn.primary-btn {
  background: linear-gradient(135deg, var(--green), var(--blue));
  color: #020617;
  border: none;
}
.plan-btn.primary-btn:hover { opacity: .92; color: #020617; }

/* ── CTA BANNER ── */
.cta-section { background: var(--bg); }

.cta-banner {
  background: linear-gradient(135deg, rgba(0,255,136,.1), rgba(56,189,248,.06));
  border: 1px solid rgba(0,255,136,.2);
  border-radius: 28px;
  padding: 64px 48px;
  text-align: center;
}

.cta-banner h2 { font-size: 44px; margin-bottom: 16px; }
.cta-banner p { color: var(--muted2); font-size: 17px; max-width: 500px; margin: 0 auto 36px; }

/* ── FOOTER ── */
footer {
  background: var(--bg2);
  border-top: 1px solid var(--border);
  padding: 48px 32px 32px;
}

.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 48px;
  margin-bottom: 40px;
}

.footer-brand .brand-name { font-size: 18px; font-weight: 900; margin-bottom: 10px; }
.footer-brand p { color: var(--muted); font-size: 14px; max-width: 280px; line-height: 1.6; }

.footer-col h4 { font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted2); margin-bottom: 16px; }
.footer-col a { display: block; color: var(--muted); font-size: 14px; text-decoration: none; margin-bottom: 10px; transition: color .15s; }
.footer-col a:hover { color: var(--green); }

.footer-bottom {
  max-width: 1200px;
  margin: 0 auto;
  padding-top: 24px;
  border-top: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--muted);
  font-size: 13px;
}

.footer-bottom a { color: var(--muted); text-decoration: none; }
.footer-bottom a:hover { color: var(--green); }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .features-grid, .steps, .pricing-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 768px) {
  .hero { grid-template-columns: 1fr; padding: 60px 20px 40px; }
  .hero-panel { display: none; }
  h1 { font-size: 40px; }
  h2 { font-size: 30px; }
  .features-grid, .steps, .markets-grid, .pricing-grid { grid-template-columns: 1fr; }
  section { padding: 60px 20px; }
  header { padding: 0 20px; }
  .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  nav a:not(.nav-cta) { display: none; }
}
</style>
</head>

<body>

<!-- HEADER -->
<header>
  <a class="brand" href="/">
    <div class="logo">TT</div>
    <div>
      <div class="brand-name">TrendTrooper</div>
