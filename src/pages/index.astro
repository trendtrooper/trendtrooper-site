---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>TrendTrooper</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <nav>
        <div class="brand"><span>TT</span> TrendTrooper</div>
        <div class="links">
          <a href="/">Home</a>
          <a href="/chart">Full Chart</a>
          <a href="https://bot.trendtrooper.com">Bot Status</a>
        </div>
      </nav>

      <section class="dashboard">
        <div class="left">
          <p class="tag">LIVE TRADING DASHBOARD</p>
          <h1>TrendTrooper Command Center</h1>
          <p class="sub">
            Live FTS chart, TradingView alerts, webhook bot status, and trading tools in one clean dashboard.
          </p>

          <div class="actions">
            <a class="primary" href="/chart">Open Full Chart</a>
            <a class="secondary" href="https://bot.trendtrooper.com">Check Bot</a>
          </div>

          <div class="cards">
            <div><small>Symbol</small><b>FTS / NYSE</b></div>
            <div><small>Timeframe</small><b>5 min</b></div>
            <div><small>Mode</small><b>Paper</b></div>
            <div><small>Status</small><b class="green">Online</b></div>
          </div>
        </div>

        <div class="right">
          <div class="panel price-panel">
            <div class="panel-title">Live FTS Price</div>
            <iframe
              src="https://s.tradingview.com/embed-widget/symbol-info/?locale=en#%7B%22symbol%22%3A%22NYSE%3AFTS%22%2C%22width%22%3A%22100%25%22%2C%22height%22%3A%22180%22%2C%22colorTheme%22%3A%22dark%22%2C%22isTransparent%22%3Atrue%7D"
              width="100%"
              height="180"
              frameborder="0"
              scrolling="no">
            </iframe>
          </div>

          <div class="panel log-panel">
            <div class="panel-title">Bot Feed</div>
            <p>&gt; webhook armed</p>
            <p>&gt; bot.trendtrooper.com online</p>
            <p>&gt; waiting for TradingView alert...</p>
          </div>
        </div>
      </section>

      <section class="chart-panel">
        <div class="panel-title">Live TradingView Chart</div>

        <iframe
          src="https://www.tradingview.com/widgetembed/?symbol=NYSE%3AFTS&interval=5&theme=dark&style=1&timezone=America%2FSt_Johns&hide_top_toolbar=false&hide_side_toolbar=false&withdateranges=true&studies=%5B%5D"
          width="100%"
          height="620"
          frameborder="0"
          allowtransparency="true"
          scrolling="no">
        </iframe>
      </section>
    </main>
  </body>
</html>

<style>
* { box-sizing: border-box; }

body {
  margin: 0;
  font-family: Inter, Arial, sans-serif;
  background: #030712;
  color: #d6e1ff;
  font-size: 14px;
}

main {
  min-height: 100vh;
  padding: 14px;
  background:
    radial-gradient(circle at 10% 10%, rgba(47,124,255,.15), transparent 30%),
    radial-gradient(circle at 90% 20%, rgba(57,217,138,.1), transparent 30%),
    #030712;
}

/* NAV */
nav {
  max-width: 1400px;
  margin: 0 auto 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.brand {
  font-size: 16px;
  font-weight: 800;
}

.links {
  display: flex;
  gap: 8px;
}

.links a {
  padding: 8px 12px;
  border-radius: 8px;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.1);
}

/* GRID */
.dashboard {
  max-width: 1400px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 260px 1fr 300px;
  gap: 12px;
}

/* LEFT PANEL */
.left {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 12px;
  padding: 14px;
}

.left h1 {
  font-size: 16px;
  margin: 0 0 10px;
}

.left p {
  font-size: 12px;
  color: #8fa3c8;
}

/* STATUS CARDS */
.cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
  margin-top: 10px;
}

.cards div {
  padding: 10px;
  border-radius: 8px;
  background: rgba(0,0,0,.3);
}

.cards small {
  font-size: 10px;
  color: #6f7c99;
}

.cards b {
  font-size: 13px;
}

/* CENTER CHART */
.chart-panel {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 12px;
  padding: 10px;
}

.chart-panel iframe {
  width: 100%;
  height: 520px;
  border-radius: 10px;
}

/* RIGHT PANEL */
.right {
  display: grid;
  gap: 10px;
}

.panel {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 12px;
  padding: 10px;
}

.panel-title {
  font-size: 11px;
  color: #7f8fb3;
  margin-bottom: 6px;
}

/* BOT LOG */
.log-panel {
  font-family: monospace;
  font-size: 11px;
  color: #9fe7bd;
}

/* PRICE PANEL */
.price-panel iframe {
  height: 120px;
}

/* EXTRA PANELS */
.watchlist, .signals {
  font-size: 12px;
}

.watchlist div,
.signals div {
  padding: 6px 0;
  border-bottom: 1px solid rgba(255,255,255,.05);
}

/* MOBILE */
@media (max-width: 900px) {
  .dashboard {
    grid-template-columns: 1fr;
  }

  .chart-panel iframe {
    height: 420px;
  }
}
</style></style>
