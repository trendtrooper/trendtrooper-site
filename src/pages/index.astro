<!-- ===== LIVE TRADINGVIEW CHART ===== -->

<section style="margin-top:20px;">
  <h2>Live TradingView Chart</h2>

  <!-- INPUT -->
  <div style="margin-bottom:10px;">
    <input id="symbolInput" type="text" value="NYSE:FTS"
      style="padding:8px;width:220px;border-radius:4px;border:1px solid #333;background:#111;color:#fff;">
    <button onclick="loadChart()"
      style="padding:8px 14px;background:#00c853;border:none;color:#000;font-weight:600;border-radius:4px;cursor:pointer;">
      Load
    </button>
  </div>

  <!-- QUICK BUTTONS -->
  <div style="margin-bottom:10px;">
    <button onclick="setSymbol('NYSE:FTS')">FTS</button>
    <button onclick="setSymbol('AMEX:SPY')">SPY</button>
    <button onclick="setSymbol('NASDAQ:QQQ')">QQQ</button>
    <button onclick="setSymbol('NASDAQ:AAPL')">AAPL</button>
    <button onclick="setSymbol('NASDAQ:TSLA')">TSLA</button>
  </div>

  <!-- CHART -->
  <div id="tv_chart" style="width:100%;height:500px;"></div>
</section>

<!-- ===== TRADINGVIEW SCRIPT ===== -->
<script src="https://s3.tradingview.com/tv.js"></script>

<script>
let tvWidget = null;

// CREATE / RELOAD CHART
function loadChart() {
  const input = document.getElementById("symbolInput").value.trim();
  const symbol = input !== "" ? input : "NYSE:FTS";

  // wipe old chart
  document.getElementById("tv_chart").innerHTML = "";

  // build new chart
  tvWidget = new TradingView.widget({
    autosize: true,
    symbol: symbol,
    interval: "5",
    timezone: "America/New_York",
    theme: "dark",
    style: "1",
    locale: "en",
    toolbar_bg: "#111",
    enable_publishing: false,
    hide_top_toolbar: false,
    hide_legend: false,
    save_image: false,
    container_id: "tv_chart"
  });
}

// BUTTON HANDLER
function setSymbol(sym) {
  document.getElementById("symbolInput").value = sym;
  loadChart();
}

// LOAD DEFAULT ON PAGE OPEN
window.addEventListener("DOMContentLoaded", function() {
  loadChart();
});
</script>

<style>
/* button styling */
button {
  padding:6px 12px;
  margin-right:6px;
  border:none;
  background:#111;
  color:#fff;
  border-radius:4px;
  cursor:pointer;
  font-weight:600;
}
button:hover {
  background:#00c853;
  color:#000;
}
</style>
