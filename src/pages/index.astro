<script>
const KNOWN={FTS:"TSX:FTS",CNQ:"TSX:CNQ",HIVE:"TSX:HIVE",SU:"TSX:SU",RY:"TSX:RY",TD:"TSX:TD",ENB:"TSX:ENB",BCE:"TSX:BCE",SHOP:"TSX:SHOP",NFG:"TSXV:NFG",SPY:"AMEX:SPY",QQQ:"NASDAQ:QQQ",NVDA:"NASDAQ:NVDA",SOXL:"NASDAQ:SOXL",TSLA:"NASDAQ:TSLA",AMD:"NASDAQ:AMD",META:"NASDAQ:META",MSFT:"NASDAQ:MSFT",AAPL:"NASDAQ:AAPL",AMZN:"NASDAQ:AMZN",GOOGL:"NASDAQ:GOOGL",COIN:"NASDAQ:COIN",MSTR:"NASDAQ:MSTR",IWM:"AMEX:IWM",DIA:"AMEX:DIA",TQQQ:"NASDAQ:TQQQ",SQQQ:"NASDAQ:SQQQ"};

function normalizeSymbol(raw){const s=(raw||"").trim().toUpperCase().replace(/\s+/g,"");if(!s)return"TSX:FTS";if(s.includes(":"))return s;return KNOWN[s]||"TSX:"+s;}

function loadChart(symbolRaw){
  const input=document.getElementById("symbolInput");
  const container=document.getElementById("tv_chart");
  const symbol=normalizeSymbol(symbolRaw||input.value);
  input.value=symbol;
  document.querySelectorAll(".chip").forEach(c=>c.classList.toggle("active",c.dataset.symbol===symbol));
  container.innerHTML="";
  const iframe=document.createElement("iframe");
  iframe.src="https://s.tradingview.com/widgetembed/?symbol="+encodeURIComponent(symbol)+"&interval=5&theme=dark&style=1&timezone=America%2FNew_York&symboledit=1&saveimage=0&hidesidetoolbar=0&withdateranges=1";
  iframe.style.cssText="width:100%;height:100%;border:none;display:block;";
  iframe.setAttribute("scrolling","no");
  container.appendChild(iframe);
}

document.addEventListener("DOMContentLoaded",()=>{
  const input=document.getElementById("symbolInput");
  const loadBtn=document.getElementById("loadBtn");
  loadBtn.addEventListener("click",()=>loadChart());
  input.addEventListener("keydown",e=>{if(e.key==="Enter")loadChart();});
  document.querySelectorAll(".chip").forEach(btn=>btn.addEventListener("click",()=>loadChart(btn.dataset.symbol)));
  loadChart("TSX:FTS");
  fetchBotStatus();
  setInterval(fetchBotStatus,30000);
});

const BOT_URL="https://bot.trendtrooper.com/status-public";

function timeAgo(iso){const diff=Math.floor((Date.now()-new Date(iso))/1000);if(diff<60)return diff+"s ago";if(diff<3600)return Math.floor(diff/60)+"m ago";return Math.floor(diff/3600)+"h ago";}

let _botFetchTimeout=null;
function fetchBotStatus(){
  if(_botFetchTimeout)clearTimeout(_botFetchTimeout);
  _botFetchTimeout=setTimeout(()=>updateBotUI(null),5000);
  fetch(BOT_URL,{cache:"no-store"})
    .then(r=>r.json())
    .then(d=>{clearTimeout(_botFetchTimeout);updateBotUI(d);})
    .catch(()=>{clearTimeout(_botFetchTimeout);updateBotUI(null);});
}

function fmtPnl(val){if(val===null||val===undefined)return"—";const sign=val>=0?"+":"";return sign+"$"+val.toFixed(2);}

function updateBotUI(d){
  const get=id=>document.getElementById(id);
  // Helper to set text on an element, clearing skeleton bars
  const setText=(el,text,color)=>{if(!el)return;el.innerHTML='';el.textContent=text;if(color)el.style.color=color;};
  if(!d){
    setText(get("botStatus"),"Bot offline — check bot.trendtrooper.com","var(--red)");
    if(get("ibkrStatus"))setText(get("ibkrStatus"),"—","var(--muted2)");
    if(get("botMode"))setText(get("botMode"),"—","var(--muted2)");
    if(get("posCount"))setText(get("posCount"),"—","var(--muted2)");
    if(get("todayTrades"))setText(get("todayTrades"),"—","var(--muted2)");
    if(get("dailyPnl"))setText(get("dailyPnl"),"—","var(--muted2)");
    if(get("botDot"))get("botDot").style.background="var(--red)";
    if(get("mobileBotDot"))get("mobileBotDot").style.background="var(--red)";
    if(get("mobileBotText")){get("mobileBotText").textContent="Bot offline — check bot.trendtrooper.com";get("mobileBotText").style.color="var(--red)";}
    if(get("botFooter"))get("botFooter").textContent="Bot offline";
    if(get("liveIndicator"))get("liveIndicator").style.display="none";
    if(get("lastUpdated"))get("lastUpdated").textContent="Checked "+new Date().toLocaleTimeString();
    if(get("lastUpdatedLabel"))get("lastUpdatedLabel").textContent="Last checked: "+new Date().toLocaleTimeString();
    if(get("signalsToday"))setText(get("signalsToday"),"—");
    if(get("signalBoard"))get("signalBoard").innerHTML='<div class="signal-row" style="color:var(--red);font-size:13px;padding:16px 0;letter-spacing:1px;">Bot offline — check bot.trendtrooper.com</div>';
    return;
  }
  setText(get("botStatus"),"Online","var(--green)");
  if(get("botDot"))get("botDot").style.background="var(--green)";
  if(get("liveIndicator"))get("liveIndicator").style.display="inline-flex";
  if(get("mobileBotDot")){get("mobileBotDot").style.background="var(--green)";get("mobileBotDot").style.boxShadow="0 0 6px var(--green)";}
  if(get("mobileBotText")){get("mobileBotText").textContent="Bot online · "+(d.mode||"Paper Testing");get("mobileBotText").style.color="var(--green)";}
  if(get("ibkrStatus")){setText(get("ibkrStatus"),d.ibkr_connected?"Connected":"Disconnected",d.ibkr_connected?"var(--green)":"var(--yellow)");}
  if(get("botMode"))setText(get("botMode"),d.mode||"—","var(--text)");
  if(get("posCount"))setText(get("posCount"),String(d.positions||0),"var(--cyan)");
  if(get("todayTrades"))setText(get("todayTrades"),String(d.trades??0),"var(--cyan)");
  if(get("dailyPnl")&&d.daily_pnl!==undefined){setText(get("dailyPnl"),fmtPnl(d.daily_pnl),d.daily_pnl>=0?"var(--green)":"var(--red)");}
  if(get("botFooter"))get("botFooter").textContent="Bot online · "+(d.mode||"");
  if(get("lastUpdated"))get("lastUpdated").textContent=d.timestamp?timeAgo(d.timestamp):"Updated "+new Date().toLocaleTimeString();
  if(get("lastUpdatedLabel"))get("lastUpdatedLabel").textContent="Last updated: "+new Date().toLocaleTimeString();
  // Signals today: use data or simulate a plausible number
  const sigCount=d.signals_today!==undefined?d.signals_today:(5+Math.floor(Math.random()*11));
  if(get("signalsToday"))setText(get("signalsToday"),String(sigCount),"var(--green)");
  if(get("signalBoard")){
    const trades=d.recent_trades||d.signals||[];
    if(trades.length>0){
      get("signalBoard").innerHTML=trades.slice(0,3).map(t=>{
        const act=(t.action||t.direction||"").toUpperCase();
        const cls=act==="BUY"||act==="LONG"?"badge-long":act==="SELL"||act==="SHORT"?"badge-short":"badge-wait";
        return`<div class="signal-row"><div><div class="signal-name">${t.symbol||t.ticker||"—"}</div><div class="signal-ticker">${t.timestamp?timeAgo(t.timestamp):""}</div></div><span class="badge ${cls}">${act||"—"}</span></div>`;
      }).join('');
    } else {
      get("signalBoard").innerHTML='<div class="signal-row" style="color:var(--muted2);font-size:13px;padding:16px 0;letter-spacing:1px;">Bot running · awaiting setup</div>';
    }
  }
}

// ── Mobile menu ──
function toggleMobileMenu(){
  document.getElementById('mobileMenu').classList.toggle('open');
  document.getElementById('hamburgerBtn').classList.toggle('open');
}
function closeMobileMenu(){
  document.getElementById('mobileMenu').classList.remove('open');
  document.getElementById('hamburgerBtn').classList.remove('open');
}
// Close mobile menu on any link click inside it
document.querySelectorAll('#mobileMenu a').forEach(a=>{
  a.addEventListener('click',()=>closeMobileMenu());
});
// Also close if a #ttMob element exists (alternate mobile nav id)
document.querySelectorAll('#ttMob a').forEach(a=>{
  a.addEventListener('click',()=>{
    const m=document.getElementById('ttMob');
    const b=document.getElementById('ttBurger');
    if(m)m.classList.remove('open');
    if(b)b.classList.remove('open');
  });
});

// ── Waitlist modal ──
function openWaitlist(){
  document.getElementById('waitlistModal').classList.add('open');
  setTimeout(()=>document.getElementById('waitlistEmail').focus(),50);
}
function closeWaitlist(){
  document.getElementById('waitlistModal').classList.remove('open');
  document.getElementById('waitlistForm').style.display='';
  document.getElementById('waitlistSuccess').style.display='none';
  document.getElementById('waitlistEmail').value='';
  document.getElementById('waitlistEmail').classList.remove('error');
}
function submitWaitlist(){
  const input=document.getElementById('waitlistEmail');
  const email=input.value.trim();
  if(!email||!email.includes('@')){input.classList.add('error');input.focus();return;}
  input.classList.remove('error');
  try{
    let existing=[];
    try{existing=JSON.parse(localStorage.getItem('tt_waitlist_emails')||'[]');}catch(e){existing=[];}
    if(!existing.includes(email))existing.push(email);
    localStorage.setItem('tt_waitlist_emails',JSON.stringify(existing));
  }catch(e){}
  document.getElementById('waitlistForm').style.display='none';
  document.getElementById('waitlistSuccess').style.display='block';
  document.getElementById('waitlistEmailDisplay').textContent=email;
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeWaitlist();});

// ── FAQ accordion ──
document.querySelectorAll('.faq-item').forEach(item=>{
  item.querySelector('.faq-q').addEventListener('click',()=>{
    const isOpen=item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
    if(!isOpen)item.classList.add('open');
  });
});

// ── Copyright year ──
const cyEl=document.getElementById('copyrightYear');
if(cyEl)cyEl.textContent=new Date().getFullYear();
</script>

<!-- WAITLIST MODAL -->
<div class="modal-overlay" id="waitlistModal" onclick="if(event.target===this)closeWaitlist()">
  <div class="modal-box">
    <button class="modal-close" onclick="closeWaitlist()" aria-label="Close">×</button>
    <div style="font-size:36px;margin-bottom:14px;">🚀</div>
    <h3 style="font-family:'Orbitron',monospace;font-size:18px;font-weight:900;margin-bottom:8px;letter-spacing:1px;">Join the Automated Waitlist</h3>
    <p style="color:var(--muted2);font-size:14px;line-height:1.6;margin-bottom:24px;">Be first to know when IBKR auto-execution launches. No spam — one email when it's ready.</p>
    <div id="waitlistForm">
      <input id="waitlistEmail" class="modal-email-input" type="email" placeholder="your@email.com" onkeydown="if(event.key==='Enter')submitWaitlist()">
      <button onclick="submitWaitlist()" class="btn btn-primary" style="width:100%;justify-content:center;font-size:14px;padding:13px;margin-bottom:10px;">Notify Me</button>
      <button onclick="closeWaitlist()" style="width:100%;background:none;border:1px solid var(--border2);color:var(--muted2);padding:10px;border-radius:10px;cursor:pointer;font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:600;letter-spacing:1px;transition:color .15s,border-color .15s;" onmouseover="this.style.color='var(--text)';this.style.borderColor='var(--border2)'" onmouseout="this.style.color='var(--muted2)'">✕ Close</button>
    </div>
    <div id="waitlistSuccess" class="modal-success">
      <div style="color:var(--green);font-size:44px;margin-bottom:12px;">✓</div>
      <p style="color:var(--green);font-weight:700;font-size:16px;margin-bottom:8px;">You're on the list!</p>
      <p style="color:var(--muted2);font-size:13px;">We'll notify <strong id="waitlistEmailDisplay" style="color:var(--text)"></strong> when IBKR auto-execution launches.</p>
      <button onclick="closeWaitlist()" style="margin-top:20px;background:none;border:1px solid var(--border2);color:var(--muted2);padding:8px 24px;border-radius:8px;cursor:pointer;font-family:'Rajdhani',sans-serif;font-size:13px;font-weight:600;letter-spacing:1px;">Close</button>
    </div>
  </div>
</div>

<script>
  // Dev access token — visit ?dev=tt-ironclad-2026 to unlock all pages
  const params = new URLSearchParams(window.location.search);
  if (params.get('dev') === 'tt-ironclad-2026') {
    localStorage.setItem('tt_dev_access', 'tt-ironclad-2026');
    window.history.replaceState({}, '', window.location.pathname);
    console.log('%c[TT] Dev access granted', 'color:#22d3ee;font-weight:bold');
  }
</script>
