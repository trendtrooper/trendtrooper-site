// TrendTrooper — Trading Tools
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Trading Tools — TrendTrooper</title>
<meta name="description" content="Free trading tools: position size calculator, risk/reward calculator, ATR stop calculator, and compound growth planner.">
<meta property="og:title" content="TrendTrooper — Free Trading Calculators">
<meta property="og:description" content="Position size calculator, risk/reward calculator, ATR stop calculator, and compound growth planner. Free.">
<meta property="og:image" content="https://trendtrooper.com/bot-preview.png">
<meta property="og:url" content="https://trendtrooper.com/tools">
<meta property="og:type" content="website">
<link rel="canonical" href="https://trendtrooper.com/tools">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#020510;--cyan:#00cfff;--purple:#7040ff;--green:#00ff88;--red:#ff4060;--yellow:#ffd060;
  --text:#e8eeff;--muted:rgba(220,235,255,0.85);--muted2:rgba(180,210,255,0.55);
  --border:rgba(0,200,255,0.1);--border2:rgba(0,200,255,0.2);
  --card:rgba(4,8,30,0.85);--card2:rgba(6,12,40,0.6);
}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Rajdhani',sans-serif;line-height:1.6;min-height:100vh;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,200,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(0,200,255,0.02) 1px,transparent 1px);background-size:50px 50px;z-index:0;pointer-events:none;}
body::after{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 20% 0%,rgba(112,64,255,0.06) 0%,transparent 50%),radial-gradient(ellipse at 80% 100%,rgba(0,200,255,0.04) 0%,transparent 50%);z-index:0;pointer-events:none;}

/* HEADER */
header{position:sticky;top:0;z-index:100;height:70px;background:rgba(2,5,20,.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);display:flex;align-items:center;justify-content:space-between;padding:0 32px;}
.tt-brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:#e8eeff;}
.tt-logo{flex-shrink:0;}
.tt-name{font-family:'Orbitron',monospace;font-size:16px;font-weight:900;letter-spacing:2px;background:linear-gradient(90deg,#fff,#00cfff,#7040ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.tt-tag{font-size:9px;color:#00cfff;font-weight:600;letter-spacing:3px;text-transform:uppercase;display:block;opacity:.8;}
.tt-nav{display:flex;align-items:center;gap:1px;white-space:nowrap;}
.tt-nav a{color:#c8d8f0;padding:6px 9px;border-radius:8px;text-decoration:none;font-weight:800;font-size:11.5px;letter-spacing:.8px;text-transform:uppercase;transition:color .15s,background .15s;}
.tt-nav a:hover{color:#e8eeff;background:rgba(0,200,255,.06);}
.tt-nav a.cur{color:#00cfff;}
.tt-cta{background:linear-gradient(135deg,#00cfff,#7040ff)!important;color:#fff!important;font-weight:800!important;padding:8px 14px!important;border-radius:8px!important;box-shadow:0 0 20px rgba(0,200,255,.2)!important;}
.tt-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
.tt-burger span{width:22px;height:2px;background:#e8eeff;border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
.tt-burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.tt-burger.open span:nth-child(2){opacity:0;}
.tt-burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.tt-mob{display:none;flex-direction:column;position:sticky;top:70px;z-index:99;background:rgba(2,5,20,.97);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);padding:8px 24px 16px;}
.tt-mob.open{display:flex;}
.tt-mob a{color:#c8d8f0;padding:10px 0;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:1px;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.04);}
.tt-mob a:hover{color:#e8eeff;}
@media(max-width:900px){.tt-nav{display:none;}.tt-burger{display:flex;}}

/* CONTENT */
.page{position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:40px 24px 80px;}
.page-hero{text-align:center;margin-bottom:48px;}
.page-label{font-family:'Orbitron',monospace;font-size:10px;letter-spacing:4px;color:var(--cyan);text-transform:uppercase;margin-bottom:12px;}
.page-hero h1{font-family:'Orbitron',monospace;font-size:clamp(28px,4vw,42px);font-weight:900;margin-bottom:12px;background:linear-gradient(135deg,#fff,var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.page-hero p{color:var(--muted2);font-size:15px;max-width:560px;margin:0 auto;}

.tools-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(480px,1fr));gap:24px;}
@media(max-width:600px){.tools-grid{grid-template-columns:1fr;}}

/* TOOL CARD */
.tool-card{background:var(--card);border:1px solid var(--border2);border-radius:16px;padding:28px;position:relative;overflow:hidden;}
.tool-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--cyan),var(--purple));}
.tool-title{font-family:'Orbitron',monospace;font-size:13px;font-weight:900;letter-spacing:2px;color:var(--cyan);text-transform:uppercase;margin-bottom:6px;display:flex;align-items:center;gap:8px;}
.tool-desc{color:var(--muted2);font-size:13px;margin-bottom:20px;line-height:1.5;}

/* FORM */
.field{margin-bottom:14px;}
.field label{display:block;font-size:12px;font-weight:700;color:var(--muted2);letter-spacing:1px;text-transform:uppercase;margin-bottom:5px;}
.field input,.field select{width:100%;padding:10px 14px;border-radius:10px;border:1px solid var(--border2);background:rgba(255,255,255,.04);color:var(--text);font-size:14px;font-family:'JetBrains Mono',monospace;outline:none;transition:.15s;}
.field input:focus,.field select:focus{border-color:rgba(0,200,255,.4);background:rgba(0,200,255,.04);}
.field input::placeholder{color:var(--muted2);}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

.calc-btn{width:100%;padding:12px;border-radius:10px;border:none;background:linear-gradient(135deg,var(--cyan),var(--purple));color:#fff;font-family:'Orbitron',monospace;font-size:12px;font-weight:900;letter-spacing:2px;cursor:pointer;margin-top:4px;transition:opacity .15s;}
.calc-btn:hover{opacity:.85;}

/* RESULTS */
.result-box{margin-top:16px;padding:16px;border-radius:10px;background:rgba(0,200,255,.04);border:1px solid rgba(0,200,255,.12);display:none;}
.result-box.show{display:block;}
.result-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.05);}
.result-row:last-child{border-bottom:none;margin-top:4px;padding-top:10px;}
.result-label{font-size:12px;color:var(--muted2);font-weight:600;letter-spacing:.5px;}
.result-value{font-family:'JetBrains Mono',monospace;font-size:15px;font-weight:700;color:var(--text);}
.result-value.green{color:var(--green);}
.result-value.red{color:var(--red);}
.result-value.cyan{color:var(--cyan);}
.result-value.yellow{color:var(--yellow);}

/* DIVIDER */
.divider{height:1px;background:linear-gradient(90deg,transparent,var(--border2),transparent);margin:6px 0 14px;}

/* COMPOUND TABLE */
.compound-table{width:100%;border-collapse:collapse;margin-top:12px;font-size:13px;}
.compound-table th{font-family:'Orbitron',monospace;font-size:10px;letter-spacing:1px;color:var(--cyan);text-transform:uppercase;padding:8px 10px;border-bottom:1px solid var(--border2);text-align:left;}
.compound-table td{padding:7px 10px;border-bottom:1px solid rgba(255,255,255,.03);font-family:'JetBrains Mono',monospace;color:var(--muted);}
.compound-table tr:hover td{background:rgba(0,200,255,.03);color:var(--text);}
.compound-table .profit{color:var(--green);}

/* TIPS */
.tip-box{margin-top:20px;padding:14px;border-radius:10px;background:rgba(167,139,250,.05);border:1px solid rgba(167,139,250,.15);}
.tip-box p{font-size:12px;color:var(--muted2);line-height:1.6;}
.tip-box strong{color:#a78bfa;}
</style>
</head>
<body>

<header>
  <a class="tt-brand" href="/">
    <svg class="tt-logo" width="44" height="50" viewBox="0 0 52 58"><defs><linearGradient id="shG" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#6644ff"/><stop offset="100%" stop-color="#00aaff"/></linearGradient></defs><path d="M26 2 L50 12 L50 32 Q50 48 26 56 Q2 48 2 32 L2 12 Z" fill="url(#shG)" stroke="rgba(100,160,255,0.6)" stroke-width="1.5"/><text x="26" y="36" text-anchor="middle" font-family="Orbitron,monospace" font-weight="900" font-size="16" fill="#ffffff" letter-spacing="1">TT</text><text x="26" y="17" text-anchor="middle" font-size="10" fill="rgba(255,220,100,0.9)">*</text></svg>
    <div><div class="tt-name">TRENDTROOPER</div><span class="tt-tag">Signal Service</span></div>
  </a>
  <nav class="tt-nav">
    <a href="/#features">Features</a>
    <a href="/chart">Live Chart</a>
    <a href="/#markets">Markets</a>
    <a href="/#pricing">Pricing</a>
    <a href="/chart">Full Chart</a>
    <a href="/analysis">Analysis</a>
    <a href="/screener">Screener</a>
    <a href="/academy">Academy</a>
    <a href="/tools" class="cur">Tools</a>
    <a href="https://bot.trendtrooper.com/" target="_blank">Live Bot Trading</a>
    <a href="/#pricing" class="tt-cta">Get Started</a>
  </nav>
  <button class="tt-burger" id="ttBurger" onclick="this.classList.toggle('open');document.getElementById('ttMob').classList.toggle('open')" aria-label="Menu"><span></span><span></span><span></span></button>
</header>
<div class="tt-mob" id="ttMob">
  <a href="/#features">Features</a>
  <a href="/chart">Live Chart</a>
  <a href="/#markets">Markets</a>
  <a href="/#pricing">Pricing</a>
  <a href="/chart">Full Chart</a>
  <a href="/analysis">Analysis</a>
  <a href="/screener">Screener</a>
  <a href="/academy">Academy</a>
  <a href="/tools">Tools</a>
  <a href="https://bot.trendtrooper.com/" target="_blank">Live Bot Trading</a>
  <a href="/#pricing">Get Started</a>
</div>

<div class="page">
  <div class="page-hero">
    <div class="page-label">Free Tools</div>
    <h1>Trading Calculators</h1>
    <p>Professional-grade tools to size positions correctly, manage risk, and plan your trades before you enter them.</p>
  </div>

  <div class="tools-grid">

    <!-- POSITION SIZE CALCULATOR -->
    <div class="tool-card">
      <div class="tool-title">⚡ Position Size Calculator</div>
      <p class="tool-desc">Calculate the exact number of shares to buy based on your account size and risk tolerance.</p>
      <div class="field-row">
        <div class="field">
          <label>Account Size ($)</label>
          <input type="number" id="ps-account" placeholder="10000" value="10000" min="100">
        </div>
        <div class="field">
          <label>Risk Per Trade (%)</label>
          <input type="number" id="ps-risk" placeholder="2" value="2" min="0.1" max="10" step="0.1">
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Entry Price ($)</label>
          <input type="number" id="ps-entry" placeholder="50.00" step="0.01">
        </div>
        <div class="field">
          <label>Stop Loss ($)</label>
          <input type="number" id="ps-stop" placeholder="48.00" step="0.01">
        </div>
      </div>
      <button class="calc-btn" onclick="calcPositionSize()">CALCULATE POSITION SIZE</button>
      <div class="result-box" id="ps-result">
        <div class="result-row"><span class="result-label">Max Risk Dollar Amount</span><span class="result-value red" id="ps-maxrisk">—</span></div>
        <div class="result-row"><span class="result-label">Risk Per Share</span><span class="result-value" id="ps-riskpershare">—</span></div>
        <div class="result-row"><span class="result-label">Position Size (Shares)</span><span class="result-value cyan" id="ps-shares">—</span></div>
        <div class="result-row"><span class="result-label">Total Position Value</span><span class="result-value" id="ps-value">—</span></div>
        <div class="result-row"><span class="result-label">% of Account Deployed</span><span class="result-value yellow" id="ps-pct">—</span></div>
      </div>
      <div class="tip-box">
        <p><strong>Rule of thumb:</strong> Risk no more than 1–2% of your account on a single trade. This means you can absorb 50+ consecutive losses before blowing up — nearly impossible if your strategy has positive expectancy.</p>
      </div>
    </div>

    <!-- RISK / REWARD CALCULATOR -->
    <div class="tool-card">
      <div class="tool-title">📊 Risk / Reward Calculator</div>
      <p class="tool-desc">Evaluate whether a trade setup is worth taking based on your entry, stop, and target.</p>
      <div class="field-row">
        <div class="field">
          <label>Entry Price ($)</label>
          <input type="number" id="rr-entry" placeholder="50.00" step="0.01">
        </div>
        <div class="field">
          <label>Stop Loss ($)</label>
          <input type="number" id="rr-stop" placeholder="48.00" step="0.01">
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Take Profit ($)</label>
          <input type="number" id="rr-target" placeholder="55.00" step="0.01">
        </div>
        <div class="field">
          <label>Shares</label>
          <input type="number" id="rr-shares" placeholder="100">
        </div>
      </div>
      <button class="calc-btn" onclick="calcRiskReward()">CALCULATE R:R</button>
      <div class="result-box" id="rr-result">
        <div class="result-row"><span class="result-label">Risk (Loss if stopped)</span><span class="result-value red" id="rr-risk">—</span></div>
        <div class="result-row"><span class="result-label">Reward (Profit at target)</span><span class="result-value green" id="rr-reward">—</span></div>
        <div class="result-row"><span class="result-label">Risk:Reward Ratio</span><span class="result-value cyan" id="rr-ratio">—</span></div>
        <div class="result-row"><span class="result-label">Min Win Rate Needed</span><span class="result-value yellow" id="rr-winrate">—</span></div>
        <div class="result-row"><span class="result-label">Trade Quality</span><span class="result-value" id="rr-quality">—</span></div>
      </div>
      <div class="tip-box">
        <p><strong>Minimum standard:</strong> TrendTrooper targets a minimum <strong>1:2 R:R ratio</strong>. This means you only need to be right 34% of the time to break even — your winners carry the strategy.</p>
      </div>
    </div>

    <!-- ATR STOP CALCULATOR -->
    <div class="tool-card">
      <div class="tool-title">🎯 ATR Stop Loss Calculator</div>
      <p class="tool-desc">Set volatility-adjusted stops using Average True Range so you aren't stopped out by normal price noise.</p>
      <div class="field-row">
        <div class="field">
          <label>Entry Price ($)</label>
          <input type="number" id="atr-entry" placeholder="50.00" step="0.01">
        </div>
        <div class="field">
          <label>ATR Value ($)</label>
          <input type="number" id="atr-value" placeholder="1.25" step="0.01">
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>ATR Multiplier</label>
          <select id="atr-mult">
            <option value="1">1× ATR (tight)</option>
            <option value="1.5" selected>1.5× ATR (standard)</option>
            <option value="2">2× ATR (loose)</option>
            <option value="2.5">2.5× ATR (very loose)</option>
          </select>
        </div>
        <div class="field">
          <label>Trade Direction</label>
          <select id="atr-dir">
            <option value="long">Long (Buy)</option>
            <option value="short">Short (Sell)</option>
          </select>
        </div>
      </div>
      <button class="calc-btn" onclick="calcATRStop()">CALCULATE ATR STOP</button>
      <div class="result-box" id="atr-result">
        <div class="result-row"><span class="result-label">ATR Buffer Distance</span><span class="result-value" id="atr-buffer">—</span></div>
        <div class="result-row"><span class="result-label">Stop Loss Price</span><span class="result-value red" id="atr-stopprice">—</span></div>
        <div class="result-row"><span class="result-label">Stop Distance (%)</span><span class="result-value yellow" id="atr-stopdist">—</span></div>
        <div class="result-row"><span class="result-label">Suggested Take Profit (2:1)</span><span class="result-value green" id="atr-tp">—</span></div>
        <div class="result-row"><span class="result-label">Suggested Take Profit (3:1)</span><span class="result-value cyan" id="atr-tp3">—</span></div>
      </div>
      <div class="tip-box">
        <p><strong>Why ATR?</strong> A fixed $0.50 stop on a $10 stock is very different from the same stop on a $200 stock. <strong>ATR scales your stop to actual volatility</strong>, giving your trade room to breathe without giving up too much.</p>
      </div>
    </div>

    <!-- COMPOUND GROWTH PLANNER -->
    <div class="tool-card">
      <div class="tool-title">📈 Compound Growth Planner</div>
      <p class="tool-desc">See how consistent monthly returns compound over time. Shows the power of protecting capital and staying in the game.</p>
      <div class="field-row">
        <div class="field">
          <label>Starting Capital ($)</label>
          <input type="number" id="cg-start" placeholder="10000" value="10000">
        </div>
        <div class="field">
          <label>Monthly Return (%)</label>
          <input type="number" id="cg-monthly" placeholder="3" value="3" step="0.1">
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Monthly Contribution ($)</label>
          <input type="number" id="cg-contrib" placeholder="500" value="500">
        </div>
        <div class="field">
          <label>Time Period (Years)</label>
          <input type="number" id="cg-years" placeholder="3" value="3" min="1" max="20">
        </div>
      </div>
      <button class="calc-btn" onclick="calcCompound()">PROJECT GROWTH</button>
      <div class="result-box" id="cg-result">
        <div class="result-row"><span class="result-label">Final Portfolio Value</span><span class="result-value cyan" id="cg-final">—</span></div>
        <div class="result-row"><span class="result-label">Total Contributed</span><span class="result-value" id="cg-invested">—</span></div>
        <div class="result-row"><span class="result-label">Total Profit from Returns</span><span class="result-value green" id="cg-profit">—</span></div>
        <div class="result-row"><span class="result-label">Annualized Return</span><span class="result-value yellow" id="cg-annual">—</span></div>
        <div class="divider"></div>
        <div style="overflow-x:auto;">
          <table class="compound-table" id="cg-table">
            <thead><tr><th>Year</th><th>Start</th><th>Contributed</th><th>Profit</th><th>End Value</th></tr></thead>
            <tbody id="cg-tbody"></tbody>
          </table>
        </div>
      </div>
      <div class="tip-box">
        <p><strong>The math:</strong> A 3% monthly return compounds to <strong>~42.6% annually</strong>. The goal isn't giant wins — it's <strong>consistent small edges, never blowing up,</strong> and letting time work.</p>
      </div>
    </div>

  </div><!-- end tools-grid -->
</div><!-- end page -->

<script>
document.querySelectorAll('#ttMob a').forEach(a=>a.addEventListener('click',()=>{document.getElementById('ttMob').classList.remove('open');document.getElementById('ttBurger').classList.remove('open');}));

function fmt(n){return n.toLocaleString('en-CA',{minimumFractionDigits:2,maximumFractionDigits:2});}
function fmtPct(n){return n.toFixed(2)+'%';}

// POSITION SIZE
function calcPositionSize(){
  const account=parseFloat(document.getElementById('ps-account').value)||0;
  const risk=parseFloat(document.getElementById('ps-risk').value)||0;
  const entry=parseFloat(document.getElementById('ps-entry').value)||0;
  const stop=parseFloat(document.getElementById('ps-stop').value)||0;
  if(!account||!risk||!entry||!stop||entry<=0||stop<=0||entry===stop){return;}
  const maxRisk=account*(risk/100);
  const riskPerShare=Math.abs(entry-stop);
  const shares=Math.floor(maxRisk/riskPerShare);
  const totalValue=shares*entry;
  const pctDeployed=(totalValue/account)*100;
  document.getElementById('ps-maxrisk').textContent='$'+fmt(maxRisk);
  document.getElementById('ps-riskpershare').textContent='$'+fmt(riskPerShare);
  document.getElementById('ps-shares').textContent=shares+' shares';
  document.getElementById('ps-value').textContent='$'+fmt(totalValue);
  document.getElementById('ps-pct').textContent=fmtPct(pctDeployed);
  document.getElementById('ps-result').classList.add('show');
}

// RISK REWARD
function calcRiskReward(){
  const entry=parseFloat(document.getElementById('rr-entry').value)||0;
  const stop=parseFloat(document.getElementById('rr-stop').value)||0;
  const target=parseFloat(document.getElementById('rr-target').value)||0;
  const shares=parseFloat(document.getElementById('rr-shares').value)||1;
  if(!entry||!stop||!target){return;}
  const risk=Math.abs(entry-stop)*shares;
  const reward=Math.abs(target-entry)*shares;
  const ratio=reward/risk;
  const minWin=1/(1+ratio)*100;
  let quality,qcolor;
  if(ratio>=3){quality='Excellent (3:1+)';qcolor='var(--green)';}
  else if(ratio>=2){quality='Good (2:1+)';qcolor='var(--cyan)';}
  else if(ratio>=1.5){quality='Acceptable (1.5:1)';qcolor='var(--yellow)';}
  else{quality='Poor — avoid this setup';qcolor='var(--red)';}
  document.getElementById('rr-risk').textContent='$'+fmt(risk);
  document.getElementById('rr-reward').textContent='$'+fmt(reward);
  document.getElementById('rr-ratio').textContent='1:'+ratio.toFixed(2);
  document.getElementById('rr-winrate').textContent=fmtPct(minWin)+' win rate to break even';
  const qEl=document.getElementById('rr-quality');
  qEl.textContent=quality;qEl.style.color=qcolor;
  document.getElementById('rr-result').classList.add('show');
}

// ATR STOP
function calcATRStop(){
  const entry=parseFloat(document.getElementById('atr-entry').value)||0;
  const atr=parseFloat(document.getElementById('atr-value').value)||0;
  const mult=parseFloat(document.getElementById('atr-mult').value)||1.5;
  const dir=document.getElementById('atr-dir').value;
  if(!entry||!atr){return;}
  const buffer=atr*mult;
  const stopPrice=dir==='long'?entry-buffer:entry+buffer;
  const stopDist=(buffer/entry)*100;
  const tp2=dir==='long'?entry+buffer*2:entry-buffer*2;
  const tp3=dir==='long'?entry+buffer*3:entry-buffer*3;
  document.getElementById('atr-buffer').textContent='$'+fmt(buffer);
  document.getElementById('atr-stopprice').textContent='$'+fmt(stopPrice);
  document.getElementById('atr-stopdist').textContent=fmtPct(stopDist)+' from entry';
  document.getElementById('atr-tp').textContent='$'+fmt(tp2);
  document.getElementById('atr-tp3').textContent='$'+fmt(tp3);
  document.getElementById('atr-result').classList.add('show');
}

// COMPOUND GROWTH
function calcCompound(){
  const start=parseFloat(document.getElementById('cg-start').value)||0;
  const monthly=parseFloat(document.getElementById('cg-monthly').value)||0;
  const contrib=parseFloat(document.getElementById('cg-contrib').value)||0;
  const years=parseInt(document.getElementById('cg-years').value)||1;
  if(!start||!monthly){return;}
  const r=monthly/100;
  let balance=start;
  let totalContrib=start;
  const rows=[];
  for(let y=1;y<=years;y++){
    const startBal=balance;
    for(let m=0;m<12;m++){balance=balance*(1+r)+contrib;}
    totalContrib+=contrib*12;
    rows.push({year:y,start:startBal,contrib:contrib*12,profit:balance-startBal-contrib*12,end:balance});
  }
  const totalProfit=balance-totalContrib;
  const annualReturn=(Math.pow(1+r,12)-1)*100;
  document.getElementById('cg-final').textContent='$'+fmt(balance);
  document.getElementById('cg-invested').textContent='$'+fmt(totalContrib);
  document.getElementById('cg-profit').textContent='$'+fmt(totalProfit);
  document.getElementById('cg-annual').textContent=fmtPct(annualReturn)+' per year';
  const tbody=document.getElementById('cg-tbody');
  tbody.innerHTML=rows.map(r=>`<tr><td>${r.year}</td><td>$${fmt(r.start)}</td><td class="profit">+$${fmt(r.contrib)}</td><td class="profit">+$${fmt(r.profit)}</td><td>$${fmt(r.end)}</td></tr>`).join('');
  document.getElementById('cg-result').classList.add('show');
}
</script>
