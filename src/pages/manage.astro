---
// TrendTrooper — Manage Subscription
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>Manage Subscription — TrendTrooper</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<script>if(localStorage.getItem("tt_dev_access")!=="tt-ironclad-2026"&&!localStorage.getItem("tt_sub_token")){sessionStorage.setItem("tt_redirect",location.pathname);location.replace("/subscribe");}</script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#020510;--cyan:#00cfff;--cyan-dim:rgba(0,200,255,0.08);--green:#00ff88;--red:#ff4060;--text:#e8eeff;--muted:rgba(220,235,255,0.95);--muted2:rgba(180,210,255,0.6);--border:rgba(0,200,255,0.1);--border2:rgba(0,200,255,0.2);}
body{background:var(--bg);color:var(--text);font-family:'Rajdhani',sans-serif;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,200,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,200,255,0.025) 1px,transparent 1px);background-size:50px 50px;z-index:0;pointer-events:none;}
body::after{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 20% 0%,rgba(112,64,255,0.08) 0%,transparent 50%),radial-gradient(ellipse at 80% 100%,rgba(0,200,255,0.06) 0%,transparent 50%);z-index:0;pointer-events:none;}
.card{position:relative;z-index:1;background:rgba(4,8,30,0.92);border:1px solid var(--border2);border-radius:16px;padding:48px 40px;max-width:500px;width:90%;}
.label{font-family:'Orbitron',sans-serif;font-size:0.6rem;letter-spacing:0.2em;color:var(--cyan);margin-bottom:10px;}
h1{font-family:'Orbitron',sans-serif;font-size:1.5rem;background:linear-gradient(135deg,#fff,var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:24px;}
.row{display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid var(--border);}
.row:last-of-type{border-bottom:none;}
.row-label{color:var(--muted2);font-size:0.9rem;}
.row-val{color:var(--text);font-weight:600;font-size:0.95rem;}
.status-active{color:var(--green);}
.status-inactive{color:var(--red);}
.token-box{background:var(--cyan-dim);border:1px solid var(--border2);border-radius:8px;padding:12px 16px;margin:24px 0;word-break:break-all;}
.token-label{font-size:0.75rem;color:var(--muted2);margin-bottom:6px;}
.token-val{font-family:'Orbitron',sans-serif;font-size:0.75rem;color:var(--cyan);letter-spacing:0.03em;}
.btn{display:block;width:100%;padding:13px;border-radius:8px;font-family:'Orbitron',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.1em;cursor:pointer;border:none;margin-bottom:10px;transition:all .2s;}
.btn-cancel{background:rgba(255,64,96,0.1);border:1px solid rgba(255,64,96,0.3);color:var(--red);}
.btn-cancel:hover{background:rgba(255,64,96,0.2);}
.btn-logout{background:var(--cyan-dim);border:1px solid var(--border2);color:var(--muted);}
.btn-logout:hover{border-color:var(--cyan);color:var(--cyan);}
.back{display:block;text-align:center;margin-top:16px;color:var(--muted2);font-size:0.85rem;text-decoration:none;}
.back:hover{color:var(--cyan);}
.msg{padding:12px 16px;border-radius:8px;font-size:0.9rem;margin-bottom:16px;display:none;}
.msg-ok{background:rgba(0,255,136,0.08);border:1px solid rgba(0,255,136,0.2);color:var(--green);}
.msg-err{background:rgba(255,64,96,0.08);border:1px solid rgba(255,64,96,0.2);color:var(--red);}
.confirm-box{display:none;background:rgba(255,64,96,0.06);border:1px solid rgba(255,64,96,0.2);border-radius:8px;padding:16px;margin-bottom:16px;text-align:center;}
.confirm-box p{color:var(--muted);font-size:0.9rem;margin-bottom:12px;}
.confirm-btns{display:flex;gap:10px;}
.confirm-btns button{flex:1;padding:10px;border-radius:8px;font-family:'Orbitron',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.08em;cursor:pointer;border:none;}
.confirm-yes{background:var(--red);color:#fff;}
.confirm-no{background:var(--cyan-dim);border:1px solid var(--border2)!important;color:var(--muted);}
@media(max-width:480px){.card{padding:32px 20px;}}
header{position:sticky;top:0;z-index:100;height:70px;background:rgba(2,5,20,.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);display:flex;align-items:center;justify-content:space-between;padding:0 32px;}
.tt-brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:#e8eeff;}
.tt-logo{width:42px;height:42px;border-radius:10px;background:linear-gradient(135deg,#7040ff,#00cfff);display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-weight:900;font-size:14px;color:#fff;flex-shrink:0;box-shadow:0 0 20px rgba(112,64,255,.4);}
.tt-name{font-family:'Orbitron',monospace;font-size:16px;font-weight:900;letter-spacing:2px;background:linear-gradient(90deg,#fff,#00cfff,#7040ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.tt-tag{font-size:9px;color:#00cfff;font-weight:600;letter-spacing:3px;text-transform:uppercase;display:block;opacity:.8;}
.tt-nav{display:flex;align-items:center;gap:1px;white-space:nowrap;}
.tt-nav a{color:#c8d8f0;padding:6px 9px;border-radius:8px;text-decoration:none;font-weight:800;font-size:11.5px;letter-spacing:.8px;text-transform:uppercase;transition:color .15s,background .15s;}
.tt-nav a:hover{color:#e8eeff;background:rgba(0,200,255,.06);}
.tt-nav a.cur{color:#00cfff;}
.tt-cta{background:linear-gradient(135deg,#00cfff,#7040ff)!important;color:#fff!important;font-weight:800!important;padding:8px 14px!important;border-radius:8px!important;box-shadow:0 0 20px rgba(0,200,255,.2)!important;}
.tt-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
.tt-burger span{width:22px;height:2px;background:#e8eeff;border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
.tt-burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.tt-burger.open span:nth-child(2){opacity:0;}
.tt-burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.tt-mob{display:none;flex-direction:column;position:sticky;top:70px;z-index:99;background:rgba(2,5,20,.97);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);padding:8px 24px 16px;}
.tt-mob.open{display:flex;}
.tt-mob a{color:#c8d8f0;padding:10px 0;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:1px;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.04);}
.tt-mob a:hover{color:#e8eeff;}
@media(max-width:900px){.tt-nav{display:none;}.tt-burger{display:flex;}}
.page-wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:40px 20px;}
</style>
</head>
<body style="justify-content:flex-start;align-items:stretch;">
<header>
  <a class="tt-brand" href="/">
    <div class="tt-logo">TT</div>
    <div><div class="tt-name">TRENDTROOPER</div><span class="tt-tag">Signal Service</span></div>
  </a>
  <nav class="tt-nav">
    <a href="/#features">Features</a>
    <a href="/chart">Live Chart</a>
    <a href="/#markets">Markets</a>
    <a href="/#pricing">Pricing</a>
    <a href="/chart">Full Chart</a>
    <a href="/analysis">Analysis</a>
    <a href="/screener">Screener</a>
    <a href="/academy">Academy</a>
    <a href="/tools">Tools</a>
    <a href="https://bot.trendtrooper.com/" target="_blank">Bot Status</a>
    <a href="/#pricing" class="tt-cta">Get Started</a>
  </nav>
  <button class="tt-burger" id="ttBurger" onclick="this.classList.toggle('open');document.getElementById('ttMob').classList.toggle('open')" aria-label="Menu"><span></span><span></span><span></span></button>
</header>
<div class="tt-mob" id="ttMob">
  <a href="/#features">Features</a>
  <a href="/chart">Live Chart</a>
  <a href="/#markets">Markets</a>
  <a href="/#pricing">Pricing</a>
  <a href="/chart">Full Chart</a>
  <a href="/analysis">Analysis</a>
  <a href="/screener">Screener</a>
  <a href="/academy">Academy</a>
  <a href="/tools">Tools</a>
  <a href="https://bot.trendtrooper.com/" target="_blank">Bot Status</a>
  <a href="/#pricing">Get Started</a>
</div>
<div class="page-wrap">
<div class="card">
  <div class="label">Account</div>
  <h1>Manage Subscription</h1>

  <div class="msg msg-ok" id="msgOk">Your subscription has been cancelled.</div>
  <div class="msg msg-err" id="msgErr">Something went wrong. Please try again.</div>

  <div class="row"><span class="row-label">Plan</span><span class="row-val" id="planVal">—</span></div>
  <div class="row"><span class="row-label">Status</span><span class="row-val status-active" id="statusVal">Active</span></div>
  <div class="row"><span class="row-label">Access</span><span class="row-val" id="accessVal">—</span></div>

  <div class="token-box">
    <div class="token-label">Your access token</div>
    <div class="token-val" id="tokenDisplay">Loading...</div>
  </div>

  <div class="confirm-box" id="confirmBox">
    <p>Are you sure? Your access will end at the current billing period.</p>
    <div class="confirm-btns">
      <button class="confirm-yes" onclick="doCancel()">Yes, Cancel</button>
      <button class="confirm-no" onclick="hideConfirm()">Keep Subscription</button>
    </div>
  </div>

  <button class="btn btn-cancel" onclick="showConfirm()" id="cancelBtn">Cancel Subscription</button>
  <button class="btn btn-logout" onclick="logout()">Log Out</button>
  <a href="/" class="back">← Back to TrendTrooper</a>
</div>

<script>
  const BOT = 'https://bot.trendtrooper.com';
  const token = localStorage.getItem('tt_sub_token') || localStorage.getItem('tt_dev_access');

  document.getElementById('tokenDisplay').textContent = token || '—';

  if (token === 'tt-ironclad-2026') {
    document.getElementById('planVal').textContent = 'Developer';
    document.getElementById('statusVal').textContent = 'Active (Dev)';
    document.getElementById('accessVal').textContent = 'All pages';
    document.getElementById('cancelBtn').style.display = 'none';
  } else if (token) {
    fetch(`${BOT}/verify-token?token=${token}`)
      .then(r => r.json())
      .then(d => {
        if (d.valid) {
          document.getElementById('planVal').textContent = d.plan.charAt(0).toUpperCase() + d.plan.slice(1);
          document.getElementById('accessVal').textContent = 'All member pages';
        } else {
          document.getElementById('statusVal').textContent = 'Inactive';
          document.getElementById('statusVal').className = 'row-val status-inactive';
          document.getElementById('cancelBtn').style.display = 'none';
        }
      });
  }

  function showConfirm() { document.getElementById('confirmBox').style.display = 'block'; }
  function hideConfirm() { document.getElementById('confirmBox').style.display = 'none'; }

  function doCancel() {
    fetch(`${BOT}/cancel-subscription`, {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({token})
    })
    .then(r => r.json())
    .then(d => {
      if (d.status === 'cancelled') {
        localStorage.removeItem('tt_sub_token');
        document.getElementById('confirmBox').style.display = 'none';
        document.getElementById('msgOk').style.display = 'block';
        document.getElementById('cancelBtn').style.display = 'none';
        document.getElementById('statusVal').textContent = 'Cancelled';
        document.getElementById('statusVal').className = 'row-val status-inactive';
      } else {
        document.getElementById('msgErr').style.display = 'block';
      }
    })
    .catch(() => { document.getElementById('msgErr').style.display = 'block'; });
  }

  function logout() {
    localStorage.removeItem('tt_dev_access');
    localStorage.removeItem('tt_sub_token');
    window.location.href = '/';
  }
  document.querySelectorAll('#ttMob a').forEach(a=>a.addEventListener('click',()=>{document.getElementById('ttMob').classList.remove('open');document.getElementById('ttBurger').classList.remove('open');}));
</script>
</div></div>
</body>
</html>
