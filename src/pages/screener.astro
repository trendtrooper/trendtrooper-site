---
// TrendTrooper — Screener src/pages/screener.astro
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>TrendTrooper — Signal Screener</title>
  <meta name="description" content="Filter stocks and ETFs by technical signals. EMA, RSI, VWAP, ATR and more." />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root{
      --bg:#070e1c;--card:#0f1b33;--card2:#111e38;
      --muted:#7a96bb;--muted2:#4a6490;
      --text:#ddeeff;--text2:#b8d0ee;
      --accent:#6ee7ff;--accent2:#a78bfa;
      --green:#22d673;--red:#ff5c6a;--amber:#f59e0b;
      --border2:rgba(255,255,255,.06);--r:16px;--max:1260px;
      --mono:'JetBrains Mono',monospace;--sans:'Space Grotesk',sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:var(--sans);color:var(--text);background:var(--bg);min-height:100vh}
    a{color:inherit;text-decoration:none}
    header{position:sticky;top:0;z-index:100;background:rgba(7,14,28,.9);backdrop-filter:blur(16px);border-bottom:1px solid var(--border2)}
    .nav{max-width:var(--max);margin:0 auto;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;gap:20px}
    .brand{display:flex;align-items:center;gap:12px;font-weight:900;font-size:13px;font-family:'Orbitron',monospace;letter-spacing:.5px;}
    .logo{width:34px;height:34px;border-radius:10px;flex:0 0 auto;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-weight:900;font-size:11px;color:#fff;letter-spacing:.5px;box-shadow:0 0 16px rgba(110,231,255,.25);}
    .brand-sub{font-size:11px;color:var(--muted);font-weight:500}
    .navlinks{display:flex;gap:22px;color:var(--muted);font-size:13.5px;font-weight:500}
    .navlinks a:hover{color:var(--text)}.navlinks a.active{color:var(--accent)}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:9px 18px;border-radius:12px;font-weight:600;font-size:13.5px;border:1px solid var(--border2);background:rgba(255,255,255,.05);color:var(--text);cursor:pointer;transition:.15s;font-family:var(--sans)}
    .btn:hover{background:rgba(255,255,255,.08)}
    .btn.primary{background:linear-gradient(135deg,var(--accent),var(--accent2));border:none;color:#070e1c;font-weight:700}
    .btn.active-filter{border-color:rgba(110,231,255,.4);background:rgba(110,231,255,.10);color:var(--accent)}
    .wrap{max-width:var(--max);margin:0 auto;padding:32px 24px}
    /* FILTERS */
    .filter-bar{background:var(--card);border-radius:var(--r);border:1px solid var(--border2);padding:20px;margin-bottom:20px}
    .filter-row{display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-bottom:14px}
    .filter-row:last-child{margin-bottom:0}
    .filter-label{font-size:11px;font-weight:700;color:var(--muted2);letter-spacing:.5px;min-width:80px}
    .fchip{padding:6px 14px;border-radius:999px;font-size:12px;font-weight:600;border:1px solid var(--border2);color:var(--muted);cursor:pointer;background:transparent;font-family:var(--sans);transition:.15s}
    .fchip:hover{color:var(--text);border-color:rgba(255,255,255,.15)}
    .fchip.on{background:rgba(110,231,255,.12);border-color:rgba(110,231,255,.35);color:var(--accent)}
    .fchip.green-on{background:rgba(34,214,115,.12);border-color:rgba(34,214,115,.35);color:var(--green)}
    .fchip.red-on{background:rgba(255,92,106,.12);border-color:rgba(255,92,106,.35);color:var(--red)}
    .search-wrap{position:relative;flex:1;min-width:200px}
    .search-wrap input{width:100%;padding:9px 14px 9px 38px;border-radius:12px;border:1px solid var(--border2);background:rgba(255,255,255,.04);color:var(--text);font-size:13.5px;font-family:var(--sans);outline:none;transition:.15s}
    .search-wrap input:focus{border-color:rgba(110,231,255,.4);background:rgba(110,231,255,.04)}
    .search-wrap::before{content:"⌕";position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:16px;pointer-events:none}
    /* RESULTS BAR */
    .results-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px}
    .results-count{font-size:13px;color:var(--muted)}
    .results-count strong{color:var(--text)}
    .sort-row{display:flex;gap:8px;align-items:center}
    .sort-label{font-size:12px;color:var(--muted2)}
    select{padding:7px 12px;border-radius:10px;border:1px solid var(--border2);background:var(--card);color:var(--text);font-size:12.5px;font-family:var(--sans);outline:none;cursor:pointer}
    /* TABLE */
    .table-wrap{border-radius:var(--r);border:1px solid var(--border2);overflow:hidden;background:var(--card)}
    table{width:100%;border-collapse:collapse}
    th{padding:12px 16px;font-size:10px;font-weight:700;color:var(--muted2);letter-spacing:.8px;text-align:left;border-bottom:1px solid var(--border2);background:rgba(255,255,255,.02);cursor:pointer;user-select:none;white-space:nowrap}
    th:hover{color:var(--muted)}
    th .sort-arrow{margin-left:4px;opacity:.5}
    td{padding:11px 16px;font-size:13px;border-bottom:1px solid rgba(255,255,255,.03);white-space:nowrap}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:rgba(255,255,255,.025)}
    .td-sym{font-family:var(--mono);font-weight:700;color:var(--accent);font-size:14px}
    .td-name{color:var(--muted);font-size:12px}
    .td-price{font-family:var(--mono);font-weight:700}
    .td-chg{font-family:var(--mono);font-weight:700}
    .up{color:var(--green)}.dn{color:var(--red)}
    .sig{display:inline-block;font-size:10px;font-weight:700;padding:3px 8px;border-radius:999px;font-family:var(--mono)}
    .sig.buy{background:rgba(34,214,115,.12);border:1px solid rgba(34,214,115,.3);color:var(--green)}
    .sig.sell{background:rgba(255,92,106,.12);border:1px solid rgba(255,92,106,.3);color:var(--red)}
    .sig.hold{background:rgba(245,158,11,.10);border:1px solid rgba(245,158,11,.25);color:var(--amber)}
    .sig.neutral{background:rgba(255,255,255,.05);border:1px solid var(--border2);color:var(--muted)}
    .rsi-bar{display:flex;align-items:center;gap:6px}
    .rsi-track{width:50px;height:5px;border-radius:3px;background:rgba(255,255,255,.08);position:relative;overflow:hidden}
    .rsi-fill{height:100%;border-radius:3px;transition:.3s}
    .td-tag{font-size:10px;padding:2px 7px;border-radius:999px;border:1px solid var(--border2);color:var(--muted2);background:rgba(255,255,255,.03)}
    /* EMPTY STATE */
    .empty{text-align:center;padding:60px 20px;color:var(--muted)}
    .empty h3{font-size:16px;margin-bottom:8px;color:var(--text2)}
    footer{max-width:var(--max);margin:40px auto 0;padding:24px;border-top:1px solid var(--border2);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;color:var(--muted2);font-size:13px}
    .foot-links{display:flex;gap:18px}.foot-links a:hover{color:var(--muted)}
    @media(max-width:900px){.navlinks{display:none}.hamburger{display:flex;}table{font-size:12px}td,th{padding:10px 10px}}
    .hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
    .hamburger span{width:20px;height:2px;background:var(--text);border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
    .hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .hamburger.open span:nth-child(2){opacity:0;}
    .hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .inner-mobile-menu{display:none;flex-direction:column;position:sticky;top:61px;z-index:99;background:rgba(7,14,28,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border2);padding:8px 24px 16px;}
    .inner-mobile-menu.open{display:flex;}
    .inner-mobile-menu a{color:var(--muted);text-decoration:none;font-weight:600;font-size:14px;padding:11px 0;border-bottom:1px solid var(--border2);transition:color .15s;}
    .inner-mobile-menu a:last-child{border-bottom:none;}
    .inner-mobile-menu a:hover{color:var(--text);}
  </style>
</head>
<body>
<header>
  <div class="nav">
    <div class="brand">
      <div class="logo">TT</div>
      <div><div>TrendTrooper</div><div class="brand-sub">SCREENER</div></div>
    </div>
    <nav class="navlinks">
      <a href="/">Home</a>
      <a href="/dashboard">Dashboard</a>
      <a href="/screener" class="active">Screener</a>
      <a href="/strategy">Strategy</a>
      <a href="/academy">Academy</a>
    </nav>
    <div style="display:flex;gap:8px;align-items:center">
      <a class="btn" href="/">← HQ</a>
      <button class="hamburger" id="hamburgerBtn" onclick="toggleInnerMenu()" aria-label="Open navigation"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>
<div class="inner-mobile-menu" id="innerMobileMenu">
  <a href="/">Home</a>
  <a href="/dashboard">Dashboard</a>
  <a href="/screener">Screener</a>
  <a href="/strategy">Strategy</a>
  <a href="/academy">Academy</a>
  <a href="https://bot.trendtrooper.com/" target="_blank">Bot Status</a>
</div>

<div class="wrap">
  <div style="margin-bottom:20px">
    <h1 style="font-size:24px;font-weight:700;margin-bottom:6px">Signal Screener</h1>
    <p style="color:var(--muted);font-size:13.5px">Filter by signal, sector, RSI zone, and more. Simulated data — connects to live feed in production.</p>
  </div>

  <!-- FILTER BAR -->
  <div class="filter-bar">
    <div class="filter-row">
      <span class="filter-label">SIGNAL</span>
      <button class="fchip green-on" data-filter="signal" data-val="BUY">BUY</button>
      <button class="fchip red-on" data-filter="signal" data-val="SELL">SELL</button>
      <button class="fchip" data-filter="signal" data-val="HOLD">HOLD</button>
      <button class="fchip" data-filter="signal" data-val="NEUTRAL">NEUTRAL</button>
      <button class="fchip on" data-filter="signal" data-val="ALL">ALL</button>
      <div class="search-wrap" style="margin-left:auto">
        <input type="text" id="searchInput" placeholder="Search symbol or name…" />
      </div>
    </div>
    <div class="filter-row">
      <span class="filter-label">SECTOR</span>
      <button class="fchip on" data-filter="sector" data-val="ALL">All</button>
      <button class="fchip" data-filter="sector" data-val="ETF">ETF</button>
      <button class="fchip" data-filter="sector" data-val="Tech">Tech</button>
      <button class="fchip" data-filter="sector" data-val="Finance">Finance</button>
      <button class="fchip" data-filter="sector" data-val="Energy">Energy</button>
      <button class="fchip" data-filter="sector" data-val="Health">Health</button>
      <button class="fchip" data-filter="sector" data-val="Industrials">Industrials</button>
    </div>
    <div class="filter-row">
      <span class="filter-label">RSI ZONE</span>
      <button class="fchip on" data-filter="rsi" data-val="ALL">All</button>
      <button class="fchip red-on" data-filter="rsi" data-val="OS">Oversold &lt;30</button>
      <button class="fchip" data-filter="rsi" data-val="MID">Mid 30–70</button>
      <button class="fchip" data-filter="rsi" data-val="OB">Overbought &gt;70</button>
      <span class="filter-label" style="margin-left:20px">ABOVE VWAP</span>
      <button class="fchip on" data-filter="vwap" data-val="ALL">All</button>
      <button class="fchip" data-filter="vwap" data-val="YES">Yes</button>
      <button class="fchip" data-filter="vwap" data-val="NO">No</button>
    </div>
  </div>

  <div class="results-bar">
    <div class="results-count">Showing <strong id="resCount">0</strong> results</div>
    <div class="sort-row">
      <span class="sort-label">Sort by</span>
      <select id="sortSel">
        <option value="sym">Symbol</option>
        <option value="chg">Change %</option>
        <option value="rsi">RSI</option>
        <option value="atr">ATR</option>
      </select>
    </div>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>SYMBOL</th>
          <th>NAME</th>
          <th>PRICE</th>
          <th>CHG %</th>
          <th>SIGNAL</th>
          <th>RSI(14)</th>
          <th>VWAP</th>
          <th>ATR(14)</th>
          <th>EMA TREND</th>
          <th>SECTOR</th>
        </tr>
      </thead>
      <tbody id="tableBody"></tbody>
    </table>
    <div class="empty" id="emptyState" style="display:none">
      <h3>No results match your filters</h3>
      <p>Try adjusting the signal or sector filters above.</p>
    </div>
  </div>
</div>

<footer>
  <div>TrendTrooper Screener &nbsp;•&nbsp; © <span id="yr"></span> &nbsp;•&nbsp; Simulated data</div>
  <div class="foot-links"><a href="/">Home</a><a href="/dashboard">Dashboard</a><a href="/academy">Academy</a></div>
</footer>

<script>
document.getElementById('yr').textContent=new Date().getFullYear();
function toggleInnerMenu(){
  document.getElementById('innerMobileMenu').classList.toggle('open');
  document.getElementById('hamburgerBtn').classList.toggle('open');
}

function rnd(a,b){return+(Math.random()*(b-a)+a).toFixed(2)}

const RAW=[
  {sym:'SPXL',name:'Direxion S&P 500 Bull 3x',sector:'ETF',base:98.4,signal:'BUY',rsi:58,vwap:true,ema:'Bullish'},
  {sym:'TQQQ',name:'ProShares Ultra QQQ 3x',sector:'ETF',base:62.15,signal:'BUY',rsi:62,vwap:true,ema:'Bullish'},
  {sym:'SQQQ',name:'ProShares UltraPro Short QQQ',sector:'ETF',base:8.44,signal:'HOLD',rsi:42,vwap:false,ema:'Bearish'},
  {sym:'SPXS',name:'Direxion S&P 500 Bear 3x',sector:'ETF',base:14.22,signal:'SELL',rsi:38,vwap:false,ema:'Bearish'},
  {sym:'UVXY',name:'ProShares Ultra VIX',sector:'ETF',base:5.88,signal:'HOLD',rsi:55,vwap:true,ema:'Neutral'},
  {sym:'LABU',name:'Direxion Daily Biotech Bull',sector:'ETF',base:102.3,signal:'NEUTRAL',rsi:50,vwap:true,ema:'Neutral'},
  {sym:'AAPL',name:'Apple Inc.',sector:'Tech',base:211.5,signal:'BUY',rsi:64,vwap:true,ema:'Bullish'},
  {sym:'MSFT',name:'Microsoft Corp.',sector:'Tech',base:415.2,signal:'BUY',rsi:68,vwap:true,ema:'Bullish'},
  {sym:'NVDA',name:'NVIDIA Corp.',sector:'Tech',base:875.4,signal:'BUY',rsi:72,vwap:true,ema:'Bullish'},
  {sym:'GOOGL',name:'Alphabet Inc.',sector:'Tech',base:178.9,signal:'HOLD',rsi:58,vwap:true,ema:'Neutral'},
  {sym:'META',name:'Meta Platforms',sector:'Tech',base:492.1,signal:'BUY',rsi:61,vwap:true,ema:'Bullish'},
  {sym:'TSLA',name:'Tesla Inc.',sector:'Tech',base:182.4,signal:'SELL',rsi:35,vwap:false,ema:'Bearish'},
  {sym:'AMD',name:'Advanced Micro Devices',sector:'Tech',base:155.8,signal:'HOLD',rsi:48,vwap:false,ema:'Neutral'},
  {sym:'JPM',name:'JPMorgan Chase',sector:'Finance',base:198.5,signal:'BUY',rsi:60,vwap:true,ema:'Bullish'},
  {sym:'BAC',name:'Bank of America',sector:'Finance',base:38.9,signal:'HOLD',rsi:45,vwap:false,ema:'Neutral'},
  {sym:'GS',name:'Goldman Sachs',sector:'Finance',base:448.2,signal:'BUY',rsi:63,vwap:true,ema:'Bullish'},
  {sym:'XOM',name:'Exxon Mobil',sector:'Energy',base:112.4,signal:'SELL',rsi:29,vwap:false,ema:'Bearish'},
  {sym:'CVX',name:'Chevron Corp.',sector:'Energy',base:154.8,signal:'HOLD',rsi:44,vwap:false,ema:'Neutral'},
  {sym:'JNJ',name:'Johnson & Johnson',sector:'Health',base:158.2,signal:'HOLD',rsi:52,vwap:true,ema:'Neutral'},
  {sym:'PFE',name:'Pfizer Inc.',sector:'Health',base:27.4,signal:'SELL',rsi:32,vwap:false,ema:'Bearish'},
  {sym:'UNH',name:'UnitedHealth Group',sector:'Health',base:492.0,signal:'BUY',rsi:66,vwap:true,ema:'Bullish'},
  {sym:'CAT',name:'Caterpillar Inc.',sector:'Industrials',base:352.1,signal:'BUY',rsi:61,vwap:true,ema:'Bullish'},
  {sym:'BA',name:'Boeing Co.',sector:'Industrials',base:182.5,signal:'SELL',rsi:34,vwap:false,ema:'Bearish'},
];

// Generate live-ish prices
const DATA=RAW.map(r=>{
  const chg=rnd(-2.8,2.8);
  const price=+(r.base*(1+chg/100)).toFixed(2);
  const atr=rnd(0.8,4.5);
  return{...r,price,chg,atr};
});

let filters={signal:'ALL',sector:'ALL',rsi:'ALL',vwap:'ALL',search:''};
let sortKey='sym';

function getRsiZone(r){return r<30?'OS':r>70?'OB':'MID'}

function applyFilters(){
  return DATA.filter(r=>{
    if(filters.signal!=='ALL'&&r.signal!==filters.signal)return false;
    if(filters.sector!=='ALL'&&r.sector!==filters.sector)return false;
    if(filters.rsi!=='ALL'&&getRsiZone(r.rsi)!==filters.rsi)return false;
    if(filters.vwap==='YES'&&!r.vwap)return false;
    if(filters.vwap==='NO'&&r.vwap)return false;
    if(filters.search&&!r.sym.toLowerCase().includes(filters.search)&&!r.name.toLowerCase().includes(filters.search))return false;
    return true;
  }).sort((a,b)=>{
    if(sortKey==='chg')return b.chg-a.chg;
    if(sortKey==='rsi')return b.rsi-a.rsi;
    if(sortKey==='atr')return b.atr-a.atr;
    return a.sym.localeCompare(b.sym);
  });
}

function renderTable(){
  const rows=applyFilters();
  const tb=document.getElementById('tableBody');
  const empty=document.getElementById('emptyState');
  document.getElementById('resCount').textContent=rows.length;
  if(rows.length===0){tb.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  const rsiCol=(r)=>{
    const pct=r/100;
    const col=r<30?'#ff5c6a':r>70?'#a78bfa':'#6ee7ff';
    return`<div class="rsi-bar"><div class="rsi-track"><div class="rsi-fill" style="width:${r}%;background:${col}"></div></div><span style="font-family:var(--mono);font-size:12px">${r}</span></div>`;
  };
  tb.innerHTML=rows.map(r=>`
    <tr>
      <td class="td-sym">${r.sym}</td>
      <td class="td-name">${r.name}</td>
      <td class="td-price">$${r.price.toFixed(2)}</td>
      <td class="td-chg ${r.chg>=0?'up':'dn'}">${r.chg>=0?'+':''}${r.chg.toFixed(2)}%</td>
      <td><span class="sig ${r.signal.toLowerCase()}">${r.signal}</span></td>
      <td>${rsiCol(r.rsi)}</td>
      <td style="color:${r.vwap?'var(--green)':'var(--red)'};font-family:var(--mono);font-size:12px">${r.vwap?'↑ Above':'↓ Below'}</td>
      <td style="font-family:var(--mono)">$${r.atr.toFixed(2)}</td>
      <td><span class="td-tag" style="color:${r.ema==='Bullish'?'var(--green)':r.ema==='Bearish'?'var(--red)':'var(--amber)'}">${r.ema}</span></td>
      <td><span class="td-tag">${r.sector}</span></td>
    </tr>`).join('');
}

// Filter chips
document.querySelectorAll('.fchip').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const f=btn.dataset.filter;
    const v=btn.dataset.val;
    filters[f]=v;
    document.querySelectorAll(`.fchip[data-filter="${f}"]`).forEach(b=>{
      b.classList.remove('on','green-on','red-on');
    });
    if(v==='BUY')btn.classList.add('green-on');
    else if(v==='SELL')btn.classList.add('red-on');
    else btn.classList.add('on');
    renderTable();
  });
});

document.getElementById('searchInput').addEventListener('input',e=>{
  filters.search=e.target.value.toLowerCase().trim();
  renderTable();
});

document.getElementById('sortSel').addEventListener('change',e=>{
  sortKey=e.target.value;
  renderTable();
});

renderTable();
</script>
</body>
</html>
