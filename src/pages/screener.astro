---
import LogoutBar from "../components/LogoutBar.astro";
// TrendTrooper — Screener src/pages/screener.astro
---
<!doctype html>
<html lang="en">
<head>
<script>if(localStorage.getItem("tt_dev_access")!=="tt-ironclad-2026"&&!localStorage.getItem("tt_sub_token")){sessionStorage.setItem("tt_redirect",location.pathname);location.replace("/subscribe");}</script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>TrendTrooper — Signal Screener</title>
  <meta name="description" content="Filter stocks and ETFs by technical signals. EMA, RSI, VWAP, ATR and more." />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root{
      --bg:#070e1c;--card:#0f1b33;--card2:#111e38;
      --muted:#7a96bb;--muted2:#4a6490;
      --text:#ddeeff;--text2:#b8d0ee;
      --accent:#6ee7ff;--accent2:#a78bfa;
      --green:#22d673;--red:#ff5c6a;--amber:#f59e0b;
      --border2:rgba(255,255,255,.06);--r:16px;--max:1260px;
      --mono:'JetBrains Mono',monospace;--sans:'Space Grotesk',sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:var(--sans);color:var(--text);background:var(--bg);min-height:100vh}
    a{color:inherit;text-decoration:none}
    header{position:sticky;top:0;z-index:100;height:70px;background:rgba(2,5,20,.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);display:flex;align-items:center;justify-content:space-between;padding:0 32px;}
    .tt-brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:#e8eeff;}
    .tt-logo{width:42px;height:42px;border-radius:10px;background:linear-gradient(135deg,#7040ff,#00cfff);display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-weight:900;font-size:14px;color:#fff;flex-shrink:0;box-shadow:0 0 20px rgba(112,64,255,.4);}
    .tt-name{font-family:'Orbitron',monospace;font-size:16px;font-weight:900;letter-spacing:2px;background:linear-gradient(90deg,#fff,#00cfff,#7040ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
    .tt-tag{font-size:9px;color:#00cfff;font-weight:600;letter-spacing:3px;text-transform:uppercase;display:block;opacity:.8;}
    .tt-nav{display:flex;align-items:center;gap:1px;white-space:nowrap;}
    .tt-nav a{color:#c8d8f0;padding:6px 9px;border-radius:8px;text-decoration:none;font-weight:800;font-size:11.5px;letter-spacing:.8px;text-transform:uppercase;transition:color .15s,background .15s;}
    .tt-nav a:hover{color:#e8eeff;background:rgba(0,200,255,.06);}
    .tt-nav a.cur{color:#00cfff;}
    .tt-cta{background:linear-gradient(135deg,#00cfff,#7040ff)!important;color:#fff!important;font-weight:800!important;padding:8px 14px!important;border-radius:8px!important;box-shadow:0 0 20px rgba(0,200,255,.2)!important;}
    .tt-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
    .tt-burger span{width:22px;height:2px;background:#e8eeff;border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
    .tt-burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .tt-burger.open span:nth-child(2){opacity:0;}
    .tt-burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .tt-mob{display:none;flex-direction:column;position:sticky;top:70px;z-index:99;background:rgba(2,5,20,.97);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);padding:8px 24px 16px;}
    .tt-mob.open{display:flex;}
    .tt-mob a{color:rgba(180,210,255,.65);padding:10px 0;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:1px;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.04);}
    .tt-mob a:hover{color:#e8eeff;}
    @media(max-width:900px){.tt-nav{display:none;}.tt-burger{display:flex;}}
    /* Simulated data banner */
    .sim-banner{width:100%;background:#f59e0b;color:#1a1000;font-size:13.5px;font-weight:700;text-align:center;padding:8px 16px;letter-spacing:.3px;}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:9px 18px;border-radius:12px;font-weight:600;font-size:13.5px;border:1px solid var(--border2);background:rgba(255,255,255,.05);color:var(--text);cursor:pointer;transition:.15s;font-family:var(--sans)}
    .btn:hover{background:rgba(255,255,255,.08)}
    .btn.primary{background:linear-gradient(135deg,var(--accent),var(--accent2));border:none;color:#070e1c;font-weight:700}
    .btn.active-filter{border-color:rgba(110,231,255,.4);background:rgba(110,231,255,.10);color:var(--accent)}
    .wrap{max-width:var(--max);margin:0 auto;padding:32px 24px}
    /* FILTERS */
    .filter-bar{background:var(--card);border-radius:var(--r);border:1px solid var(--border2);padding:20px;margin-bottom:20px}
    .filter-row{display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-bottom:14px}
    .filter-row:last-child{margin-bottom:0}
    .filter-label{font-size:11px;font-weight:700;color:var(--muted2);letter-spacing:.5px;min-width:80px}
    .fchip{padding:6px 14px;border-radius:999px;font-size:12px;font-weight:600;border:1px solid var(--border2);color:var(--muted);cursor:pointer;background:transparent;font-family:var(--sans);transition:.15s}
    .fchip:hover{color:var(--text);border-color:rgba(255,255,255,.15)}
    .fchip.on{background:rgba(110,231,255,.12);border-color:rgba(110,231,255,.35);color:var(--accent)}
    .fchip.green-on{background:rgba(34,214,115,.12);border-color:rgba(34,214,115,.35);color:var(--green)}
    .fchip.red-on{background:rgba(255,92,106,.12);border-color:rgba(255,92,106,.35);color:var(--red)}
    .search-wrap{position:relative;flex:1;min-width:200px}
    .search-wrap input{width:100%;padding:9px 14px 9px 38px;border-radius:12px;border:1px solid var(--border2);background:rgba(255,255,255,.04);color:var(--text);font-size:13.5px;font-family:var(--sans);outline:none;transition:.15s}
    .search-wrap input:focus{border-color:rgba(110,231,255,.4);background:rgba(110,231,255,.04)}
    .search-wrap::before{content:"⌕";position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:16px;pointer-events:none}
    /* RESULTS BAR */
    .results-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px}
    .results-count{font-size:13px;color:var(--muted)}
    .results-count strong{color:var(--text)}
    .results-bar-right{display:flex;align-items:center;gap:10px}
    /* CSV export button */
    .btn-csv{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:10px;font-size:12.5px;font-weight:600;border:1px solid rgba(110,231,255,.3);background:rgba(110,231,255,.07);color:var(--accent);cursor:pointer;font-family:var(--sans);transition:.15s;}
    .btn-csv:hover{background:rgba(110,231,255,.14);border-color:rgba(110,231,255,.5);}
    select{padding:7px 12px;border-radius:10px;border:1px solid var(--border2);background:var(--card);color:var(--text);font-size:12.5px;font-family:var(--sans);outline:none;cursor:pointer}
    /* TABLE */
    .table-wrap{border-radius:var(--r);border:1px solid var(--border2);overflow:hidden;background:var(--card)}
    table{width:100%;border-collapse:collapse}
    th{padding:12px 16px;font-size:12px;font-weight:700;color:var(--muted2);letter-spacing:.8px;text-align:left;border-bottom:1px solid var(--border2);background:rgba(255,255,255,.02);cursor:pointer;user-select:none;white-space:nowrap}
    th:hover{color:var(--muted)}
    th.sort-active{color:var(--accent)}
    th .sort-arrow{margin-left:4px;opacity:.7;font-size:10px}
    td{padding:11px 16px;font-size:13px;border-bottom:1px solid rgba(255,255,255,.03);white-space:nowrap}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:rgba(255,255,255,.025)}
    .td-sym{font-family:var(--mono);font-weight:700;color:var(--accent);font-size:14px}
    .td-name{color:var(--muted);font-size:13px}
    .td-price{font-family:var(--mono);font-weight:700}
    .td-chg{font-family:var(--mono);font-weight:700}
    .up{color:var(--green)}.dn{color:var(--red)}
    .sig{display:inline-block;font-size:10px;font-weight:700;padding:3px 8px;border-radius:999px;font-family:var(--mono)}
    .sig.buy{background:rgba(34,214,115,.12);border:1px solid rgba(34,214,115,.3);color:var(--green)}
    .sig.sell{background:rgba(255,92,106,.12);border:1px solid rgba(255,92,106,.3);color:var(--red)}
    .sig.hold{background:rgba(245,158,11,.10);border:1px solid rgba(245,158,11,.25);color:var(--amber)}
    .sig.neutral{background:rgba(255,255,255,.05);border:1px solid var(--border2);color:var(--muted)}
    .rsi-bar{display:flex;align-items:center;gap:6px}
    .rsi-track{width:50px;height:5px;border-radius:3px;background:rgba(255,255,255,.08);position:relative;overflow:hidden}
    .rsi-fill{height:100%;border-radius:3px;transition:.3s}
    .td-tag{font-size:10px;padding:2px 7px;border-radius:999px;border:1px solid var(--border2);color:var(--muted2);background:rgba(255,255,255,.03)}
    .td-vol{font-family:var(--mono);font-size:13px;color:var(--muted)}
    /* EMPTY STATE */
    .empty{text-align:center;padding:60px 20px;color:var(--muted)}
    .empty h3{font-size:16px;margin-bottom:8px;color:var(--text2)}
    /* PAGINATION */
    .pagination{display:flex;align-items:center;justify-content:center;gap:10px;padding:16px;border-top:1px solid var(--border2);flex-wrap:wrap}
    .pg-btn{padding:7px 16px;border-radius:10px;font-size:13px;font-weight:600;border:1px solid var(--border2);background:rgba(255,255,255,.04);color:var(--text);cursor:pointer;font-family:var(--sans);transition:.15s;}
    .pg-btn:hover:not(:disabled){background:rgba(110,231,255,.08);border-color:rgba(110,231,255,.3);color:var(--accent);}
    .pg-btn:disabled{opacity:.3;cursor:default;}
    .pg-info{font-size:13px;color:var(--muted);font-family:var(--mono);}
    @media(max-width:768px){
      .pg-info-full{display:none;}
      .pg-info-short{display:block;}
      td,th{padding:9px 10px;}
      td{font-size:13px;}
      th{font-size:11px;}
    }
    @media(min-width:769px){
      .pg-info-short{display:none;}
      .pg-info-full{display:block;}
    }
    /* highlight matches */
    mark{background:rgba(110,231,255,.22);color:var(--accent);border-radius:2px;padding:0 1px;}
    footer{max-width:var(--max);margin:40px auto 0;padding:24px;border-top:1px solid var(--border2);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;color:var(--muted2);font-size:13px}
    .foot-links{display:flex;gap:18px}.foot-links a:hover{color:var(--muted)}
    @media(max-width:900px){table{font-size:12px}}
  </style>
</head>
<body>

<!-- Simulated data banner -->
<div class="sim-banner">&#9888; Simulated data for demonstration purposes. Not real-time market data.</div>

<header>
  <a class="tt-brand" href="/">
    <div class="tt-logo">TT</div>
    <div><div class="tt-name">TRENDTROOPER</div><span class="tt-tag">Signal Service</span></div>
  </a>
  <nav class="tt-nav">
    <a href="/#features">Features</a>
    <a href="/chart">Live Chart</a>
    <a href="/#markets">Markets</a>
    <a href="/#pricing">Pricing</a>
    <a href="/chart">Full Chart</a>
    <a href="/analysis">Analysis</a>
    <a href="/screener">Screener</a>
    <a href="/academy">Academy</a>
    <a href="/tools">Tools</a>
    <a href="https://bot.trendtrooper.com/" target="_blank">Live Bot Trading</a>
    <a href="/#pricing" class="tt-cta">Get Started</a>
  </nav>
  <button class="tt-burger" id="ttBurger" onclick="this.classList.toggle('open');document.getElementById('ttMob').classList.toggle('open')" aria-label="Menu"><span></span><span></span><span></span></button>
</header>
<div class="tt-mob" id="ttMob">
  <a href="/#features">Features</a>
  <a href="/chart">Live Chart</a>
  <a href="/#markets">Markets</a>
  <a href="/#pricing">Pricing</a>
  <a href="/chart">Full Chart</a>
  <a href="/analysis">Analysis</a>
  <a href="/screener">Screener</a>
  <a href="/academy">Academy</a>
  <a href="/tools">Tools</a>
  <a href="https://bot.trendtrooper.com/" target="_blank">Live Bot Trading</a>
  <a href="/#pricing">Get Started</a>
</div>

<div class="wrap">
  <div style="margin-bottom:20px">
    <h1 style="font-size:24px;font-weight:700;margin-bottom:6px">Signal Screener</h1>
    <p style="color:var(--muted);font-size:13.5px">Filter by signal, sector, RSI zone, and more. Simulated data — connects to live feed in production.</p>
  </div>

  <!-- FILTER BAR -->
  <div class="filter-bar">
    <div class="filter-row">
      <span class="filter-label">SIGNAL</span>
      <button class="fchip on" data-filter="signal" data-val="ALL">ALL</button>
      <button class="fchip" data-filter="signal" data-val="BUY">BUY</button>
      <button class="fchip" data-filter="signal" data-val="SELL">SELL</button>
      <button class="fchip" data-filter="signal" data-val="HOLD">HOLD</button>
      <button class="fchip" data-filter="signal" data-val="NEUTRAL">NEUTRAL</button>
      <div class="search-wrap" style="margin-left:auto">
        <input type="text" id="searchInput" placeholder="Search symbol or name…" />
      </div>
    </div>
    <div class="filter-row">
      <span class="filter-label">SECTOR</span>
      <button class="fchip on" data-filter="sector" data-val="ALL">All</button>
      <button class="fchip" data-filter="sector" data-val="ETF">ETF</button>
      <button class="fchip" data-filter="sector" data-val="Tech">Tech</button>
      <button class="fchip" data-filter="sector" data-val="Finance">Finance</button>
      <button class="fchip" data-filter="sector" data-val="Energy">Energy</button>
      <button class="fchip" data-filter="sector" data-val="Health">Health</button>
      <button class="fchip" data-filter="sector" data-val="Industrials">Industrials</button>
      <button class="fchip" data-filter="sector" data-val="Consumer">Consumer</button>
      <button class="fchip" data-filter="sector" data-val="Telecom">Telecom</button>
    </div>
    <div class="filter-row">
      <span class="filter-label">RSI ZONE</span>
      <button class="fchip on" data-filter="rsi" data-val="ALL">All</button>
      <button class="fchip red-on" data-filter="rsi" data-val="OS">Oversold &lt;30</button>
      <button class="fchip" data-filter="rsi" data-val="MID">Mid 30–70</button>
      <button class="fchip" data-filter="rsi" data-val="OB">Overbought &gt;70</button>
      <span class="filter-label" style="margin-left:20px">ABOVE VWAP</span>
      <button class="fchip on" data-filter="vwap" data-val="ALL">All</button>
      <button class="fchip" data-filter="vwap" data-val="YES">Yes</button>
      <button class="fchip" data-filter="vwap" data-val="NO">No</button>
    </div>
  </div>

  <div class="results-bar">
    <div class="results-count" id="resultsCount">Showing <strong id="resRange">—</strong> of <strong id="resTotal">0</strong> results</div>
    <div class="results-bar-right">
      <button class="btn-csv" id="exportCsvBtn">&#8659; Export CSV</button>
    </div>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr id="tableHead">
          <th data-col="sym">SYMBOL<span class="sort-arrow" id="arr-sym"></span></th>
          <th data-col="name">NAME<span class="sort-arrow" id="arr-name"></span></th>
          <th data-col="price">PRICE<span class="sort-arrow" id="arr-price"></span></th>
          <th data-col="chg">CHG %<span class="sort-arrow" id="arr-chg"></span></th>
          <th data-col="signal">SIGNAL<span class="sort-arrow" id="arr-signal"></span></th>
          <th data-col="rsi" title="Relative Strength Index — >70 overbought, <30 oversold">RSI(14)<span class="sort-arrow" id="arr-rsi"></span></th>
          <th data-col="vwap" title="Volume Weighted Average Price — price vs. daily average">VWAP<span class="sort-arrow" id="arr-vwap"></span></th>
          <th data-col="atr" title="Average True Range — measures volatility">ATR(14)<span class="sort-arrow" id="arr-atr"></span></th>
          <th data-col="vol">VOLUME<span class="sort-arrow" id="arr-vol"></span></th>
          <th data-col="ema" title="Exponential Moving Average trend using 9 and 20 period EMAs">EMA TREND (9/20)<span class="sort-arrow" id="arr-ema"></span></th>
          <th data-col="sector">SECTOR<span class="sort-arrow" id="arr-sector"></span></th>
        </tr>
      </thead>
      <tbody id="tableBody"><tr id="skeletonRow"><td colspan="11" style="text-align:center;padding:28px;color:rgba(180,210,255,.4);font-size:13px;letter-spacing:1px;">LOADING SIGNALS...</td></tr></tbody>
    </table>
    <div class="empty" id="emptyState" style="display:none">
      <h3>No results match your filters</h3>
      <p>Try adjusting the signal or sector filters above.</p>
    </div>
    <div class="pagination" id="paginationBar">
      <button class="pg-btn" id="pgPrev">&#8592; Prev</button>
      <span class="pg-info pg-info-full" id="pgInfoFull">Page 1 of 1</span>
      <span class="pg-info pg-info-short" id="pgInfoShort">Page 1 of 1</span>
      <button class="pg-btn" id="pgNext">Next &#8594;</button>
    </div>
  </div>
</div>

<footer>
  <div>TrendTrooper Screener &nbsp;•&nbsp; &copy; <span id="yr"></span> &nbsp;•&nbsp; Simulated data</div>
  <div class="foot-links"><a href="/">Home</a><a href="/dashboard">Dashboard</a><a href="/academy">Academy</a></div>
</footer>

<script>
document.getElementById('yr').textContent = new Date().getFullYear();

// Burger menu: close on link click inside mobile menu
document.querySelectorAll('#ttMob a').forEach(function(a) {
  a.addEventListener('click', function() {
    document.getElementById('ttMob').classList.remove('open');
    document.getElementById('ttBurger').classList.remove('open');
  });
});

function rnd(a, b) { return +(Math.random() * (b - a) + a).toFixed(2); }

function fmtVol(n) {
  if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
  if (n >= 1e3) return (n / 1e3).toFixed(0) + 'K';
  return n.toString();
}

function rndVol() {
  // return a raw number, format on display
  const tiers = [
    [200000, 900000],
    [900000, 5000000],
    [5000000, 80000000],
  ];
  const t = tiers[Math.floor(Math.random() * tiers.length)];
  return Math.floor(Math.random() * (t[1] - t[0]) + t[0]);
}

const RAW = [
  // ETFs
  {sym:'SPXL', name:'Direxion S&P 500 Bull 3x',    sector:'ETF',      base:98.4,  signal:'BUY',     rsi:58, vwap:true,  ema:'Bullish'},
