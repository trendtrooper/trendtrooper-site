// Generate live-ish prices and volumes
const DATA = RAW.map(function(r) {
  var chg = rnd(-2.8, 2.8);
  var price = +(r.base * (1 + chg / 100)).toFixed(2);
  var atr = rnd(0.8, 4.5);
  var vol = rndVol();
  return Object.assign({}, r, {price: price, chg: chg, atr: atr, vol: vol});
});

// ── State ──────────────────────────────────────────────────────────────
var signalFilters = new Set(['ALL']); // multi-select for signal
var filters = {sector:'ALL', rsi:'ALL', vwap:'ALL', search:''};
var sortKey = 'sym';
var sortDir = 0; // 0=default asc, 1=desc, 2=asc
var PAGE_SIZE = 25;
var currentPage = 1;
var searchTimer = null;

// ── Helpers ────────────────────────────────────────────────────────────
function getRsiZone(r) { return r < 30 ? 'OS' : r > 70 ? 'OB' : 'MID'; }

function highlightText(text, query) {
  if (!query) return escHtml(text);
  var escaped = escHtml(text);
  var re = new RegExp('(' + escRe(query) + ')', 'gi');
  return escaped.replace(re, '<mark>$1</mark>');
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function escRe(s) {
  return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

// ── Filtering & Sorting ────────────────────────────────────────────────
function applyFilters() {
  var q = filters.search;
  var rows = DATA.filter(function(r) {
    // Signal: if ALL in set or set is empty → pass; else must match one of the selected
    if (!signalFilters.has('ALL') && signalFilters.size > 0 && !signalFilters.has(r.signal)) return false;
    if (filters.sector !== 'ALL' && r.sector !== filters.sector) return false;
    if (filters.rsi !== 'ALL' && getRsiZone(r.rsi) !== filters.rsi) return false;
    if (filters.vwap === 'YES' && !r.vwap) return false;
    if (filters.vwap === 'NO' && r.vwap) return false;
    if (q && !r.sym.toLowerCase().includes(q) && !r.name.toLowerCase().includes(q)) return false;
    return true;
  });

  rows.sort(function(a, b) {
    var dir = (sortDir === 1) ? -1 : 1; // sortDir 1=desc, 2=asc (default=0 is asc by sym)
    if (sortKey === 'sym')    return dir * a.sym.localeCompare(b.sym);
    if (sortKey === 'name')   return dir * a.name.localeCompare(b.name);
    if (sortKey === 'price')  return dir * (b.price - a.price);
    if (sortKey === 'chg')    return dir * (b.chg - a.chg);
    if (sortKey === 'rsi')    return dir * (b.rsi - a.rsi);
    if (sortKey === 'atr')    return dir * (b.atr - a.atr);
    if (sortKey === 'vol')    return dir * (b.vol - a.vol);
    if (sortKey === 'vwap')   return dir * ((b.vwap ? 1 : 0) - (a.vwap ? 1 : 0));
    if (sortKey === 'ema')    return dir * a.ema.localeCompare(b.ema);
    if (sortKey === 'sector') return dir * a.sector.localeCompare(b.sector);
    if (sortKey === 'signal') return dir * a.signal.localeCompare(b.signal);
    return dir * a.sym.localeCompare(b.sym);
  });

  return rows;
}

// ── Render ─────────────────────────────────────────────────────────────
function renderTable() {
  var allRows = applyFilters();
  var total = allRows.length;
  var totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
  if (currentPage > totalPages) currentPage = totalPages;
  if (currentPage < 1) currentPage = 1;

  var start = (currentPage - 1) * PAGE_SIZE;
  var end = Math.min(start + PAGE_SIZE, total);
  var pageRows = allRows.slice(start, end);

  var tb = document.getElementById('tableBody');
  var empty = document.getElementById('emptyState');
  var pgBar = document.getElementById('paginationBar');

  // Update counts
  if (total === 0) {
    document.getElementById('resRange').textContent = '0';
    document.getElementById('resTotal').textContent = '0';
  } else {
    document.getElementById('resRange').textContent = (start + 1) + '–' + end;
    document.getElementById('resTotal').textContent = total;
  }

  // Pagination controls
  var pgFull = document.getElementById('pgInfoFull');
  var pgShort = document.getElementById('pgInfoShort');
  pgFull.textContent = 'Page ' + currentPage + ' of ' + totalPages;
  pgShort.textContent = 'Page ' + currentPage + ' of ' + totalPages;
  document.getElementById('pgPrev').disabled = (currentPage <= 1);
  document.getElementById('pgNext').disabled = (currentPage >= totalPages);
  pgBar.style.display = total === 0 ? 'none' : 'flex';

  if (total === 0) {
    tb.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';

  var q = filters.search;

  function rsiCol(r) {
    var col = r < 30 ? '#ff5c6a' : r > 70 ? '#a78bfa' : '#6ee7ff';
    return '<div class="rsi-bar"><div class="rsi-track"><div class="rsi-fill" style="width:' + r + '%;background:' + col + '"></div></div><span style="font-family:var(--mono);font-size:13px">' + r + '</span></div>';
  }

  tb.innerHTML = pageRows.map(function(r) {
    var symHl = highlightText(r.sym, q);
    var nameHl = highlightText(r.name, q);
    var vwapColor = r.vwap ? 'var(--green)' : 'var(--red)';
    var emaColor = r.ema === 'Bullish' ? 'var(--green)' : r.ema === 'Bearish' ? 'var(--red)' : 'var(--amber)';
    return '<tr>' +
      '<td class="td-sym">' + symHl + '</td>' +
      '<td class="td-name">' + nameHl + '</td>' +
      '<td class="td-price">$' + r.price.toFixed(2) + '</td>' +
      '<td class="td-chg ' + (r.chg >= 0 ? 'up' : 'dn') + '">' + (r.chg >= 0 ? '+' : '') + r.chg.toFixed(2) + '%</td>' +
      '<td><span class="sig ' + r.signal.toLowerCase() + '">' + r.signal + '</span></td>' +
      '<td>' + rsiCol(r.rsi) + '</td>' +
      '<td style="color:' + vwapColor + ';font-family:var(--mono);font-size:13px">' + (r.vwap ? '&#8593; Above' : '&#8595; Below') + '</td>' +
      '<td style="font-family:var(--mono)">$' + r.atr.toFixed(2) + '</td>' +
      '<td class="td-vol">' + fmtVol(r.vol) + '</td>' +
      '<td><span class="td-tag" style="color:' + emaColor + '">' + r.ema + '</span></td>' +
      '<td><span class="td-tag">' + r.sector + '</span></td>' +
    '</tr>';
  }).join('');

  updateSortHeaders();
}

function updateSortHeaders() {
  var cols = ['sym','name','price','chg','signal','rsi','vwap','atr','vol','ema','sector'];
  cols.forEach(function(col) {
    var th = document.querySelector('th[data-col="' + col + '"]');
    var arr = document.getElementById('arr-' + col);
    if (!th || !arr) return;
    th.classList.remove('sort-active');
    arr.textContent = '';
    if (col === sortKey) {
      th.classList.add('sort-active');
      arr.textContent = sortDir === 1 ? ' ▼' : ' ▲';
    }
  });
}

// ── Column sort click ──────────────────────────────────────────────────
document.getElementById('tableHead').addEventListener('click', function(e) {
  var th = e.target.closest('th[data-col]');
  if (!th) return;
  var col = th.dataset.col;
  if (sortKey === col) {
    sortDir = (sortDir + 1) % 3; // 0→1→2→0
    if (sortDir === 0) { sortKey = 'sym'; } // reset to default
  } else {
    sortKey = col;
    sortDir = 1; // first click = descending
  }
  currentPage = 1;
  renderTable();
});

// ── Signal filter chips (multi-select) ────────────────────────────────
document.querySelectorAll('.fchip[data-filter="signal"]').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var v = btn.dataset.val;
    if (v === 'ALL') {
      signalFilters.clear();
      signalFilters.add('ALL');
    } else {
      signalFilters.delete('ALL');
      if (signalFilters.has(v)) {
        signalFilters.delete(v);
        if (signalFilters.size === 0) signalFilters.add('ALL');
      } else {
        signalFilters.add(v);
      }
    }
    // Update chip visual states
    document.querySelectorAll('.fchip[data-filter="signal"]').forEach(function(b) {
      var bv = b.dataset.val;
      b.classList.remove('on', 'green-on', 'red-on');
      if (signalFilters.has(bv)) {
        if (bv === 'BUY') b.classList.add('green-on');
        else if (bv === 'SELL') b.classList.add('red-on');
        else b.classList.add('on');
      }
    });
    currentPage = 1;
    renderTable();
  });
});

// ── Sector / RSI / VWAP chips (exclusive) ─────────────────────────────
document.querySelectorAll('.fchip[data-filter="sector"], .fchip[data-filter="rsi"], .fchip[data-filter="vwap"]').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var f = btn.dataset.filter;
    var v = btn.dataset.val;
    filters[f] = v;
    document.querySelectorAll('.fchip[data-filter="' + f + '"]').forEach(function(b) {
      b.classList.remove('on', 'green-on', 'red-on');
    });
    btn.classList.add('on');
    currentPage = 1;
    renderTable();
  });
});

// ── Debounced search ───────────────────────────────────────────────────
document.getElementById('searchInput').addEventListener('input', function(e) {
  clearTimeout(searchTimer);
  var val = e.target.value;
  searchTimer = setTimeout(function() {
    filters.search = val.toLowerCase().trim();
    currentPage = 1;
    renderTable();
  }, 300);
});

// ── Pagination buttons ─────────────────────────────────────────────────
document.getElementById('pgPrev').addEventListener('click', function() {
  if (currentPage > 1) { currentPage--; renderTable(); }
});
document.getElementById('pgNext').addEventListener('click', function() {
  var allRows = applyFilters();
  var totalPages = Math.max(1, Math.ceil(allRows.length / PAGE_SIZE));
  if (currentPage < totalPages) { currentPage++; renderTable(); }
});

// ── CSV export ─────────────────────────────────────────────────────────
document.getElementById('exportCsvBtn').addEventListener('click', function() {
  var rows = applyFilters();
  var headers = ['Symbol','Name','Price','Chg%','Signal','RSI','VWAP','ATR','Volume','EMA Trend','Sector'];
  var lines = [headers.join(',')];
  rows.forEach(function(r) {
    lines.push([
      r.sym,
      '"' + r.name.replace(/"/g,'""') + '"',
      r.price.toFixed(2),
      r.chg.toFixed(2),
      r.signal,
      r.rsi,
      r.vwap ? 'Above' : 'Below',
      r.atr.toFixed(2),
      r.vol,
      r.ema,
      r.sector
    ].join(','));
  });
  var csv = lines.join('\r\n');
  var blob = new Blob([csv], {type:'text/csv'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = 'trendtrooper-screener.csv';
  document.body.appendChild(a);
  a.click();
  setTimeout(function() { document.body.removeChild(a); URL.revokeObjectURL(url); }, 100);
});

// ── Initial render ─────────────────────────────────────────────────────
renderTable();
</script>
