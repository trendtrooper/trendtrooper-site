  {sym:'UVXY', name:'ProShares Ultra VIX',           sector:'ETF',      base:5.88,  signal:'HOLD',    rsi:55, vwap:true,  ema:'Neutral'},
  {sym:'LABU', name:'Direxion Daily Biotech Bull',   sector:'ETF',      base:102.3, signal:'NEUTRAL', rsi:50, vwap:true,  ema:'Neutral'},
  // US Tech
  {sym:'AAPL', name:'Apple Inc.',                    sector:'Tech',     base:211.5, signal:'BUY',     rsi:64, vwap:true,  ema:'Bullish'},
  {sym:'MSFT', name:'Microsoft Corp.',               sector:'Tech',     base:415.2, signal:'BUY',     rsi:68, vwap:true,  ema:'Bullish'},
  {sym:'NVDA', name:'NVIDIA Corp.',                  sector:'Tech',     base:875.4, signal:'BUY',     rsi:72, vwap:true,  ema:'Bullish'},
  {sym:'GOOGL',name:'Alphabet Inc.',                 sector:'Tech',     base:178.9, signal:'HOLD',    rsi:58, vwap:true,  ema:'Neutral'},
  {sym:'META', name:'Meta Platforms',                sector:'Tech',     base:492.1, signal:'BUY',     rsi:61, vwap:true,  ema:'Bullish'},
  {sym:'TSLA', name:'Tesla Inc.',                    sector:'Tech',     base:182.4, signal:'SELL',    rsi:35, vwap:false, ema:'Bearish'},
  {sym:'AMD',  name:'Advanced Micro Devices',        sector:'Tech',     base:155.8, signal:'HOLD',    rsi:48, vwap:false, ema:'Neutral'},
  {sym:'AMZN', name:'Amazon.com Inc.',               sector:'Tech',     base:188.3, signal:'BUY',     rsi:65, vwap:true,  ema:'Bullish'},
  {sym:'CRM',  name:'Salesforce Inc.',               sector:'Tech',     base:273.6, signal:'HOLD',    rsi:52, vwap:true,  ema:'Neutral'},
  // US Finance
  {sym:'JPM',  name:'JPMorgan Chase',                sector:'Finance',  base:198.5, signal:'BUY',     rsi:60, vwap:true,  ema:'Bullish'},
  {sym:'BAC',  name:'Bank of America',               sector:'Finance',  base:38.9,  signal:'HOLD',    rsi:45, vwap:false, ema:'Neutral'},
