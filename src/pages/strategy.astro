---
import LogoutBar from "../components/LogoutBar.astro";
// TrendTrooper — Strategy Page src/pages/strategy.astro
---
<!doctype html>
<html lang="en">
<head>
<script>if(localStorage.getItem("tt_dev_access")!=="tt-ironclad-2026"&&!localStorage.getItem("tt_sub_token")){sessionStorage.setItem("tt_redirect",location.pathname);location.replace("/subscribe");}</script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>TrendTrooper — Auto-Switch Strategy</title>
  <meta name="description" content="How TrendTrooper's leveraged ETF auto-switch system works. Signal logic, risk rules, execution pipeline." />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root{
      --bg:#070e1c;--card:#0f1b33;--card2:#111e38;
      --muted:#7a96bb;--muted2:#4a6490;
      --text:#ddeeff;--text2:#b8d0ee;
      --accent:#6ee7ff;--accent2:#a78bfa;
      --green:#22d673;--red:#ff5c6a;--amber:#f59e0b;
      --border2:rgba(255,255,255,.06);--r:16px;--max:1100px;
      --mono:'JetBrains Mono',monospace;--sans:'Space Grotesk',sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);color:var(--text);background:var(--bg);min-height:100vh;line-height:1.5}
    a{color:inherit;text-decoration:none}
    header{position:sticky;top:0;z-index:100;height:70px;background:rgba(2,5,20,.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);display:flex;align-items:center;justify-content:space-between;padding:0 32px;}
    .tt-brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:#e8eeff;}
    .tt-logo{width:42px;height:42px;border-radius:10px;background:linear-gradient(135deg,#7040ff,#00cfff);display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-weight:900;font-size:14px;color:#fff;flex-shrink:0;box-shadow:0 0 20px rgba(112,64,255,.4);}
    .tt-name{font-family:'Orbitron',monospace;font-size:16px;font-weight:900;letter-spacing:2px;background:linear-gradient(90deg,#fff,#00cfff,#7040ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
    .tt-tag{font-size:9px;color:#00cfff;font-weight:600;letter-spacing:3px;text-transform:uppercase;display:block;opacity:.8;}
    .tt-nav{display:flex;align-items:center;gap:1px;white-space:nowrap;}
    .tt-nav a{color:#c8d8f0;padding:6px 9px;border-radius:8px;text-decoration:none;font-weight:800;font-size:11.5px;letter-spacing:.8px;text-transform:uppercase;transition:color .15s,background .15s;}
    .tt-nav a:hover{color:#e8eeff;background:rgba(0,200,255,.06);}
    .tt-nav a.cur{color:#00cfff;}
    .tt-cta{background:linear-gradient(135deg,#00cfff,#7040ff)!important;color:#fff!important;font-weight:800!important;padding:8px 14px!important;border-radius:8px!important;box-shadow:0 0 20px rgba(0,200,255,.2)!important;}
    .tt-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
    .tt-burger span{width:22px;height:2px;background:#e8eeff;border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
    .tt-burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .tt-burger.open span:nth-child(2){opacity:0;}
    .tt-burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .tt-mob{display:none;flex-direction:column;position:sticky;top:70px;z-index:99;background:rgba(2,5,20,.97);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);padding:8px 24px 16px;}
    .tt-mob.open{display:flex;}
    .tt-mob a{color:rgba(180,210,255,.65);padding:10px 0;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:1px;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.04);}
    .tt-mob a:hover{color:#e8eeff;}
    @media(max-width:900px){.tt-nav{display:none;}.tt-burger{display:flex;}}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:9px 18px;border-radius:12px;font-weight:600;font-size:13.5px;border:1px solid var(--border2);background:rgba(255,255,255,.05);color:var(--text);cursor:pointer;transition:.15s;font-family:var(--sans)}
    .btn:hover{background:rgba(255,255,255,.08)}
    .btn.primary{background:linear-gradient(135deg,var(--accent),var(--accent2));border:none;color:#070e1c;font-weight:700}
    .wrap{max-width:var(--max);margin:0 auto;padding:48px 24px}
    .strat-hero{text-align:center;padding-bottom:48px;border-bottom:1px solid var(--border2);margin-bottom:48px}
    .badge{display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:999px;border:1px solid rgba(110,231,255,.25);background:rgba(110,231,255,.07);color:var(--accent);font-size:12.5px;font-weight:600;margin-bottom:20px}
    .strat-hero h1{font-size:clamp(32px,4vw,52px);font-weight:700;letter-spacing:-.6px;margin-bottom:16px;line-height:1.1}
    .grad{background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .strat-hero p{color:var(--muted);font-size:16px;max-width:55ch;margin:0 auto 28px;line-height:1.65}
    .hero-stats{display:flex;gap:32px;justify-content:center;flex-wrap:wrap}
    .hs{text-align:center}
    .hs .v{font-size:28px;font-weight:700;font-family:var(--mono);color:var(--accent)}
    .hs .l{font-size:12px;color:var(--muted);margin-top:3px}
    .pipeline{display:flex;align-items:stretch;gap:0;margin-bottom:48px;overflow-x:auto}
    .pipe-step{flex:1;min-width:140px;background:var(--card);border:1px solid var(--border2);padding:20px 16px;position:relative;text-align:center}
    .pipe-step:first-child{border-radius:var(--r) 0 0 var(--r)}
    .pipe-step:last-child{border-radius:0 var(--r) var(--r) 0}
    .pipe-step:not(:last-child)::after{content:"→";position:absolute;right:-14px;top:50%;transform:translateY(-50%);color:var(--accent);font-size:18px;font-weight:700;z-index:1;background:var(--bg);padding:0 4px}
    .pipe-num{font-size:10px;font-weight:700;color:var(--accent);font-family:var(--mono);letter-spacing:.5px;margin-bottom:10px}
    .pipe-icon{font-size:24px;margin-bottom:10px}
    .pipe-step h3{font-size:13px;font-weight:700;margin-bottom:6px}
    .pipe-step p{font-size:11.5px;color:var(--muted);line-height:1.5}
    .section{margin-bottom:48px}
    .sec-label{font-size:11px;font-weight:700;color:var(--accent);letter-spacing:1px;font-family:var(--mono);margin-bottom:8px}
    .section h2{font-size:22px;font-weight:700;margin-bottom:6px}
    .section .sub{color:var(--muted);font-size:14px;margin-bottom:24px}
    .two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px}
    .three-col{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    .card{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);padding:20px}
    .card h4{font-size:14px;font-weight:700;margin-bottom:8px}
    .card p{color:var(--muted);font-size:13px;line-height:1.55}
    .code-block{border-radius:var(--r);border:1px solid var(--border2);background:#040b18;overflow:hidden;margin-bottom:24px}
    .code-head{padding:12px 16px;border-bottom:1px solid var(--border2);display:flex;align-items:center;justify-content:space-between}
    .code-head span{font-size:12px;color:var(--muted);font-family:var(--mono)}
    .code-head .lang{font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px;background:rgba(110,231,255,.10);color:var(--accent);border:1px solid rgba(110,231,255,.2)}
    .code-body{padding:16px;font-family:var(--mono);font-size:12.5px;line-height:1.7;overflow-x:auto;color:rgba(220,240,255,.85)}
    .kw{color:#a78bfa}.str{color:#22d673}.num{color:#6ee7ff}.cmt{color:#4a6490}.fn{color:#f59e0b}
    .rules{display:grid;gap:10px}
    .rule{display:flex;gap:14px;align-items:flex-start;padding:14px 16px;border-radius:12px;border:1px solid var(--border2);background:rgba(255,255,255,.025)}
    .rule-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;flex:0 0 auto}
    .rule-icon.g{background:rgba(34,214,115,.12);border:1px solid rgba(34,214,115,.25)}
    .rule-icon.r{background:rgba(255,92,106,.12);border:1px solid rgba(255,92,106,.25)}
    .rule-icon.b{background:rgba(110,231,255,.10);border:1px solid rgba(110,231,255,.2)}
    .rule b{display:block;font-size:13.5px;margin-bottom:3px}
    .rule small{color:var(--muted);font-size:12.5px;line-height:1.5}
    .switch-table{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);overflow:hidden}
    table{width:100%;border-collapse:collapse}
    th{padding:12px 16px;font-size:10px;font-weight:700;color:var(--muted2);letter-spacing:.8px;text-align:left;border-bottom:1px solid var(--border2);background:rgba(255,255,255,.02)}
    td{padding:11px 16px;font-size:13px;border-bottom:1px solid rgba(255,255,255,.03)}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:rgba(255,255,255,.02)}
    .tag{font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px;font-family:var(--mono)}
    .tag.buy{background:rgba(34,214,115,.12);border:1px solid rgba(34,214,115,.3);color:var(--green)}
    .tag.sell{background:rgba(255,92,106,.12);border:1px solid rgba(255,92,106,.3);color:var(--red)}
    .tag.hold{background:rgba(245,158,11,.10);border:1px solid rgba(245,158,11,.25);color:var(--amber)}
    .chart-wrap{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);overflow:hidden}
    .chart-head{padding:14px 18px;border-bottom:1px solid var(--border2);display:flex;justify-content:space-between;align-items:center}
    .chart-head h3{font-size:14px;font-weight:700}
    .chart-body{padding:20px}
    .chart-container{position:relative;width:100%;height:260px}
    .disclaimer{padding:16px 20px;border-radius:12px;border:1px solid rgba(245,158,11,.2);background:rgba(245,158,11,.06);color:rgba(245,158,11,.85);font-size:12.5px;line-height:1.6;margin-top:24px}
    footer{max-width:var(--max);margin:40px auto 0;padding:24px;border-top:1px solid var(--border2);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;color:var(--muted2);font-size:13px}
    .foot-links{display:flex;gap:18px}.foot-links a:hover{color:var(--muted)}
    @media(max-width:900px){
      .two-col,.three-col{grid-template-columns:1fr}
      .navlinks{display:none}
      .hamburger{display:flex;}
      .pipeline{flex-direction:column}
      .pipe-step:first-child{border-radius:var(--r) var(--r) 0 0}
      .pipe-step:last-child{border-radius:0 0 var(--r) var(--r)}
    }
    .hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
    .hamburger span{width:20px;height:2px;background:var(--text);border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
    .hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .hamburger.open span:nth-child(2){opacity:0;}
    .hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .inner-mobile-menu{display:none;flex-direction:column;position:sticky;top:61px;z-index:99;background:rgba(7,14,28,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border2);padding:8px 24px 16px;}
    .inner-mobile-menu.open{display:flex;}
    .inner-mobile-menu a{color:var(--muted);text-decoration:none;font-weight:600;font-size:14px;padding:11px 0;border-bottom:1px solid var(--border2);transition:color .15s;}
    .inner-mobile-menu a:last-child{border-bottom:none;}
    .inner-mobile-menu a:hover{color:var(--text);}
  </style>
</head>
<body>
<header>
  <a class="tt-brand" href="/">
    <div class="tt-logo">TT</div>
    <div><div class="tt-name">TRENDTROOPER</div><span class="tt-tag">Signal Service</span></div>
  </a>
  <nav class="tt-nav">
    <a href="/#features">Features</a>
    <a href="/chart">Live Chart</a>
    <a href="/#markets">Markets</a>
    <a href="/#pricing">Pricing</a>
    <a href="/chart">Full Chart</a>
    <a href="/analysis">Analysis</a>
    <a href="/academy">Academy</a>
    <a href="/tools">Tools</a>
    <a href="https://bot.trendtrooper.com/" target="_blank">Bot Status</a>
    <a href="/#pricing" class="tt-cta">Get Started</a>
  </nav>
  <button class="tt-burger" id="ttBurger" onclick="this.classList.toggle('open');document.getElementById('ttMob').classList.toggle('open')" aria-label="Menu"><span></span><span></span><span></span></button>
</header>
<div class="tt-mob" id="ttMob">
  <a href="/#features">Features</a>
  <a href="/chart">Live Chart</a>
  <a href="/#markets">Markets</a>
  <a href="/#pricing">Pricing</a>
  <a href="/chart">Full Chart</a>
  <a href="/analysis">Analysis</a>
  <a href="/academy">Academy</a>
  <a href="/tools">Tools</a>
  <a href="https://bot.trendtrooper.com/" target="_blank">Bot Status</a>
  <a href="/#pricing">Get Started</a>
</div>

<div class="wrap">
  <div class="strat-hero">
    <div class="badge">&#9881;&#65039; Auto-Switch System &middot; Leveraged ETF Focus</div>
    <h1>The <span class="grad">TrendTrooper</span><br>Auto-Switch Strategy</h1>
    <p>A systematic pipeline that reads TradingView signals, validates risk rules, and automatically rotates between leveraged ETFs based on momentum and trend conditions.</p>
    <div class="hero-stats">
      <div class="hs"><div class="v">3x</div><div class="l">Leveraged ETF focus</div></div>
      <div class="hs"><div class="v">5m</div><div class="l">Primary timeframe</div></div>
      <div class="hs"><div class="v">ATR</div><div class="l">Dynamic stop sizing</div></div>
      <div class="hs"><div class="v">1%</div><div class="l">Max risk per trade</div></div>
    </div>
  </div>

  <div class="section">
    <div class="sec-label">THE PIPELINE</div>
    <h2>Signal to Execution — End to End</h2>
    <p class="sub">Every trade follows the same path. No manual intervention required.</p>
    <div class="pipeline">
      <div class="pipe-step">
        <div class="pipe-num">STEP 01</div>
        <div class="pipe-icon">&#128225;</div>
        <h3>TradingView Alert</h3>
        <p>Pine Script strategy fires. Payload includes symbol, action, price, ATR, signal_id.</p>
      </div>
      <div class="pipe-step">
        <div class="pipe-num">STEP 02</div>
        <div class="pipe-icon">&#128274;</div>
        <h3>Cloudflare Gate</h3>
        <p>DNS + SSL + WAF. Webhook authenticated with shared secret. Replay protection via signal_id.</p>
      </div>
      <div class="pipe-step">
        <div class="pipe-num">STEP 03</div>
        <div class="pipe-icon">&#9989;</div>
        <h3>Risk Validator</h3>
        <p>Checks position size, daily loss limit, ATR stop distance. Rejects invalid signals with reason log.</p>
      </div>
      <div class="pipe-step">
        <div class="pipe-num">STEP 04</div>
        <div class="pipe-icon">&#128257;</div>
        <h3>Auto-Switch Logic</h3>
        <p>Determines bull vs bear ETF. Closes existing position, opens new bracket order.</p>
      </div>
      <div class="pipe-step">
        <div class="pipe-num">STEP 05</div>
        <div class="pipe-icon">&#127982;</div>
        <h3>Broker Execution</h3>
        <p>IBKR API. Entry + stop-loss + take-profit as bracket. Paper mode default.</p>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="sec-label">SIGNAL LOGIC</div>
    <h2>Auto-Switch Conditions</h2>
    <p class="sub">The system rotates between SPXL and SPXS (or TQQQ/SQQQ) based on these conditions:</p>
    <div class="switch-table">
      <table>
        <thead><tr><th>CONDITION</th><th>INDICATORS</th><th>ACTION</th><th>ETF TARGET</th></tr></thead>
        <tbody>
          <tr><td>Strong bullish trend</td><td style="font-family:var(--mono);font-size:12px">EMA9 &gt; EMA20 &middot; Price &gt; VWAP &middot; RSI 50-70</td><td><span class="tag buy">BUY BULL</span></td><td style="color:var(--green);font-family:var(--mono)">SPXL / TQQQ</td></tr>
          <tr><td>Momentum confirmed</td><td style="font-family:var(--mono);font-size:12px">MACD histogram positive &middot; ATR expanding</td><td><span class="tag buy">HOLD BULL</span></td><td style="color:var(--green);font-family:var(--mono)">SPXL / TQQQ</td></tr>
          <tr><td>Trend weakening</td><td style="font-family:var(--mono);font-size:12px">EMA crossunder &middot; RSI near 50 &middot; MACD flat</td><td><span class="tag hold">CLOSE</span></td><td style="color:var(--amber);font-family:var(--mono)">CASH</td></tr>
          <tr><td>Bearish momentum</td><td style="font-family:var(--mono);font-size:12px">EMA9 &lt; EMA20 &middot; Price &lt; VWAP &middot; RSI 30-50</td><td><span class="tag sell">BUY BEAR</span></td><td style="color:var(--red);font-family:var(--mono)">SPXS / SQQQ</td></tr>
          <tr><td>Oversold extreme</td><td style="font-family:var(--mono);font-size:12px">RSI &lt; 30 &middot; VIX spike &middot; ATR elevated</td><td><span class="tag hold">WAIT</span></td><td style="color:var(--amber);font-family:var(--mono)">NO TRADE</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="section">
    <div class="sec-label">PINE SCRIPT</div>
    <h2>Core Signal Logic</h2>
    <p class="sub">The TradingView strategy that generates the webhook payload. Runs on 5-minute bars.</p>
    <div class="code-block">
      <div class="code-head"><span>strategy_core.pine</span><span class="lang">Pine Script v5</span></div>
      <div class="code-body" id="pineCode"></div>
    </div>
  </div>

  <div class="section">
    <div class="sec-label">RISK RULES</div>
    <h2>Guardrails &amp; Safety Controls</h2>
    <p class="sub">These rules run before every order. A single failed check cancels the trade and logs the reason.</p>
    <div class="two-col">
      <div class="rules">
        <div class="rule"><div class="rule-icon g">&#10003;</div><div><b>Max 1% risk per trade</b><small>Dollar risk = account x 1%. Position size = dollar risk / ATR stop distance.</small></div></div>
        <div class="rule"><div class="rule-icon g">&#10003;</div><div><b>Max 3% daily loss limit</b><small>If total daily P&amp;L reaches -3%, all trading halts until next session open.</small></div></div>
        <div class="rule"><div class="rule-icon g">&#10003;</div><div><b>Signal authentication</b><small>Every webhook validated against shared secret. Unsigned requests rejected instantly.</small></div></div>
        <div class="rule"><div class="rule-icon b">&#10003;</div><div><b>Replay protection</b><small>Each signal carries a unique signal_id. Duplicates within 60s window are dropped.</small></div></div>
      </div>
      <div class="rules">
        <div class="rule"><div class="rule-icon r">&#10007;</div><div><b>No trades outside market hours</b><small>9:30 AM - 4:00 PM ET only. Pre/post market signals queued or discarded.</small></div></div>
        <div class="rule"><div class="rule-icon r">&#10007;</div><div><b>No trade if ATR too low</b><small>If ATR is below minimum threshold, stop distance is too small — order rejected.</small></div></div>
        <div class="rule"><div class="rule-icon r">&#10007;</div><div><b>No pyramiding</b><small>System is always flat or in one position. No adding to winners or losers.</small></div></div>
        <div class="rule"><div class="rule-icon b">&#10003;</div><div><b>Paper mode default</b><small>All new deployments start in paper trading. Live mode requires explicit opt-in.</small></div></div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="sec-label">PERFORMANCE</div>
    <h2>Simulated Equity Curve</h2>
    <p class="sub">Illustrative only — based on strategy logic applied to generated data. Not a guarantee of future results.</p>
    <div class="chart-wrap">
      <div class="chart-head">
        <h3>Portfolio Equity — Simulated 6 Month Run</h3>
        <div style="display:flex;gap:14px;font-size:12px;font-family:var(--mono)">
          <span style="color:var(--green)">&#9679; Strategy</span>
          <span style="color:var(--muted)">&#9679; Buy &amp; Hold SPX</span>
        </div>
      </div>
      <div class="chart-body">
        <div class="chart-container"><canvas id="equityChart" role="img" aria-label="Simulated equity curve comparison">Chart loading...</canvas></div>
      </div>
    </div>
    <div class="disclaimer">
      &#9888;&#65039; <strong>Disclaimer:</strong> TrendTrooper is software tooling, not investment advice. All performance data shown is simulated and for illustrative purposes only. Trading leveraged ETFs involves substantial risk. Past simulated performance does not predict future results. Always test in paper mode first. You are solely responsible for your trading decisions.
    </div>
  </div>

  <div class="section">
    <div class="sec-label">INTEGRATION</div>
    <h2>Webhook Payload Format</h2>
    <p class="sub">Paste this into your TradingView alert message. TrendTrooper parses and validates each field.</p>
    <div class="code-block">
      <div class="code-head"><span>Alert message (JSON)</span><span class="lang">JSON</span></div>
      <div class="code-body" id="webhookCode"></div>
    </div>
    <div class="three-col" style="margin-top:16px">
      <div class="card"><h4>Webhook URL</h4><p>Point your TradingView alert to your Cloudflare domain. Set method to POST, content-type to application/json.</p></div>
      <div class="card"><h4>Secret Key</h4><p>Generate a strong random secret. Set it in both your TradingView alert and your TrendTrooper environment config.</p></div>
