// Equity chart
var n = 120;
var labels = Array.from({length: n}, function(_, i) {
  var d = new Date(2024, 10, 1);
  d.setDate(d.getDate() + i);
  return d.toLocaleDateString('en-US', {month: 'short', day: 'numeric'});
});

function genEquity(start, vol, drift) {
  var d = [start];
  for (var i = 1; i < n; i++) {
    var chg = (Math.random() - 0.48) * vol + drift;
    d.push(parseFloat((d[i-1] * (1 + chg/100)).toFixed(2)));
  }
  return d;
}

var stratData = genEquity(100000, 2.2, 0.18);
var buyholdData = genEquity(100000, 1.4, 0.08);

new Chart(document.getElementById('equityChart'), {
  type: 'line',
  data: {
    labels: labels,
    datasets: [
      {label:'Strategy', data:stratData, borderColor:'#22d673', borderWidth:2, pointRadius:0, tension:0.4, fill:true, backgroundColor:'rgba(34,214,115,.06)'},
      {label:'Buy & Hold SPX', data:buyholdData, borderColor:'rgba(122,150,187,.5)', borderWidth:1.5, borderDash:[4,3], pointRadius:0, tension:0.4, fill:false}
    ]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    animation: {duration: 1200},
    plugins: {
      legend: {display: false},
      tooltip: {
        mode: 'index', intersect: false,
        backgroundColor: '#0f1b33', titleColor: '#7a96bb', bodyColor: '#ddeeff',
        borderColor: 'rgba(110,231,255,.2)', borderWidth: 1,
        callbacks: {
          label: function(ctx) {
            return ctx.dataset.label + ': $' + ctx.parsed.y.toLocaleString();
          }
        }
      }
    },
    scales: {
      x: {ticks: {color:'rgba(122,150,187,.7)', font:{size:10}, maxTicksLimit:8}, grid: {color:'rgba(255,255,255,.04)'}},
      y: {ticks: {color:'rgba(122,150,187,.7)', font:{size:10}, callback: function(v) { return '$' + v.toLocaleString(); }}, grid: {color:'rgba(255,255,255,.04)'}}
    }
  }
});
</script>
