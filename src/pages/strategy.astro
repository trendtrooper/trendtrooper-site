  document.getElementById('hamburgerBtn').classList.toggle('open');
}

// Inject Pine Script code block safely via JS to avoid Astro parsing issues
document.getElementById('pineCode').innerHTML = [
  '<span class="cmt">//@version=5</span>',
  '<span class="fn">strategy</span>(<span class="str">"TrendTrooper Auto-Switch"</span>, overlay=<span class="kw">true</span>, default_qty_type=strategy.percent_of_equity)',
  '',
  '<span class="cmt">// — Inputs —</span>',
  'emaFast = <span class="fn">input.int</span>(<span class="num">9</span>,  <span class="str">"EMA Fast"</span>)',
  'emaSlow = <span class="fn">input.int</span>(<span class="num">20</span>, <span class="str">"EMA Slow"</span>)',
  'rsiLen  = <span class="fn">input.int</span>(<span class="num">14</span>, <span class="str">"RSI Period"</span>)',
  'atrLen  = <span class="fn">input.int</span>(<span class="num">14</span>, <span class="str">"ATR Period"</span>)',
  'atrMult = <span class="fn">input.float</span>(<span class="num">2.0</span>, <span class="str">"ATR Stop Multiplier"</span>)',
  '',
  '<span class="cmt">// — Indicators —</span>',
  'ema9  = <span class="fn">ta.ema</span>(close, emaFast)',
  'ema20 = <span class="fn">ta.ema</span>(close, emaSlow)',
  'rsi   = <span class="fn">ta.rsi</span>(close, rsiLen)',
  'atr   = <span class="fn">ta.atr</span>(atrLen)',
  'vwap  = <span class="fn">ta.vwap</span>(hlc3)',
  '',
  '<span class="cmt">// — Conditions —</span>',
  'bullish = ema9 &gt; ema20 <span class="kw">and</span> close &gt; vwap <span class="kw">and</span> rsi &gt; <span class="num">50</span> <span class="kw">and</span> rsi &lt; <span class="num">70</span>',
  'bearish = ema9 &lt; ema20 <span class="kw">and</span> close &lt; vwap <span class="kw">and</span> rsi &lt; <span class="num">50</span> <span class="kw">and</span> rsi &gt; <span class="num">30</span>',
  '',
  '<span class="cmt">// — Entries —</span>',
  '<span class="kw">if</span> <span class="fn">ta.crossover</span>(ema9, ema20) <span class="kw">and</span> bullish',
  '    stopLoss   = close - atr * atrMult',
  '    takeProfit = close + atr * atrMult * <span class="num">2.5</span>',
  '    strategy.<span class="fn">entry</span>(<span class="str">"Long SPXL"</span>, strategy.long)',
  '    strategy.<span class="fn">exit</span>(<span class="str">"Long Exit"</span>, stop=stopLoss, limit=takeProfit)',
  '',
  '<span class="kw">if</span> <span class="fn">ta.crossunder</span>(ema9, ema20) <span class="kw">and</span> bearish',
  '    stopLoss   = close + atr * atrMult',
  '    takeProfit = close - atr * atrMult * <span class="num">2.5</span>',
  '    strategy.<span class="fn">entry</span>(<span class="str">"Long SPXS"</span>, strategy.short)',
  '    strategy.<span class="fn">exit</span>(<span class="str">"Bear Exit"</span>, stop=stopLoss, limit=takeProfit)'
