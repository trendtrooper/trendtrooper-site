  renderDonut('gMABear', 'gMABull', 'gMAScore', 'gMALabel',  ma.bull||0,  ma.bear||0,  maTotal);
  renderBreakdownBar('expIndBreak', ind.bull||0, ind.neutral||0, ind.bear||0, indTotal);
  renderBreakdownBar('expMABreak',  ma.bull||0,  0,              ma.bear||0,  maTotal);
  var ib = document.getElementById('expIndBull'); if(ib) ib.textContent = (ind.bull||0) + ' bull';
  var ir = document.getElementById('expIndBear'); if(ir) ir.textContent = (ind.bear||0) + ' bear';
  var mb = document.getElementById('expMABull');  if(mb) mb.textContent = (ma.bull||0)  + ' bull';
  var mr = document.getElementById('expMABear');  if(mr) mr.textContent = (ma.bear||0)  + ' bear';
  var price = data.price;
  var mas = data.moving_averages || {};
  var stColor = data.direction === 'bullish' ? 'var(--green)' : data.direction === 'bearish' ? 'var(--red)' : 'var(--amber)';
  var stEl = document.getElementById('expTrendShort');
  if(stEl){ stEl.textContent = data.direction.toUpperCase(); stEl.style.color = stColor; }
  var ltEl = document.getElementById('expTrendLong');
  if(ltEl){
    var lt = mas.ma200 ? (price > mas.ma200 ? 'BULLISH' : 'BEARISH') : '—';
    ltEl.textContent = lt;
    ltEl.style.color = mas.ma200 ? (price > mas.ma200 ? 'var(--green)' : 'var(--red)') : 'var(--muted)';
  }
}

function renderDayRange(data) {
  var lo = data.day_low, hi = data.day_high, pr = data.price;
  if (!lo || !hi) return;
  var pct = ((pr - lo) / (hi - lo) * 100).toFixed(1);
  document.getElementById('drLow').textContent  = '$' + lo;
  document.getElementById('drHigh').textContent = '$' + hi;
  document.getElementById('drCur').textContent  = '$' + pr;
  document.getElementById('drFill').style.width = pct + '%';
  document.getElementById('drDot').style.left   = pct + '%';
  var fromLow = ((pr - lo) / lo * 100).toFixed(2);
  document.getElementById('drPct').textContent  = '+' + fromLow + '% from low';
