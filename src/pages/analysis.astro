}

// CHANGE 3: Indicator tooltip data
var IND_TOOLTIPS = {
  'RSI (14)':  'Relative Strength Index. &gt;70 = Overbought (bearish), &lt;30 = Oversold (bullish), 30–70 = Neutral',
  'MACD':      'Moving Average Convergence Divergence. Positive histogram = bullish momentum',
  'ATR (14)':  'Average True Range. Higher = more volatile. Use for stop-loss sizing',
  'Stoch %K':  '&gt;80 = Overbought, &lt;20 = Oversold',
  'ADX (14)':  '&lt;20 = Weak trend, 20–40 = Moderate trend, &gt;40 = Strong trend',
};

function makeTooltipIcon(label) {
  var tip = IND_TOOLTIPS[label] || '';
  if (!tip) return '';
  return '<span class="tooltip-wrap"><span class="info-icon" onclick="this.parentNode.classList.toggle(\'active\')">i</span><span class="tooltip-box">'+tip+'</span></span>';
}

function renderIndicators(data) {
  const ind = data.indicators;
  const rows = [
    { label: 'RSI (14)',  val: ind.rsi,    min:0, max:100, warn:[30,70] },
    { label: 'Stoch %K', val: ind.stoch_k, min:0, max:100, warn:[20,80] },
    { label: 'ADX (14)', val: ind.adx,     min:0, max:100, warn:[20,40] },
    { label: 'ATR (14)', val: ind.atr,     min:null },
  ];
  // Also add MACD if present
  if (ind.macd !== undefined && ind.macd !== null) {
    rows.push({ label: 'MACD', val: ind.macd, min:null });
  }
  document.getElementById('indicators').innerHTML = rows.map(function(r) {
    if (!r.val && r.val !== 0) return '';
    let barHtml = '';
    let valColor = 'var(--text)';
    if (r.min !== null) {
      const pct = Math.min(100, (r.val / r.max) * 100);
      let barColor = 'var(--muted)';
      if (r.warn) {
        if (r.val < r.warn[0]) barColor = 'var(--green)';
        else if (r.val > r.warn[1]) barColor = 'var(--red)';
        if (r.label.includes('RSI') || r.label.includes('Stoch')) {
          if (r.val > r.warn[1]) valColor = 'var(--red)';
          else if (r.val < r.warn[0]) valColor = 'var(--green)';
        }
      }
      barHtml = '<div class="ind-bar-wrap"><div class="ind-bar" style="width:'+pct+'%;background:'+barColor+'"></div></div>';
    }
    return '<div class="ind-row"><span class="ind-label">'+r.label+' '+makeTooltipIcon(r.label)+'</span>'+barHtml+'<span class="ind-val" style="color:'+valColor+'">'+r.val.toFixed(2)+'</span></div>';
  }).join('');
}

function calcATR(candles, period) {
  if (!candles || candles.length < 2) return {};
  var trs = candles.map(function(c, i) {
    if (i === 0) return c.high - c.low;
    var p = candles[i - 1];
    return Math.max(c.high - c.low, Math.abs(c.high - p.close), Math.abs(c.low - p.close));
  });
  var atrMap = {};
  var atr = trs.slice(0, period).reduce(function(s, v) { return s + v; }, 0) / Math.min(period, trs.length);
  for (var i = period; i < candles.length; i++) {
    atr = (atr * (period - 1) + trs[i]) / period;
    atrMap[candles[i].time] = atr;
  }
  return atrMap;
}

function renderPatterns(data) {
  const list = data.patterns || [];
  const el = document.getElementById('patternsList');
  const summaryEl = document.getElementById('patSummary');
  if (list.length > 0) {
    summaryEl.textContent = list.length + ' pattern' + (list.length !== 1 ? 's' : '') + ' detected in last 20 candles';
    summaryEl.style.display = 'block';
  } else {
    summaryEl.style.display = 'none';
  }

  // Clean up old marker series
  if (bullMarkerSeries) { try { chart.removeSeries(bullMarkerSeries); } catch(e){} bullMarkerSeries = null; }
  if (bearMarkerSeries) { try { chart.removeSeries(bearMarkerSeries); } catch(e){} bearMarkerSeries = null; }

  var bar = document.getElementById('patternBar');
  if (!list.length) {
    el.innerHTML = '<div class="no-patterns">No patterns detected in recent candles.</div>';
    if (bar) { bar.style.display = 'none'; bar.innerHTML = ''; }
    return;
  }

  el.innerHTML = list.map(function(p) {
    const cls = p.signal === 'bullish' ? 'pat-bull' : p.signal === 'bearish' ? 'pat-bear' : 'pat-neutral';
    return '<div class="pat-item"><span class="pat-name">'+p.name+'</span><span class="pat-badge '+cls+'">'+p.signal+'</span></div>';
  }).join('');

  // Color pattern candles white
  var patternTimes = {};
  list.forEach(function(p) { patternTimes[p.time] = p.signal; });
  var coloredCandles = chartCandles.map(function(c) {
    if (patternTimes[c.time]) {
      return Object.assign({}, c, { color: '#ffffff', borderColor: '#ffffff', wickColor: '#ffffff' });
    }
    return c;
  });
  candleSeries.setData(coloredCandles);

  // ATR-based marker positions (3 ATR offset from bar)
  var atrMap = calcATR(chartCandles, 14);
  var candleByTime = {};
  chartCandles.forEach(function(c) { candleByTime[c.time] = c; });

  var bullData = [], bearData = [], bullMarkers = [], bearMarkers = [];
  list.forEach(function(p) {
    var c = candleByTime[p.time];
    if (!c) return;
    var atr = atrMap[p.time] || (c.high - c.low);
    var col = p.signal === 'bullish' ? '#22d673' : p.signal === 'bearish' ? '#ff5c6a' : '#a78bfa';
    var isBear = p.signal === 'bearish';
    if (isBear) {
      bearData.push({ time: p.time, value: c.high + 3 * atr });
      bearMarkers.push({ time: p.time, position: 'inBar', color: col, shape: 'arrowDown', size: 0.6 });
    } else {
      bullData.push({ time: p.time, value: c.low - 3 * atr });
      bullMarkers.push({ time: p.time, position: 'inBar', color: col, shape: 'arrowUp', size: 0.6 });
    }
  });

  var hiddenOpts = { color: 'transparent', lineWidth: 0, lastValueVisible: false, priceLineVisible: false, crosshairMarkerVisible: false };
  if (bullData.length) {
    bullMarkerSeries = chart.addLineSeries(hiddenOpts);
    bullMarkerSeries.setData(bullData.sort(function(a,b){return a.time-b.time;}));
    bullMarkerSeries.setMarkers(bullMarkers.sort(function(a,b){return a.time-b.time;}));
  }
  if (bearData.length) {
    bearMarkerSeries = chart.addLineSeries(hiddenOpts);
    bearMarkerSeries.setData(bearData.sort(function(a,b){return a.time-b.time;}));
    bearMarkerSeries.setMarkers(bearMarkers.sort(function(a,b){return a.time-b.time;}));
  }

  // Pattern bar below chart
  if (bar) {
    bar.style.display = 'flex';
    bar.innerHTML = list.map(function(p) {
      var arrow = p.signal === 'bearish' ? '▼' : '▲';
      var col = p.signal === 'bullish' ? '#22d673' : p.signal === 'bearish' ? '#ff5c6a' : '#a78bfa';
      return '<span style="display:inline-flex;align-items:center;gap:4px;background:rgba(255,255,255,0.04);border:1px solid '+col+'44;border-radius:5px;padding:2px 8px;font-size:11px;color:'+col+';letter-spacing:.5px;white-space:nowrap;"><span>'+arrow+'</span><span>'+p.name+'</span></span>';
    }).join('');
  }

  // Hover tooltip on crosshair
  var tip = document.getElementById('markerTip');
  var markerMap = {};
  list.forEach(function(p) { markerMap[p.time] = markerMap[p.time] ? markerMap[p.time]+' · '+p.name : p.name; });
  chart.subscribeCrosshairMove(function(param) {
    if (!param || !param.time || !markerMap[param.time]) { tip.style.display = 'none'; return; }
    tip.textContent = markerMap[param.time];
    tip.style.display = 'block';
    var cdiv = document.getElementById('chartDiv');
    tip.style.left = (param.point && param.point.x != null ? Math.min(param.point.x + 12, cdiv.clientWidth - tip.offsetWidth - 8) : 12) + 'px';
    tip.style.top  = (param.point && param.point.y != null ? Math.max(param.point.y - 28, 4) : 4) + 'px';
  });
}

// CHANGE 7: Risk calculator logic
function calcRisk() {
  var entry   = parseFloat(document.getElementById('rcEntry').value);
  var stop    = parseFloat(document.getElementById('rcStop').value);
  var account = parseFloat(document.getElementById('rcAccount').value) || 10000;
  var riskPct = parseFloat(document.getElementById('rcRisk').value) || 2;

  if (!entry || !stop || entry <= 0 || stop <= 0 || entry === stop) {
    document.getElementById('rcPosSize').textContent = '—';
    document.getElementById('rcMaxLoss').textContent = '—';
    document.getElementById('rcRR').textContent = '—';
    return;
  }

  var riskPerShare = Math.abs(entry - stop);
  var maxLossDollar = account * (riskPct / 100);
  var shares = maxLossDollar / riskPerShare;
  var posSize = shares * entry;

  // R:R: assume target = entry + (entry - stop) * 2 for a 1:2 default display
  var reward = Math.abs(entry - stop) * 2;
  var rrRatio = (reward / riskPerShare).toFixed(1);

  document.getElementById('rcPosSize').textContent = '$' + posSize.toFixed(0) + ' (' + Math.floor(shares) + ' shares)';
  document.getElementById('rcMaxLoss').textContent = '$' + maxLossDollar.toFixed(0);
  document.getElementById('rcRR').textContent = '1:' + rrRatio;
}

// Mark stop loss as user-edited so auto-fill from API doesn't overwrite it
document.getElementById('rcStop').addEventListener('input', function() {
  this.dataset.userEdited = '1';
  calcRisk();
});
['rcEntry','rcAccount','rcRisk'].forEach(function(id) {
  document.getElementById(id).addEventListener('input', calcRisk);
});

// CHANGE 2 & 9: showError helper with retry button
function showError(ticker, message) {
  document.getElementById('chartDiv').innerHTML =
    '<div class="error-card">' +
    '<div style="font-size:32px">⚠</div>' +
    '<h3>Analysis server offline</h3>' +
    '<p>' + (message || 'Check bot.trendtrooper.com or retry.') + '</p>' +
    '<button class="btn-retry" onclick="runAnalysis(\'' + ticker.replace(/'/g, "\\'") + '\')">↺ Retry</button>' +
    '</div>';
}

async function runAnalysis(ticker) {
  ticker = ticker.trim().toUpperCase();
  if (!ticker) return;
  currentTicker = ticker;

  // CHANGE 14: update full-chart link dynamically
  var fcLink = document.getElementById('fullChartLink');
  if (fcLink) fcLink.href = '/chart?symbol=' + encodeURIComponent(ticker);

  // Update URL
  const url = new URL(window.location.href);
  url.searchParams.set('t', ticker);
  window.history.replaceState({}, '', url.toString());

  // Update quick picks
  document.querySelectorAll('.qp:not(.tf)').forEach(function(b) {
    b.classList.toggle('active', b.dataset.t === ticker || b.dataset.t === ticker + '.TO');
  });

  // Show loading state
  document.getElementById('chartDiv').innerHTML = '<div class="chart-loading"><div class="spinner"></div> Loading ' + ticker + '…</div>';
  document.getElementById('hTicker').textContent = ticker;
  document.getElementById('hPrice').textContent = '—';

  // CHANGE 2 & 9: fetch with timeout (10s / 12s)
  var aborted = false;
  var controller = (typeof AbortController !== 'undefined') ? new AbortController() : null;
  var timeoutId = setTimeout(function() {
    aborted = true;
    if (controller) controller.abort();
    showError(ticker, 'Request timed out after 12 seconds. Check bot.trendtrooper.com or retry.');
  }, 12000);

  try {
    var fetchOpts = controller ? { signal: controller.signal } : {};
    const res = await fetch(BOT + '/analyze/' + encodeURIComponent(ticker) + '?interval=' + currentTF, fetchOpts);
    clearTimeout(timeoutId);

    if (!res.ok) {
      showError(ticker, 'Server returned ' + res.status + '. The bot may be offline.');
      return;
    }

    const data = await res.json();

    if (data.error) {
      document.getElementById('chartDiv').innerHTML = '<div class="empty-state"><div style="font-size:32px">⚠️</div><h3>Could not load '+ticker+'</h3><p class="error-msg">'+data.error+'</p></div>';
      return;
    }

    // Render chart
    initChart();
    chartCandles = data.candles.map(function(c) { return { time: c.time, open: c.open, high: c.high, low: c.low, close: c.close }; });
    candleSeries.setData(chartCandles);

    // Add S/R lines BEFORE fitContent so future points are included in the view
    clearSRLines();
    (data.resistance || []).forEach(function(v, i) { addSRLine(v, '#ff5c6a', 'R'+(i+1)); });
    (data.support    || []).forEach(function(v, i) { addSRLine(v, '#22d673', 'S'+(i+1)); });

    chart.timeScale().fitContent();

    // Render panels
    renderHeader(data);
    renderDirection(data);
    renderLevels(data);
    renderMAs(data);
    renderIndicators(data);
    renderPatterns(data);
    renderExpanded(data);

  } catch (err) {
    clearTimeout(timeoutId);
    if (aborted) return; // timeout already showed error
    showError(ticker, err.message || 'Analysis server offline. Check bot.trendtrooper.com or retry.');
  }
}

// CHANGE 8: Debounced TF button handler (500ms)
var debouncedTFAnalysis = debounce(function(ticker) {
  if (ticker) runAnalysis(ticker);
}, 500);

// Event listeners
document.getElementById('analyzeBtn').addEventListener('click', function() {
  runAnalysis(document.getElementById('tickerInput').value);
});
document.getElementById('tickerInput').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') runAnalysis(e.target.value);
});
document.querySelectorAll('.qp.tf').forEach(function(b) {
  b.addEventListener('click', function() {
    currentTF = b.dataset.tf;
    document.querySelectorAll('.qp.tf').forEach(function(x) { x.classList.remove('active'); });
    b.classList.add('active');
    const t = document.getElementById('tickerInput').value.trim().toUpperCase();
    debouncedTFAnalysis(t);
  });
});
document.querySelectorAll('.qp:not(.tf)').forEach(function(b) {
  b.addEventListener('click', function() {
    document.getElementById('tickerInput').value = b.dataset.t;
    runAnalysis(b.dataset.t);
  });
});

// ── EXPANDED PANEL RENDERERS ──────────────────────────────────

var pivotData = {};

function renderDonut(bearId, bullId, scoreId, labelId, bull, bear, total) {
  var circ = 201;
  var bullPct = total ? bull / total : 0;
  var bearPct = total ? bear / total : 0;
  var bullDash = bullPct * circ;
  var bearDash = bearPct * circ;
  document.getElementById(bearId).setAttribute('stroke-dasharray', bearDash + ' ' + circ);
  document.getElementById(bearId).setAttribute('stroke-dashoffset', -bullDash);
  document.getElementById(bullId).setAttribute('stroke-dasharray', bullDash + ' ' + circ);
  var dominant = bull > bear ? 'BUY' : bear > bull ? 'SELL' : 'NEUTRAL';
  var domCount = bull > bear ? bull : bear;
  var color = bull > bear ? 'var(--green)' : bear > bull ? 'var(--red)' : 'var(--amber)';
  document.getElementById(scoreId).textContent = dominant;
  document.getElementById(scoreId).style.color = color;
  document.getElementById(labelId).textContent = domCount + '/' + total;
}

function renderBreakdownBar(barId, bull, neutral, bear, total) {
  var el = document.getElementById(barId);
  if (!el || !total) return;
  var bPct = (bull / total * 100).toFixed(1);
  var nPct = (neutral / total * 100).toFixed(1);
  var rPct = (bear / total * 100).toFixed(1);
  el.innerHTML =
    '<div class="ind-seg" style="width:'+bPct+'%;background:var(--green)"></div>' +
    '<div class="ind-seg" style="width:'+nPct+'%;background:var(--muted2)"></div>' +
    '<div class="ind-seg" style="width:'+rPct+'%;background:var(--red)"></div>';
}

function renderExpandedSummary(data) {
  var ind = data.ind_summary || {};
  var ma  = data.ma_summary  || {};
  var indTotal = ind.total || 1;
  var maTotal  = ma.total  || 1;
