---
import LogoutBar from "../components/LogoutBar.astro";
---
<!doctype html>
<html lang="en">
<head>
<script>if(localStorage.getItem("tt_dev_access")!=="tt-ironclad-2026"&&!localStorage.getItem("tt_sub_token")){sessionStorage.setItem("tt_redirect",location.pathname);location.replace("/subscribe");}</script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>TrendTrooper — Stock Analysis</title>
  <meta name="description" content="AI-powered daily chart analysis with support/resistance, moving averages, and directional bias." />
  <meta property="og:title" content="TrendTrooper — Stock Analysis">
  <meta property="og:description" content="AI-powered chart analysis with support/resistance, moving averages, pattern detection, and risk calculator.">
  <meta property="og:image" content="https://trendtrooper.com/bot-preview.png">
  <meta property="og:url" content="https://trendtrooper.com/analysis">
  <meta property="og:type" content="website">
  <link rel="canonical" href="https://trendtrooper.com/analysis">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root{
      --bg:#070e1c;--card:#0f1b33;--card2:#111e38;
      --muted:#7a96bb;--muted2:#4a6490;
      --text:#ddeeff;--text2:#b8d0ee;
      --accent:#6ee7ff;--accent2:#a78bfa;
      --green:#22d673;--red:#ff5c6a;--amber:#f59e0b;
      --border2:rgba(255,255,255,.06);--r:16px;--max:1400px;
      --mono:'JetBrains Mono',monospace;--sans:'Space Grotesk',sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{
      font-family:var(--sans);color:var(--text);min-height:100vh;
      background:
        linear-gradient(rgba(80,0,0,.15),rgba(40,0,0,.2)),
        url('/trading-bg.png') center center / cover no-repeat fixed;
    }
    a{color:inherit;text-decoration:none}
    header{position:sticky;top:0;z-index:100;height:70px;background:rgba(2,5,20,.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);display:flex;align-items:center;justify-content:space-between;padding:0 32px;}
    .tt-brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:#e8eeff;}
    .tt-logo{flex-shrink:0;}
    .tt-name{font-family:'Orbitron',monospace;font-size:16px;font-weight:900;letter-spacing:2px;background:linear-gradient(90deg,#fff,#00cfff,#7040ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
    .tt-tag{font-size:9px;color:#00cfff;font-weight:600;letter-spacing:3px;text-transform:uppercase;display:block;opacity:.8;}
    .tt-nav{display:flex;align-items:center;gap:1px;white-space:nowrap;}
    .tt-nav a{color:#c8d8f0;padding:6px 9px;border-radius:8px;text-decoration:none;font-weight:800;font-size:11.5px;letter-spacing:.8px;text-transform:uppercase;transition:color .15s,background .15s;}
    .tt-nav a:hover{color:#e8eeff;background:rgba(0,200,255,.06);}
    .tt-nav a.cur{color:#00cfff;}
    .tt-cta{background:linear-gradient(135deg,#00cfff,#7040ff)!important;color:#fff!important;font-weight:800!important;padding:8px 14px!important;border-radius:8px!important;box-shadow:0 0 20px rgba(0,200,255,.2)!important;}
    .tt-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
    .tt-burger span{width:22px;height:2px;background:#e8eeff;border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
    .tt-burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .tt-burger.open span:nth-child(2){opacity:0;}
    .tt-burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .tt-mob{display:none;flex-direction:column;position:sticky;top:70px;z-index:99;background:rgba(2,5,20,.97);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);padding:8px 24px 16px;}
    .tt-mob.open{display:flex;}
    .tt-mob a{color:rgba(180,210,255,.65);padding:10px 0;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:1px;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.04);}
    .tt-mob a:hover{color:#e8eeff;}
    /* CHANGE 1: breakpoint from 900px nav collapse */
    @media(max-width:900px){.tt-nav{display:none;}.tt-burger{display:flex;}}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:9px 18px;border-radius:12px;font-weight:600;font-size:13.5px;border:1px solid var(--border2);background:rgba(255,255,255,.05);color:var(--text);cursor:pointer;transition:.15s;font-family:var(--sans)}
    .btn:hover{background:rgba(255,255,255,.08)}
    .btn.primary{background:linear-gradient(135deg,var(--accent2),#7c3aed);border:none;color:#fff;font-weight:700}
    .inner-mobile-menu a{color:var(--muted);text-decoration:none;font-weight:600;font-size:14px;padding:11px 0;border-bottom:1px solid var(--border2);transition:color .15s}
    .inner-mobile-menu a:last-child{border-bottom:none}
    .inner-mobile-menu a:hover{color:var(--text)}

    /* SEARCH BAR */
    .search-bar{background:rgba(7,14,28,.3);backdrop-filter:blur(8px);border-bottom:1px solid rgba(255,255,255,.08);padding:14px 24px}
    .search-inner{max-width:var(--max);margin:0 auto;display:flex;gap:10px;align-items:center;flex-wrap:wrap}
    .search-inner input{flex:1;min-width:180px;max-width:320px;padding:10px 16px;border-radius:12px;border:1px solid var(--border2);background:rgba(255,255,255,.04);color:var(--text);font-size:14px;font-family:var(--mono);font-weight:700;outline:none;transition:.15s}
    .search-inner input:focus{border-color:rgba(167,139,250,.5);background:rgba(167,139,250,.04)}
    .search-inner input::placeholder{color:var(--muted2);font-weight:400}
    .qp-wrap{display:flex;gap:6px;flex-wrap:wrap;align-items:center}
    .qp-label{font-size:11px;font-weight:700;color:var(--muted2);letter-spacing:.5px;margin-right:2px}
    .qp{padding:7px 15px;border-radius:999px;font-size:14px;font-weight:700;border:1px solid var(--border2);color:var(--muted);cursor:pointer;background:transparent;font-family:var(--mono);transition:.15s}
    .qp:hover{color:var(--text);border-color:rgba(255,255,255,.2)}
    .qp.active{background:linear-gradient(135deg,var(--accent2),#7c3aed);border-color:transparent;color:#fff}
    .qp.tf.active{background:linear-gradient(135deg,var(--accent2),#7c3aed);border-color:transparent;color:#fff}

    /* LAYOUT — CHANGE 1: breakpoint 1100px -> 900px, sidebar full-width on mobile */
    .wrap{max-width:var(--max);margin:0 auto;padding:24px 24px 40px;display:grid;grid-template-columns:1fr 340px;gap:20px;align-items:start}
    @media(max-width:900px){
      .wrap{grid-template-columns:1fr}
      .sidebar{width:100%}
    }

    /* CHART PANEL */
    .chart-card{background:transparent;border-radius:var(--r);border:1px solid rgba(255,255,255,.08);overflow:hidden}
    .chart-header{padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.06);background:transparent;display:flex;align-items:center;gap:16px;flex-wrap:wrap}
    .ticker-badge{font-family:var(--mono);font-weight:900;font-size:22px;color:var(--text)}
    .price-big{font-family:var(--mono);font-size:22px;font-weight:700}
    .chg-badge{font-family:var(--mono);font-size:13px;font-weight:700;padding:4px 10px;border-radius:8px}
    .chg-up{background:rgba(34,214,115,.12);color:var(--green);border:1px solid rgba(34,214,115,.25)}
    .chg-dn{background:rgba(255,92,106,.12);color:var(--red);border:1px solid rgba(255,92,106,.25)}
    .chg-flat{background:rgba(255,255,255,.05);color:var(--muted);border:1px solid var(--border2)}
    #chartDiv{width:100%;height:420px;position:relative}
    .chart-loading{display:flex;align-items:center;justify-content:center;height:420px;color:var(--muted);font-size:14px;gap:10px}
    .spinner{width:20px;height:20px;border:2px solid var(--border2);border-top-color:var(--accent2);border-radius:50%;animation:spin .7s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}

    /* CHANGE 2: error card style */
    .error-card{display:flex;flex-direction:column;align-items:center;justify-content:center;height:420px;gap:14px;color:var(--muted);text-align:center;padding:20px}
    .error-card h3{font-size:16px;color:var(--red)}
    .error-card p{font-size:13px;color:var(--muted);max-width:320px;line-height:1.6}
    .btn-retry{display:inline-flex;align-items:center;gap:8px;padding:9px 20px;border-radius:10px;font-weight:700;font-size:13px;border:1px solid rgba(255,92,106,.4);background:rgba(255,92,106,.08);color:var(--red);cursor:pointer;transition:.15s;font-family:var(--sans)}
    .btn-retry:hover{background:rgba(255,92,106,.16)}

    /* CHANGE 14: full-chart link */
    .chart-footer{padding:8px 16px;border-top:1px solid rgba(255,255,255,.05);text-align:right}
    .chart-footer a{font-size:12px;color:var(--muted2);text-decoration:none;transition:color .15s}
    .chart-footer a:hover{color:var(--accent)}

    /* SIDEBAR */
    .sidebar{display:flex;flex-direction:column;gap:16px}
    .card{background:rgba(7,14,28,.35);backdrop-filter:blur(8px);border-radius:var(--r);border:1px solid rgba(255,255,255,.12);padding:18px 20px}
    .card-title{font-size:10px;font-weight:700;color:var(--muted2);letter-spacing:1px;text-transform:uppercase;margin-bottom:14px}

    /* DIRECTION CARD */
    .direction-badge{display:flex;align-items:center;justify-content:center;gap:12px;padding:18px;border-radius:12px;margin-bottom:12px}
    .dir-bearish{background:rgba(255,92,106,.08);border:1px solid rgba(255,92,106,.25)}
    .dir-bullish{background:rgba(34,214,115,.08);border:1px solid rgba(34,214,115,.25)}
    .dir-neutral{background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25)}
    .dir-icon{font-size:28px;line-height:1}
    .dir-label{display:flex;flex-direction:column;align-items:flex-start;gap:2px}
    .dir-pct{font-family:var(--mono);font-size:12px;font-weight:700;opacity:.7}
    .dir-text{font-family:'Orbitron',monospace;font-size:18px;font-weight:900;letter-spacing:1px}
    .dir-bearish .dir-text{color:var(--red)}
    .dir-bullish .dir-text{color:var(--green)}
    .dir-neutral .dir-text{color:var(--amber)}

    /* TRADE FORCE */
    .force-wrap{display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:10px;background:rgba(255,255,255,.03);border:1px solid var(--border2);margin-top:10px}
    .force-label{font-size:11px;font-weight:700;color:var(--muted2);letter-spacing:.8px;white-space:nowrap}
    .force-track{flex:1;height:6px;border-radius:3px;background:rgba(255,255,255,.07);overflow:hidden}
    .force-fill{height:100%;border-radius:3px;transition:.4s}
    .force-val{font-family:var(--mono);font-size:16px;font-weight:900;min-width:36px;text-align:right}
    /* CHANGE 4: Trade Force explanation */
    .tf-explain{font-size:12px;color:var(--muted2);line-height:1.5;margin-top:8px;padding:0 2px}

    /* LEVELS TABLE */
    .levels-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .level-group{display:flex;flex-direction:column;gap:6px}
    .level-group-label{font-size:10px;font-weight:700;letter-spacing:.8px;margin-bottom:2px}
    .res-label{color:var(--red)}
    .sup-label{color:var(--green)}
    .level-row{display:flex;align-items:center;justify-content:space-between;padding:6px 10px;border-radius:8px;background:rgba(255,255,255,.025)}
    .level-tag{font-size:12px;color:var(--muted2);font-weight:600}
    .level-val{font-family:var(--mono);font-size:13px;font-weight:700}
    .level-res{color:var(--red)}
    .level-sup{color:var(--green)}
    /* CHANGE 5: S/R note */
    .sr-note{font-size:12px;color:var(--muted2);margin-top:10px;line-height:1.5;font-style:italic}

    /* MA TABLE */
    .ma-table{width:100%;border-collapse:collapse}
    .ma-table td{padding:6px 4px;font-size:12px;border-bottom:1px solid rgba(255,255,255,.03)}
    .ma-table tr:last-child td{border-bottom:none}
    .ma-name{color:var(--muted2);font-size:12px;font-weight:700}
    .ma-val{font-family:var(--mono);font-weight:700;text-align:right}
    .above-ma{color:var(--green)}
    .below-ma{color:var(--red)}
    .ma-arrow{font-size:12px;text-align:center;width:20px}
    /* CHANGE 12: MA legend */
    .ma-legend{margin-top:10px;display:flex;flex-direction:column;gap:3px;border-top:1px solid rgba(255,255,255,.05);padding-top:10px}
    .ma-legend-row{font-size:12px;color:var(--muted2);line-height:1.4}
    .ma-legend-key{font-family:var(--mono);font-weight:700;color:var(--muted)}

    /* PATTERNS */
    .pat-summary{font-size:12px;color:var(--muted2);margin-bottom:10px;font-weight:600}
    .pat-item{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.04)}
    .pat-item:last-child{border-bottom:none}
    .pat-name{font-size:13px;font-weight:600;color:var(--text)}
    .pat-badge{font-size:12px;font-weight:700;padding:2px 9px;border-radius:999px;letter-spacing:.5px;text-transform:uppercase}
    .pat-bull{background:rgba(34,214,115,.12);color:#22d673;border:1px solid rgba(34,214,115,.25)}
    .pat-bear{background:rgba(255,92,106,.12);color:#ff5c6a;border:1px solid rgba(255,92,106,.25)}
    .pat-neutral{background:rgba(167,139,250,.12);color:#a78bfa;border:1px solid rgba(167,139,250,.25)}
    .no-patterns{font-size:12px;color:var(--muted);padding:4px 0}

    /* INDICATORS */
    .ind-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.03)}
    .ind-row:last-child{border-bottom:none}
    .ind-label{font-size:12px;color:var(--muted2);font-weight:600;display:flex;align-items:center;gap:4px;position:relative}
    .ind-val{font-family:var(--mono);font-size:13px;font-weight:700}
    .ind-bar-wrap{flex:1;margin:0 10px;height:4px;border-radius:2px;background:rgba(255,255,255,.07);overflow:hidden}
    .ind-bar{height:100%;border-radius:2px;transition:.3s}

    /* CHANGE 3: Indicator tooltips */
    .info-icon{display:inline-flex;align-items:center;justify-content:center;width:14px;height:14px;border-radius:50%;background:rgba(122,150,187,.15);color:var(--muted2);font-size:10px;cursor:pointer;flex-shrink:0;border:1px solid rgba(122,150,187,.25);font-style:normal;line-height:1;transition:background .15s}
    .info-icon:hover{background:rgba(110,231,255,.15);color:var(--accent)}
    .tooltip-wrap{position:relative;display:inline-flex;align-items:center}
    .tooltip-box{display:none;position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:#0a1628;border:1px solid rgba(110,231,255,.2);border-radius:8px;padding:8px 10px;font-size:12px;color:var(--text2);line-height:1.5;white-space:normal;width:220px;z-index:200;box-shadow:0 4px 16px rgba(0,0,0,.5);pointer-events:none}
    .tooltip-box::after{content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:#0a1628}
    .tooltip-wrap:hover .tooltip-box,
    .tooltip-wrap.active .tooltip-box{display:block}

    /* NARRATIVE */
    .narrative{font-size:13px;line-height:1.7;color:var(--text2)}

    /* 52W RANGE */
    .range-wrap{margin-top:12px}
    .range-labels{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);font-family:var(--mono);margin-bottom:6px}
    .range-track{height:6px;border-radius:3px;background:rgba(255,255,255,.07);position:relative}
    .range-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--muted2),var(--accent2))}
    .range-dot{position:absolute;top:50%;transform:translate(-50%,-50%);width:12px;height:12px;border-radius:50%;background:var(--text);border:2px solid var(--bg);box-shadow:0 0 8px rgba(255,255,255,.2)}
    /* CHANGE 11: 52W end labels */
    .range-end-labels{display:flex;justify-content:space-between;margin-top:5px}
    .range-end-label{font-size:12px;font-weight:700;color:var(--muted2);letter-spacing:.5px;text-transform:uppercase}
    .range-cur-label{font-size:12px;color:var(--text2);font-family:var(--mono);font-weight:700;position:absolute;bottom:18px;transform:translateX(-50%)}

    /* EMPTY / ERROR */
    .empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;height:420px;gap:12px;color:var(--muted)}
    .empty-state h3{font-size:16px;color:var(--text2)}
    .error-msg{color:var(--red);font-size:13px}

    /* CHANGE 7: Risk Calculator */
    .risk-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
    .risk-field{display:flex;flex-direction:column;gap:4px}
    .risk-field label{font-size:12px;color:var(--muted2);font-weight:600;letter-spacing:.4px}
    .risk-field input{padding:7px 10px;border-radius:8px;border:1px solid var(--border2);background:rgba(255,255,255,.04);color:var(--text);font-size:12px;font-family:var(--mono);font-weight:700;outline:none;transition:.15s;width:100%}
    .risk-field input:focus{border-color:rgba(167,139,250,.5);background:rgba(167,139,250,.04)}
    .risk-divider{height:1px;background:rgba(255,255,255,.07);margin:10px 0}
    .risk-results{display:flex;flex-direction:column;gap:6px}
    .risk-result-row{display:flex;justify-content:space-between;align-items:center;padding:5px 0}
    .risk-result-label{font-size:12px;color:var(--muted2);font-weight:600}
    .risk-result-val{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--text)}

    footer{max-width:var(--max);margin:0 auto 0;padding:24px;border-top:1px solid var(--border2);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;color:var(--muted2);font-size:13px}
    .foot-links{display:flex;gap:18px}.foot-links a:hover{color:var(--muted)}

    /* EXPANDED ANALYSIS SECTIONS */
    .exp-wrap{max-width:var(--max);margin:0 auto;padding:0 24px 40px;display:flex;flex-direction:column;gap:16px}
    body.wide .exp-wrap{max-width:100%;padding:0 32px 40px}
    .exp-grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
    .exp-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
    @media(max-width:900px){.exp-grid-3,.exp-grid-2{grid-template-columns:1fr}}

    /* Summary strip */
    .sig-gauge{display:flex;flex-direction:column;align-items:center;gap:6px}
    .gauge-donut{position:relative;width:80px;height:80px}
    .gauge-donut svg{transform:rotate(-90deg)}
    .gauge-label{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:var(--mono);font-size:13px;font-weight:900}
    .gauge-sub{font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;opacity:.7}
    .ind-breakdown{display:flex;height:8px;border-radius:4px;overflow:hidden;gap:2px;margin-top:6px}
    .ind-seg{height:100%;border-radius:2px;transition:.4s}
    .ind-breakdown-labels{display:flex;justify-content:space-between;font-size:11px;font-family:var(--mono);font-weight:700;margin-top:4px}

    /* Day range */
    .day-range-wrap{margin-top:4px}
    .day-range-track{height:6px;border-radius:3px;background:rgba(255,255,255,.07);position:relative;margin:8px 0}
    .day-range-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--red),var(--green))}
    .day-range-dot{position:absolute;top:50%;transform:translate(-50%,-50%);width:12px;height:12px;border-radius:50%;background:var(--text);border:2px solid var(--bg);box-shadow:0 0 8px rgba(255,255,255,.2)}
    .day-range-labels{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);font-family:var(--mono)}

    /* Returns */
    .returns-bars{display:flex;align-items:flex-end;gap:6px;height:80px;margin-top:8px}
    .ret-bar-wrap{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1}
    .ret-bar-track{width:100%;flex:1;display:flex;align-items:flex-end;justify-content:center}
    .ret-bar{width:100%;border-radius:3px 3px 0 0;min-height:4px;transition:.4s}
    .ret-label{font-size:10px;color:var(--muted2);font-weight:700;letter-spacing:.5px}
    .ret-pct{font-size:11px;font-family:var(--mono);font-weight:700}

    /* Indicator + MA detail tables */
    .detail-table{width:100%;border-collapse:collapse}
    .detail-table td{padding:5px 4px;font-size:12px;border-bottom:1px solid rgba(255,255,255,.03)}
    .detail-table tr:last-child td{border-bottom:none}
    .det-label{color:var(--muted2);font-weight:600}
    .det-val{font-family:var(--mono);font-weight:700;text-align:right}
    .det-arrow{text-align:center;width:18px;font-size:11px}
    .det-pct{font-family:var(--mono);font-size:11px;text-align:right;color:var(--muted)}
    .det-bull{color:var(--green)}.det-bear{color:var(--red)}.det-neutral{color:var(--muted)}

    /* Pivot points */
    .pivot-tabs{display:flex;gap:6px;margin-bottom:14px}
