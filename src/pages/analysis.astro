<script src="https://unpkg.com/lightweight-charts@4.2.0/dist/lightweight-charts.standalone.production.js"></script>
<script is:inline>
document.getElementById('yr').textContent = new Date().getFullYear();

function toggleWide() {
  var btn = document.getElementById('wideBtn');
  if (document.body.classList.toggle('wide')) {
    btn.classList.add('active');
    localStorage.setItem('tt_wide_analysis', '1');
  } else {
    btn.classList.remove('active');
    localStorage.setItem('tt_wide_analysis', '0');
  }
}
if (localStorage.getItem('tt_wide_analysis') === '1') {
  document.body.classList.add('wide');
  document.getElementById('wideBtn').classList.add('active');
}

// CHANGE 10: Burger menu close on link click
document.querySelectorAll('#ttMob a').forEach(function(a) {
  a.addEventListener('click', function() {
    document.getElementById('ttMob').classList.remove('open');
    document.getElementById('ttBurger').classList.remove('open');
  });
});

const BOT = 'https://bot.trendtrooper.com';
let chart, candleSeries, srLines = [], currentTF = '1d', chartCandles = [];
let bullMarkerSeries = null, bearMarkerSeries = null;
let currentTicker = 'SPY';
let currentSupportLevel = null; // CHANGE 7: store support level for risk calc

// CHANGE 8: Debounce helper
function debounce(fn, ms) {
  let timer;
  return function() {
    clearTimeout(timer);
    var args = arguments;
    timer = setTimeout(function() { fn.apply(this, args); }, ms);
  };
}

function initChart() {
  const el = document.getElementById('chartDiv');
  el.innerHTML = '';
  if (chart) { try { chart.remove(); } catch(e){} }
  chart = LightweightCharts.createChart(el, {
    width: el.clientWidth,
    height: 420,
    layout: { background: { type: 'solid', color: 'transparent' }, textColor: '#ddeeff' },
    grid: { vertLines: { color: 'rgba(255,255,255,.06)' }, horzLines: { color: 'rgba(255,255,255,.06)' } },
    crosshair: { mode: LightweightCharts.CrosshairMode.Normal },
    rightPriceScale: { borderColor: 'rgba(255,255,255,.08)' },
    timeScale: { borderColor: 'rgba(255,255,255,.08)', timeVisible: true },
  });
  candleSeries = chart.addCandlestickSeries({
    upColor: '#22d673', downColor: '#ff5c6a',
    borderUpColor: '#22d673', borderDownColor: '#ff5c6a',
    wickUpColor: '#22d673', wickDownColor: '#ff5c6a',
  });
  window.addEventListener('resize', function() { if(chart) chart.applyOptions({width: el.clientWidth}); });
  return { chart, candleSeries };
}

function addSRLine(price, color, label) {
  if (!chartCandles.length) return;
  const lastIdx     = chartCandles.length - 1;
  const lastTime    = chartCandles[lastIdx].time;
  const barInterval = lastIdx > 0 ? chartCandles[lastIdx].time - chartCandles[lastIdx - 1].time : 86400;
  const pts = [];
  for (let i = 0; i <= 30; i++) {
    pts.push({ time: lastTime + barInterval * i, value: price });
  }
  const line = chart.addLineSeries({
    color,
    lineWidth: 2,
    lineStyle: 0,
    priceLineVisible: false,
    lastValueVisible: true,
    title: label,
    crosshairMarkerVisible: false,
  });
  line.setData(pts);
  srLines.push(line);
}

function clearSRLines() {
  srLines.forEach(function(l) { try { chart.removeSeries(l); } catch(e){} });
  srLines = [];
}

function renderHeader(data) {
  document.getElementById('hTicker').textContent = data.ticker;
  document.getElementById('hPrice').textContent = '$' + data.price.toFixed(2);
  const chgEl = document.getElementById('hChg');
  const up = data.change_pct >= 0;
  chgEl.textContent = (up ? '+' : '') + data.change_pct.toFixed(2) + '%';
  chgEl.className = 'chg-badge ' + (up ? 'chg-up' : 'chg-dn');
  document.getElementById('hRange').textContent = '52W: $' + data.low_52 + ' / $' + data.high_52;
}

function renderDirection(data) {
  const badge = document.getElementById('dirBadge');
  const icon  = document.getElementById('dirIcon');
  const text  = document.getElementById('dirText');
  const pct   = document.getElementById('dirPct');
  badge.className = 'direction-badge dir-' + data.direction;
  if (data.direction === 'bearish') { icon.textContent = '↓'; text.textContent = 'BEARISH'; }
  else if (data.direction === 'bullish') { icon.textContent = '↑'; text.textContent = 'BULLISH'; }
  else { icon.textContent = '→'; text.textContent = 'NEUTRAL'; }
  pct.textContent = (data.confidence || 0) + '% confidence';

  // Trade Force
  const force = data.trade_force || 0;
  const forcePct = (force / 10) * 100;
  const forceColor = force >= 7 ? 'var(--green)' : force >= 4.5 ? 'var(--amber)' : 'var(--red)';
  document.getElementById('forceFill').style.width   = forcePct + '%';
  document.getElementById('forceFill').style.background = forceColor;
  document.getElementById('forceVal').textContent    = force.toFixed(1);
  document.getElementById('forceVal').style.color    = forceColor;

  document.getElementById('narrative').textContent = data.narrative;
}

function renderLevels(data) {
  const res = data.resistance || [];
  const sup = data.support || [];
  document.getElementById('resLevels').innerHTML = res.length
    ? res.map(function(v,i){ return '<div class="level-row"><span class="level-tag">R'+(i+1)+'</span><span class="level-val level-res">$'+v.toFixed(2)+'</span></div>'; }).join('')
    : '<div style="color:var(--muted);font-size:12px">None above</div>';
  document.getElementById('supLevels').innerHTML = sup.length
    ? sup.map(function(v,i){ return '<div class="level-row"><span class="level-tag">S'+(i+1)+'</span><span class="level-val level-sup">$'+v.toFixed(2)+'</span></div>'; }).join('')
    : '<div style="color:var(--muted);font-size:12px">None below</div>';

  // CHANGE 7: Store nearest support for risk calc pre-fill
  if (sup.length > 0) {
    currentSupportLevel = sup[0];
    const stopInput = document.getElementById('rcStop');
    if (stopInput && !stopInput.dataset.userEdited) {
      stopInput.value = sup[0].toFixed(2);
      calcRisk();
    }
  }

  // 52W range bar
  const lo = data.low_52, hi = data.high_52, pr = data.price;
  const pct = ((pr - lo) / (hi - lo) * 100).toFixed(1);
  document.getElementById('rangeLow').textContent  = '$' + lo;
  document.getElementById('rangeHigh').textContent = '$' + hi;
  document.getElementById('rangeCur').textContent  = '$' + pr;
  document.getElementById('rangeFill').style.width = pct + '%';
  document.getElementById('rangeDot').style.left   = pct + '%';
  // CHANGE 11: update CURRENT label position
  var curLabel = document.getElementById('rangeCurLabel');
  if (curLabel) curLabel.style.left = pct + '%';
  document.getElementById('rangeWrap').style.display = 'block';
}

function renderMAs(data) {
  const mas = data.moving_averages;
  const price = data.price;
  const rows = [
    ['5-Day',  mas.ma5],
    ['20-Day', mas.ma20],
    ['50-Day', mas.ma50],
    ['100-Day',mas.ma100],
    ['200-Day',mas.ma200],
  ];
  document.getElementById('maTable').innerHTML = rows.map(function(row) {
    var name = row[0], val = row[1];
    if (!val) return '<tr><td class="ma-name">'+name+'</td><td class="ma-arrow">—</td><td class="ma-val" style="color:var(--muted)">—</td></tr>';
