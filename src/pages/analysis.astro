function renderReturns(data) {
  var r = data.returns || {};
  var el = document.getElementById('expReturns');
  if (!el) return;
  var entries = [
    {label:'1D',val:r.d1},{label:'1W',val:r.w1},{label:'1M',val:r.m1},
    {label:'3M',val:r.m3},{label:'6M',val:r.m6},{label:'1Y',val:r.y1},
  ];
  var maxAbs = Math.max.apply(null, entries.filter(function(e){return e.val!=null;}).map(function(e){return Math.abs(e.val);})) || 1;
  el.innerHTML = entries.map(function(e) {
    if (e.val == null) return '<div class="ret-bar-wrap"><div class="ret-pct" style="color:var(--muted)">—</div><div class="ret-bar-track"><div class="ret-bar" style="height:4px;background:rgba(255,255,255,.1)"></div></div><div class="ret-label">'+e.label+'</div></div>';
    var bull = e.val >= 0;
    var h = Math.max(4, Math.abs(e.val) / maxAbs * 72);
    var col = bull ? 'var(--green)' : 'var(--red)';
    return '<div class="ret-bar-wrap"><div class="ret-pct" style="color:'+col+'">'+(bull?'+':'')+e.val+'%</div><div class="ret-bar-track"><div class="ret-bar" style="height:'+h+'px;background:'+col+'"></div></div><div class="ret-label">'+e.label+'</div></div>';
  }).join('');
}

function renderIndTable(data) {
  var ind = data.indicators || {};
  var price = data.price;
  var rows = [
    {label:'RSI (14)',    val:ind.rsi,        bull:ind.rsi&&ind.rsi<30,              bear:ind.rsi&&ind.rsi>70},
    {label:'MACD Hist',  val:ind.macd_hist,   bull:ind.macd_hist&&ind.macd_hist>0,   bear:ind.macd_hist&&ind.macd_hist<0},
    {label:'MACD',       val:ind.macd,        bull:ind.macd&&ind.macd>0,             bear:ind.macd&&ind.macd<0},
    {label:'Williams %R',val:ind.williams_r,  bull:ind.williams_r&&ind.williams_r<-80, bear:ind.williams_r&&ind.williams_r>-20},
    {label:'CCI (20)',   val:ind.cci,         bull:ind.cci&&ind.cci<-100,            bear:ind.cci&&ind.cci>100},
    {label:'Stoch %K',   val:ind.stoch_k,     bull:ind.stoch_k&&ind.stoch_k<20,     bear:ind.stoch_k&&ind.stoch_k>80},
    {label:'ADX (14)',   val:ind.adx,         bull:false,                            bear:false},
    {label:'ATR (14)',   val:ind.atr,         bull:false,                            bear:false},
    {label:'PSAR',       val:ind.psar,        bull:ind.psar&&price>ind.psar,         bear:ind.psar&&price<ind.psar, dollar:true},
  ];
  document.getElementById('expIndTable').innerHTML = rows.filter(function(r){return r.val!=null;}).map(function(r) {
    var cls   = r.bull ? 'det-bull' : r.bear ? 'det-bear' : 'det-neutral';
    var arrow = r.bull ? '↑' : r.bear ? '↓' : '→';
    var disp  = r.dollar ? '$'+r.val.toFixed(2) : r.val.toFixed(2);
    return '<tr><td class="det-label">'+r.label+'</td><td class="det-arrow '+cls+'">'+arrow+'</td><td class="det-val '+cls+'">'+disp+'</td></tr>';
  }).join('');
}

function renderMATable(data) {
  var mas = data.moving_averages || {};
  var price = data.price;
  var rows = [
    {label:'SMA 5',  val:mas.ma5},  {label:'SMA 20', val:mas.ma20},
    {label:'SMA 50', val:mas.ma50}, {label:'SMA 100',val:mas.ma100},
    {label:'SMA 200',val:mas.ma200},{label:'EMA 7',  val:mas.ema7},
    {label:'EMA 20', val:mas.ema20},{label:'EMA 50', val:mas.ema50},
    {label:'EMA 100',val:mas.ema100},
  ];
  document.getElementById('expMATable').innerHTML = rows.filter(function(r){return r.val!=null;}).map(function(r) {
    var above   = price >= r.val;
    var cls     = above ? 'det-bull' : 'det-bear';
    var arrow   = above ? '↑' : '↓';
    var pctDiff = ((price - r.val) / r.val * 100).toFixed(2);
    var pctCol  = above ? 'var(--green)' : 'var(--red)';
    return '<tr><td class="det-label">'+r.label+'</td><td class="det-arrow '+cls+'">'+arrow+'</td><td class="det-val '+cls+'">$'+r.val.toFixed(2)+'</td><td class="det-pct" style="color:'+pctCol+'">'+(above?'+':'')+pctDiff+'%</td></tr>';
  }).join('');
}

function pivotTable(methods) {
  var cols = ['S3','S2','S1','PP','R1','R2','R3'];
  var keys = ['s3','s2','s1','pp','r1','r2','r3'];
  var names = ['Standard','Camarilla','Woodie','Fibonacci'];
  var mkeys = ['standard','camarilla','woodie','fibonacci'];
  var html = '<div class="pivot-grid">';
  html += cols.map(function(c){ return '<div class="pivot-col-head '+(c==='PP'?'pivot-pp':c[0]==='S'?'pivot-s':'pivot-r')+'">'+c+'</div>'; }).join('');
  html += '</div>';
  names.forEach(function(name, ni) {
    var m = methods && methods[mkeys[ni]];
    if (!m) return;
    html += '<div class="pivot-method-label">'+name+'</div><div class="pivot-grid">';
    html += keys.map(function(k) {
      var cls = k==='pp' ? 'pivot-pp' : k[0]==='s' ? 'pivot-s' : 'pivot-r';
      return '<div class="pivot-cell '+cls+'">'+(m[k]!=null ? '$'+m[k] : '—')+'</div>';
    }).join('');
    html += '</div>';
    if (ni < names.length - 1) html += '<div class="pivot-divider"></div>';
  });
  return html;
}

function showPivot(tf) {
  ['daily','weekly','monthly'].forEach(function(t) {
    document.getElementById('pt'+t.charAt(0).toUpperCase()+t.slice(1)).classList.toggle('active', t===tf);
  });
  var el = document.getElementById('expPivots');
  if (!el) return;
  var d = pivotData[tf];
  el.innerHTML = d ? pivotTable(d) : '<div style="color:var(--muted);font-size:12px">No data for this timeframe.</div>';
}

function renderExpanded(data) {
  document.getElementById('expWrap').style.display = 'flex';
  pivotData = data.pivot_points || {};
  renderExpandedSummary(data);
  renderDayRange(data);
  renderReturns(data);
  renderIndTable(data);
  renderMATable(data);
  showPivot('daily');
}

