---
// TrendTrooper — Subscription Success page
// Stripe redirects here after successful payment
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Welcome to TrendTrooper Pro</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#020510;
  --cyan:#00cfff;
  --cyan-dim:rgba(0,200,255,0.08);
  --cyan-glow:rgba(0,200,255,0.25);
  --green:#00ff88;
  --green-dim:rgba(0,255,136,0.08);
  --purple:#7040ff;
  --text:#e8eeff;
  --muted:rgba(220,235,255,0.95);
  --muted2:rgba(180,210,255,0.6);
  --border:rgba(0,200,255,0.1);
  --border2:rgba(0,200,255,0.2);
}
html{scroll-behavior:smooth;}
body{
  background:var(--bg);
  color:var(--text);
  font-family:'Rajdhani',sans-serif;
  line-height:1.6;
  min-height:100vh;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  overflow-x:hidden;
}
body::before{
  content:'';
  position:fixed;inset:0;
  background-image:
    linear-gradient(rgba(0,200,255,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,200,255,0.025) 1px,transparent 1px);
  background-size:50px 50px;
  z-index:0;pointer-events:none;
}
body::after{
  content:'';
  position:fixed;inset:0;
  background:
    radial-gradient(ellipse at 30% 0%,rgba(0,255,136,0.06) 0%,transparent 50%),
    radial-gradient(ellipse at 70% 100%,rgba(0,200,255,0.06) 0%,transparent 50%);
  z-index:0;pointer-events:none;
}
.card{
  position:relative;z-index:1;
  background:rgba(4,8,30,0.92);
  border:1px solid rgba(0,255,136,0.3);
  border-radius:16px;
  padding:56px 48px;
  max-width:560px;
  width:90%;
  text-align:center;
  box-shadow:0 0 60px rgba(0,255,136,0.08),0 0 0 1px rgba(0,255,136,0.05);
}
.success-icon{
  font-size:3.5rem;margin-bottom:16px;display:block;
  filter:drop-shadow(0 0 16px rgba(0,255,136,0.6));
  animation:pulse 2s ease-in-out infinite;
}
@keyframes pulse{0%,100%{filter:drop-shadow(0 0 16px rgba(0,255,136,0.6));}50%{filter:drop-shadow(0 0 30px rgba(0,255,136,0.9));}}
.label{
  font-family:'Orbitron',sans-serif;font-size:0.65rem;letter-spacing:0.2em;
  color:var(--green);text-transform:uppercase;margin-bottom:12px;
}
h1{
  font-family:'Orbitron',sans-serif;font-size:1.8rem;font-weight:700;
  background:linear-gradient(135deg,#fff 0%,var(--green) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  margin-bottom:16px;
}
p{color:var(--muted2);font-size:1.05rem;margin-bottom:32px;line-height:1.7;}
.features{
  display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:36px;text-align:left;
}
.feat{
  background:var(--green-dim);border:1px solid rgba(0,255,136,0.15);
  border-radius:8px;padding:12px 14px;font-size:0.9rem;
  display:flex;align-items:center;gap:8px;color:var(--muted);
}
.feat::before{content:'✓';color:var(--green);font-weight:700;font-size:1rem;}
.links{display:flex;flex-direction:column;gap:10px;margin-bottom:24px;}
.btn{
  display:block;width:100%;
  background:linear-gradient(135deg,var(--green),var(--cyan));
  color:#020510;font-family:'Orbitron',sans-serif;font-size:0.8rem;
  font-weight:700;letter-spacing:0.1em;
  padding:14px 24px;border-radius:8px;border:none;cursor:pointer;
  text-decoration:none;transition:all 0.2s;
  box-shadow:0 0 30px rgba(0,255,136,0.25);
}
.btn:hover{box-shadow:0 0 40px rgba(0,255,136,0.4);transform:translateY(-1px);}
.btn-outline{
  display:block;width:100%;
  background:transparent;border:1px solid var(--border2);
  color:var(--muted);font-family:'Orbitron',sans-serif;font-size:0.75rem;
  font-weight:600;letter-spacing:0.08em;
  padding:12px 24px;border-radius:8px;cursor:pointer;
  text-decoration:none;transition:all 0.2s;
}
.btn-outline:hover{border-color:var(--cyan);color:var(--cyan);}
.token-box{
  background:rgba(0,255,136,0.05);border:1px solid rgba(0,255,136,0.2);
  border-radius:8px;padding:14px 16px;margin-bottom:28px;
}
.token-label{font-size:0.75rem;color:var(--muted2);margin-bottom:6px;}
.token-val{
  font-family:'Orbitron',sans-serif;font-size:0.8rem;color:var(--green);
  letter-spacing:0.05em;word-break:break-all;
}
@media(max-width:520px){
  .card{padding:36px 20px;}
  .features{grid-template-columns:1fr;}
  h1{font-size:1.4rem;}
}
header{position:sticky;top:0;z-index:100;height:70px;background:rgba(2,5,20,.92);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);display:flex;align-items:center;justify-content:space-between;padding:0 32px;}
.tt-brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:#e8eeff;}
.tt-logo{flex-shrink:0;}
.tt-name{font-family:'Orbitron',monospace;font-size:16px;font-weight:900;letter-spacing:2px;background:linear-gradient(90deg,#fff,#00cfff,#7040ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.tt-tag{font-size:9px;color:#00cfff;font-weight:600;letter-spacing:3px;text-transform:uppercase;display:block;opacity:.8;}
.tt-nav{display:flex;align-items:center;gap:1px;white-space:nowrap;}
.tt-nav a{color:#c8d8f0;padding:6px 9px;border-radius:8px;text-decoration:none;font-weight:800;font-size:11.5px;letter-spacing:.8px;text-transform:uppercase;transition:color .15s,background .15s;}
.tt-nav a:hover{color:#e8eeff;background:rgba(0,200,255,.06);}
.tt-nav a.cur{color:#00cfff;}
.tt-cta{background:linear-gradient(135deg,#00cfff,#7040ff)!important;color:#fff!important;font-weight:800!important;padding:8px 14px!important;border-radius:8px!important;box-shadow:0 0 20px rgba(0,200,255,.2)!important;}
.tt-burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
.tt-burger span{width:22px;height:2px;background:#e8eeff;border-radius:2px;display:block;transition:transform .2s,opacity .2s;}
.tt-burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.tt-burger.open span:nth-child(2){opacity:0;}
.tt-burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.tt-mob{display:none;flex-direction:column;position:sticky;top:70px;z-index:99;background:rgba(2,5,20,.97);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,200,255,.1);padding:8px 24px 16px;}
.tt-mob.open{display:flex;}
.tt-mob a{color:#c8d8f0;padding:10px 0;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:1px;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.04);}
.tt-mob a:hover{color:#e8eeff;}
@media(max-width:900px){.tt-nav{display:none;}.tt-burger{display:flex;}}
.page-wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:40px 20px;}
</style>
</head>
<body style="justify-content:flex-start;align-items:stretch;">
<header>
  <a class="tt-brand" href="/">
    <svg class="tt-logo" width="44" height="50" viewBox="0 0 52 58"><defs><linearGradient id="shG" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#6644ff"/><stop offset="100%" stop-color="#00aaff"/></linearGradient></defs><path d="M26 2 L50 12 L50 32 Q50 48 26 56 Q2 48 2 32 L2 12 Z" fill="url(#shG)" stroke="rgba(100,160,255,0.6)" stroke-width="1.5"/><text x="26" y="36" text-anchor="middle" font-family="Orbitron,monospace" font-weight="900" font-size="16" fill="#ffffff" letter-spacing="1">TT</text><text x="26" y="17" text-anchor="middle" font-size="10" fill="rgba(255,220,100,0.9)">*</text></svg>
    <div><div class="tt-name">TRENDTROOPER</div><span class="tt-tag">Signal Service</span></div>
  </a>
  <nav class="tt-nav">
    <a href="/#features">Features</a>
    <a href="/chart">Live Chart</a>
    <a href="/#markets">Markets</a>
    <a href="/#pricing">Pricing</a>
    <a href="/chart">Full Chart</a>
    <a href="/analysis">Analysis</a>
    <a href="/screener">Screener</a>
    <a href="/academy">Academy</a>
    <a href="/tools">Tools</a>
    <a href="https://bot.trendtrooper.com/" target="_blank">Live Bot Trading</a>
    <a href="/#pricing" class="tt-cta">Get Started</a>
  </nav>
  <button class="tt-burger" id="ttBurger" onclick="this.classList.toggle('open');document.getElementById('ttMob').classList.toggle('open')" aria-label="Menu"><span></span><span></span><span></span></button>
</header>
<div class="tt-mob" id="ttMob">
  <a href="/#features">Features</a>
  <a href="/chart">Live Chart</a>
  <a href="/#markets">Markets</a>
  <a href="/#pricing">Pricing</a>
  <a href="/chart">Full Chart</a>
  <a href="/analysis">Analysis</a>
  <a href="/screener">Screener</a>
  <a href="/academy">Academy</a>
  <a href="/tools">Tools</a>
  <a href="https://bot.trendtrooper.com/" target="_blank">Live Bot Trading</a>
  <a href="/#pricing">Get Started</a>
</div>
<div class="page-wrap">
<div class="card">
  <span class="success-icon">⚡</span>
  <div class="label">Access Granted</div>
  <h1>Welcome to TrendTrooper</h1>
  <p>Your subscription is active. You now have full access to real-time signals, the trading dashboard, screener, and more.</p>

  <div class="features">
    <div class="feat">Real-time signals</div>
    <div class="feat">Bot dashboard</div>
    <div class="feat">Stock screener</div>
    <div class="feat">Live charts</div>
    <div class="feat">Academy</div>
    <div class="feat">Strategy tools</div>
  </div>

  <div class="token-box" id="tokenBox" style="display:none;">
    <div class="token-label">Your access token — save this somewhere safe</div>
    <div class="token-val" id="tokenDisplay"></div>
  </div>

  <div class="links">
    <a href="/dashboard" class="btn">Go to Dashboard →</a>
    <a href="/screener" class="btn-outline">Open Screener</a>
    <a href="/academy" class="btn-outline">Browse Academy</a>
  </div>
</div></div>

<script>
  const params = new URLSearchParams(window.location.search);
  const sessionId = params.get('session_id');

  if (params.get('dev') === 'tt-ironclad-2026') {
    localStorage.setItem('tt_dev_access', 'tt-ironclad-2026');
  }

  if (sessionId) {
    fetch('https://bot.trendtrooper.com/get-token?session_id=' + sessionId)
      .then(r => r.json())
      .then(data => {
        if (data.token) {
          localStorage.setItem('tt_sub_token', data.token);
          document.getElementById('tokenDisplay').textContent = data.token;
          document.getElementById('tokenBox').style.display = 'block';
        }
      })
      .catch(() => {});
  }
  document.querySelectorAll('#ttMob a').forEach(a=>a.addEventListener('click',()=>{document.getElementById('ttMob').classList.remove('open');document.getElementById('ttBurger').classList.remove('open');}));
</script>
</body>
</html>
