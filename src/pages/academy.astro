<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
  document.getElementById('yr').textContent = new Date().getFullYear();

  function genPrice(n,start,vol){const p=[start];for(let i=1;i<n;i++){p.push(+(p[i-1]+((Math.random()-.47)*vol)).toFixed(2))}return p}
  function sma(arr,n){return arr.map((_,i)=>i<n-1?null:+(arr.slice(i-n+1,i+1).reduce((a,b)=>a+b)/n).toFixed(2))}
  function ema(arr,n){const k=2/(n+1),out=[null];let e=arr[0];for(let i=1;i<arr.length;i++){if(i<n){out.push(null)}else if(i===n-1){e=arr.slice(0,n).reduce((a,b)=>a+b)/n;out.push(+e.toFixed(2))}else{e=arr[i]*k+e*(1-k);out.push(+e.toFixed(2))}}return out}
  function rsi(arr,n){const out=Array(n).fill(null);for(let i=n;i<arr.length;i++){let g=0,l=0;for(let j=i-n+1;j<=i;j++){const d=arr[j]-arr[j-1];if(d>0)g+=d;else l-=d}const rs=l===0?100:g/n/(l/n);out.push(+(100-100/(1+rs)).toFixed(1))}return out}

  const labels=[...Array(60)].map((_,i)=>`D${i+1}`);
  const price=genPrice(60,420,4);
  const sma20=sma(price,20);
  const ema20=ema(price,20);
  const rsiData=rsi(price,14);
  const gridColor='rgba(255,255,255,.05)';
  const tickColor='rgba(122,150,187,.7)';
  const baseOpts={responsive:true,maintainAspectRatio:false,animation:{duration:600},plugins:{legend:{display:false},tooltip:{mode:'index',intersect:false,backgroundColor:'#0f1b33',titleColor:'#7a96bb',bodyColor:'#ddeeff',borderColor:'rgba(110,231,255,.2)',borderWidth:1}},scales:{x:{ticks:{color:tickColor,font:{size:10},maxTicksLimit:10},grid:{color:gridColor}},y:{ticks:{color:tickColor,font:{size:10}},grid:{color:gridColor}}}};

  let maChart=null;
  function buildCompare(){return{labels,datasets:[{label:'Price',data:price,borderColor:'#6ee7ff',borderWidth:1.5,pointRadius:0,tension:.3,fill:false},{label:'SMA 20',data:sma20,borderColor:'#a78bfa',borderWidth:1.5,borderDash:[6,3],pointRadius:0,tension:.3,fill:false},{label:'EMA 20',data:ema20,borderColor:'#f59e0b',borderWidth:1.5,pointRadius:0,tension:.3,fill:false}]}}
  function buildCross(){const ema9=ema(price,9);return{labels,datasets:[{label:'Price',data:price,borderColor:'#6ee7ff',borderWidth:1.5,pointRadius:0,tension:.3,fill:false},{label:'EMA 9',data:ema9,borderColor:'#22d673',borderWidth:1.5,pointRadius:0,tension:.3,fill:false},{label:'EMA 20',data:ema20,borderColor:'#f59e0b',borderWidth:1.5,borderDash:[4,2],pointRadius:0,tension:.3,fill:false}]}}
  function buildRSI(){return{labels,datasets:[{label:'RSI 14',data:rsiData,borderColor:'#22d673',borderWidth:1.5,pointRadius:0,tension:.3,fill:false}]}}

  function initChart(type){
    if(maChart){maChart.destroy()}
    const ctx=document.getElementById('maChart').getContext('2d');
    const data=type==='compare'?buildCompare():type==='cross'?buildCross():buildRSI();
    const opts={...baseOpts};
    if(type==='rsi'){opts.scales={...opts.scales,y:{...opts.scales.y,min:0,max:100}}}
    maChart=new Chart(ctx,{type:'line',data,options:opts});
  }
  initChart('compare');

  document.querySelectorAll('#maTabs .ctab').forEach(btn=>{
    btn.addEventListener('click',()=>{
      document.querySelectorAll('#maTabs .ctab').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      initChart(btn.dataset.tab);
    });
  });

  function calcRisk(){
    const acc=+document.getElementById('accSize').value||25000;
    const pct=+document.getElementById('riskPct').value||1;
    const entry=+document.getElementById('entryPrice').value||0;
    const stop=+document.getElementById('stopPrice').value||0;
    const dollarRisk=acc*pct/100;
    const stopDist=Math.abs(entry-stop);
    const shares=stopDist>0?Math.floor(dollarRisk/stopDist):0;
    const actual=shares*stopDist;
    document.getElementById('sharesOut').textContent=shares.toLocaleString();
    document.getElementById('dollarRiskOut').textContent='$'+actual.toFixed(0);
  }
  document.querySelectorAll('#calcBody input').forEach(i=>i.addEventListener('input',calcRisk));
  calcRisk();

  let answered=false;
  function checkAnswer(btn,correct){
    if(answered)return;
    answered=true;
    const fb=document.getElementById('qFeedback');
    if(correct){
      btn.classList.add('correct');
      fb.textContent='✓ Correct! Dollar risk = $30,000 × 1% = $300. Stop distance = $3. Shares = $300 ÷ $3 = 100.';
      fb.className='quiz-feedback show ok';
    } else {
      btn.classList.add('wrong');
      document.querySelectorAll('.quiz-opt')[1].classList.add('correct');
      fb.textContent='✗ The correct answer is 100 shares. $300 risk ÷ $3 stop distance = 100.';
      fb.className='quiz-feedback show no';
    }
  }
</script>
</body>
