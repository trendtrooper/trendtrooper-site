---
// TrendTrooper Academy — Cyberpunk Edition
---
<!doctype html>
<html lang="en">
<head>
<script>if(localStorage.getItem("tt_dev_access")!=="tt-ironclad-2026"&&!localStorage.getItem("tt_sub_token")){sessionStorage.setItem("tt_redirect",location.pathname);location.replace("/subscribe");}</script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>TrendTrooper Academy — Trade with Structure. Not Hope.</title>
  <meta name="description" content="Systematic trading education from beginner to professional. Free forever. Cyberpunk-grade curriculum." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
  <style is:global>
    :root{
      --bg:#020510;
      --bg2:rgba(4,8,30,0.92);
      --bg3:rgba(6,12,40,0.7);
      --panel:#060d1f;
      --card:#080f22;
      --cyan:#00cfff;
      --cyan-dim:rgba(0,200,255,0.08);
      --cyan-glow:rgba(0,200,255,0.25);
      --green:#00ff88;
      --green-dim:rgba(0,255,136,0.08);
      --purple:#7040ff;
      --purple-dim:rgba(112,64,255,0.15);
      --magenta:#ff0080;
      --yellow:#ffd060;
      --red:#ff4060;
      --text:#e8eeff;
      --muted:rgba(180,210,255,0.6);
      --border:rgba(0,200,255,0.1);
      --border2:rgba(0,200,255,0.2);
      --max:1160px;
      --mono:'Share Tech Mono',ui-monospace,monospace;
      --sans:'Rajdhani',sans-serif;
      --head:'Orbitron',monospace;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{
      font-family:var(--sans);
      color:var(--text);
      background:var(--bg) url('/city-bg.png') center center/cover no-repeat fixed;
      overflow-x:hidden;
      position:relative;
    }

    /* GRID */
    body::before{
      content:'';position:fixed;inset:0;
      background-image:
        linear-gradient(rgba(0,200,255,0.025) 1px,transparent 1px),
        linear-gradient(90deg,rgba(0,200,255,0.025) 1px,transparent 1px);
      background-size:50px 50px;
      z-index:0;pointer-events:none;
    }
    /* RADIAL GLOW */
    body::after{
      content:'';position:fixed;inset:0;
      background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(0,200,255,0.06) 0%,transparent 70%);
      z-index:0;pointer-events:none;
    }
    /* SCANLINES */
    .scanlines{
      position:fixed;inset:0;z-index:1;pointer-events:none;
      background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.06) 2px,rgba(0,0,0,0.06) 4px);
    }

    a{color:inherit;text-decoration:none}

    /* ── NAV ── */
    header{
      position:sticky;top:0;z-index:100;
      background:rgba(2,5,16,0.92);
      border-bottom:1px solid var(--border2);
      backdrop-filter:blur(20px);
      box-shadow:0 0 40px rgba(0,200,255,0.08);
    }
    .nav{
      max-width:var(--max);margin:0 auto;padding:14px 24px;
      display:flex;align-items:center;justify-content:space-between;gap:20px;
    }
    .brand{display:flex;align-items:center;gap:12px;}
    .logo{
      width:36px;height:36px;border-radius:8px;
      background:linear-gradient(135deg,var(--cyan),var(--purple));
      display:flex;align-items:center;justify-content:center;
      font-family:var(--head);font-weight:900;font-size:10px;color:#000;
      letter-spacing:.5px;box-shadow:0 0 20px rgba(0,200,255,0.3);
    }
    .brand-name{font-family:var(--head);font-weight:900;font-size:12px;letter-spacing:1px;color:var(--cyan);text-shadow:0 0 15px rgba(0,200,255,0.5);}
    .brand-sub{font-size:10px;color:var(--muted);font-family:var(--mono);letter-spacing:2px;}
    .navlinks{display:flex;gap:20px;}
    .navlinks a{font-family:var(--mono);font-size:0.7rem;letter-spacing:2px;color:var(--muted);text-transform:uppercase;transition:.2s;}
    .navlinks a:hover,.navlinks a.active{color:var(--cyan);text-shadow:0 0 10px rgba(0,200,255,0.5);}
    .nav-btn{
      font-family:var(--mono);font-size:0.65rem;letter-spacing:2px;text-transform:uppercase;
      padding:8px 18px;border:1px solid var(--border2);
      background:var(--cyan-dim);color:var(--cyan);cursor:pointer;transition:.2s;
      clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);
    }
    .nav-btn:hover{background:rgba(0,200,255,0.15);box-shadow:0 0 20px rgba(0,200,255,0.2);}
    .hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:6px;}
    .hamburger span{width:20px;height:2px;background:var(--text);border-radius:1px;display:block;transition:.2s;}
    .hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .hamburger.open span:nth-child(2){opacity:0;}
    .hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .mobile-menu{display:none;flex-direction:column;position:sticky;top:61px;z-index:99;background:rgba(2,5,16,0.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border2);padding:8px 24px 16px;}
    .mobile-menu.open{display:flex;}
    .mobile-menu a{font-family:var(--mono);font-size:0.75rem;letter-spacing:2px;color:var(--muted);text-transform:uppercase;padding:12px 0;border-bottom:1px solid var(--border);transition:.15s;}
    .mobile-menu a:hover{color:var(--cyan);}

    /* ── TICKER ── */
    .ticker{overflow:hidden;background:rgba(0,200,255,0.04);border-bottom:1px solid var(--border);padding:6px 0;white-space:nowrap;}
    .ticker-inner{display:inline-block;animation:ticker 40s linear infinite;}
    .ticker-inner span{font-family:var(--mono);font-size:0.65rem;color:var(--muted);letter-spacing:1px;margin:0 2.5rem;}
    .ticker-inner .up{color:var(--green);}
    .ticker-inner .dn{color:var(--red);}
    @keyframes ticker{from{transform:translateX(100vw)}to{transform:translateX(-100%)}}

    /* ── LAYOUT ── */
    main{position:relative;z-index:2;}
    .container{max-width:var(--max);margin:0 auto;padding:0 24px;}

    /* ── HERO ── */
    .hero{
      padding:80px 24px 60px;
      max-width:var(--max);margin:0 auto;
      text-align:center;position:relative;
    }
    .hero-glow{
      position:absolute;top:-100px;left:50%;transform:translateX(-50%);
      width:900px;height:500px;
      background:radial-gradient(ellipse,rgba(0,200,255,0.1) 0%,rgba(112,64,255,0.06) 45%,transparent 70%);
      pointer-events:none;
    }
    .badge{
      display:inline-flex;align-items:center;gap:8px;
      padding:5px 14px;border:1px solid rgba(0,200,255,0.3);
      background:rgba(0,200,255,0.06);color:var(--cyan);
      font-family:var(--mono);font-size:0.65rem;letter-spacing:3px;text-transform:uppercase;
      margin-bottom:24px;
    }
    .badge .dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 10px rgba(0,255,136,0.8);animation:blink 2s infinite;}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

    .hero h1{
      font-family:var(--head);
      font-size:clamp(2.5rem,6vw,5rem);
      font-weight:900;line-height:1;letter-spacing:-1px;
      margin-bottom:20px;
    }
    .hero h1 .glitch{
      color:var(--cyan);
      text-shadow:0 0 40px rgba(0,200,255,0.5);
      position:relative;
      animation:glitch 10s infinite;
    }
    @keyframes glitch{
      0%,93%,100%{transform:translate(0)}
      94%{transform:translate(-3px,1px)}
      95%{transform:translate(3px,-1px)}
      96%{transform:translate(-2px,2px)}
    }
    .hero h1 .accent{color:var(--yellow);text-shadow:0 0 30px rgba(255,208,96,0.4);}

    .hero-sub{color:var(--muted);font-size:1.15rem;max-width:55ch;margin:0 auto 36px;line-height:1.6;}
    .hero-sub strong{color:var(--cyan);}

    .hero-stats{display:flex;gap:2.5rem;justify-content:center;flex-wrap:wrap;margin-bottom:36px;}
    .stat{text-align:center;}
    .stat-num{
      font-family:var(--head);font-size:2.4rem;font-weight:900;
      color:var(--cyan);text-shadow:0 0 20px rgba(0,200,255,0.5);
      display:block;line-height:1;
    }
    .stat-lbl{font-family:var(--mono);font-size:0.6rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:4px;}

    .hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
    .btn{
      font-family:var(--head);font-size:0.7rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;
      padding:12px 28px;cursor:pointer;transition:.2s;display:inline-block;
    }
    .btn-primary{
      background:linear-gradient(135deg,var(--cyan),var(--purple));
      color:#000;border:none;
      clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);
      box-shadow:0 0 30px rgba(0,200,255,0.3);
    }
    .btn-primary:hover{box-shadow:0 0 50px rgba(0,200,255,0.5);filter:brightness(1.1);}
    .btn-outline{background:transparent;color:var(--cyan);border:1px solid var(--border2);}
    .btn-outline:hover{background:var(--cyan-dim);box-shadow:0 0 20px rgba(0,200,255,0.15);}

    /* ── SECTION ── */
    section{padding:64px 0;position:relative;z-index:2;}
    section.alt{background:rgba(0,200,255,0.02);}

    .sec-tag{font-family:var(--mono);font-size:0.6rem;letter-spacing:4px;color:var(--magenta);text-transform:uppercase;display:block;margin-bottom:8px;}
    .sec-title{font-family:var(--head);font-size:clamp(1.6rem,3.5vw,2.6rem);font-weight:900;color:#fff;margin-bottom:12px;}
    .sec-title .c{color:var(--cyan);text-shadow:0 0 20px rgba(0,200,255,0.4);}
    .sec-title .g{color:var(--green);text-shadow:0 0 20px rgba(0,255,136,0.4);}
    .sec-title .y{color:var(--yellow);text-shadow:0 0 20px rgba(255,208,96,0.4);}
    .sec-title .p{color:var(--purple);text-shadow:0 0 20px rgba(112,64,255,0.4);}
    .sec-desc{color:var(--muted);font-size:1rem;max-width:55ch;}
    .sec-head{margin-bottom:40px;}

    /* CYBER DIVIDER */
    .cyber-line{height:1px;background:linear-gradient(90deg,transparent,var(--cyan),var(--purple),transparent);opacity:0.25;margin:0;}

    /* ── PATH ── */
    .path-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
    .path-card{
      background:var(--card);border:1px solid var(--border);
      padding:24px 20px;position:relative;transition:.3s;
      clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));
    }
    .path-card::before{content:'';position:absolute;inset:0;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));background:linear-gradient(135deg,rgba(0,200,255,0.03),transparent);pointer-events:none;}
    .path-card:hover{transform:translateY(-4px);}
    .path-card.r1{border-color:rgba(0,255,136,0.25);} .path-card.r1:hover{border-color:var(--green);box-shadow:0 8px 30px rgba(0,255,136,0.1);}
    .path-card.r2{border-color:rgba(0,200,255,0.25);} .path-card.r2:hover{border-color:var(--cyan);box-shadow:0 8px 30px rgba(0,200,255,0.1);}
    .path-card.r3{border-color:rgba(255,208,96,0.25);} .path-card.r3:hover{border-color:var(--yellow);box-shadow:0 8px 30px rgba(255,208,96,0.1);}
    .path-card.r4{border-color:rgba(255,0,128,0.25);} .path-card.r4:hover{border-color:var(--magenta);box-shadow:0 8px 30px rgba(255,0,128,0.1);}

    .rank-tag{font-family:var(--mono);font-size:0.55rem;letter-spacing:3px;text-transform:uppercase;margin-bottom:6px;}
    .r1 .rank-tag{color:var(--green);} .r2 .rank-tag{color:var(--cyan);} .r3 .rank-tag{color:var(--yellow);} .r4 .rank-tag{color:var(--magenta);}
    .rank-name{font-family:var(--head);font-size:1.3rem;font-weight:900;color:#fff;margin-bottom:4px;}
    .rank-time{font-family:var(--mono);font-size:0.65rem;color:var(--muted);margin-bottom:16px;}
    .rank-skills{list-style:none;}
    .rank-skills li{font-size:0.85rem;color:var(--text);padding:4px 0;padding-left:16px;position:relative;border-bottom:1px solid rgba(255,255,255,0.04);}
    .rank-skills li::before{content:'▸';position:absolute;left:0;font-size:0.65rem;}
    .r1 .rank-skills li::before{color:var(--green);} .r2 .rank-skills li::before{color:var(--cyan);} .r3 .rank-skills li::before{color:var(--yellow);} .r4 .rank-skills li::before{color:var(--magenta);}

    /* ── MODULES ── */
    .mods-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
    .mod{
      background:var(--card);border:1px solid var(--border);
      padding:22px;position:relative;overflow:hidden;transition:.3s;
    }
    .mod::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;transition:height .3s;}
    .mod.beg::before{background:linear-gradient(var(--green),transparent);}
    .mod.int::before{background:linear-gradient(var(--cyan),transparent);}
    .mod.adv::before{background:linear-gradient(var(--magenta),transparent);}
    .mod.beg:hover{border-color:rgba(0,255,136,0.35);box-shadow:0 8px 40px rgba(0,255,136,0.06);}
    .mod.int:hover{border-color:rgba(0,200,255,0.35);box-shadow:0 8px 40px rgba(0,200,255,0.06);}
    .mod.adv:hover{border-color:rgba(255,0,128,0.35);box-shadow:0 8px 40px rgba(255,0,128,0.06);}
    .mod:hover{transform:translateY(-3px);}
    .mod-top{display:flex;align-items:flex-start;gap:12px;margin-bottom:12px;}
    .mod-n{font-family:var(--head);font-size:1.8rem;font-weight:900;opacity:.15;line-height:1;}
    .beg .mod-n{color:var(--green);} .int .mod-n{color:var(--cyan);} .adv .mod-n{color:var(--magenta);}
    .mod-badge{font-family:var(--mono);font-size:0.5rem;letter-spacing:2px;text-transform:uppercase;padding:2px 7px;display:inline-block;margin-bottom:5px;}
    .beg .mod-badge{background:rgba(0,255,136,0.08);color:var(--green);border:1px solid rgba(0,255,136,0.25);}
    .int .mod-badge{background:rgba(0,200,255,0.08);color:var(--cyan);border:1px solid rgba(0,200,255,0.25);}
    .adv .mod-badge{background:rgba(255,0,128,0.08);color:var(--magenta);border:1px solid rgba(255,0,128,0.25);}
    .mod h3{font-family:var(--head);font-size:0.9rem;font-weight:700;color:#fff;line-height:1.3;}
    .mod p{font-size:0.85rem;color:var(--muted);line-height:1.55;margin-bottom:14px;}
    .mod-topics{list-style:none;}
    .mod-topics li{font-family:var(--mono);font-size:0.7rem;color:var(--text);padding:3px 0;padding-left:18px;position:relative;border-bottom:1px solid rgba(255,255,255,0.04);}
    .mod-topics li::before{content:'//';position:absolute;left:0;font-size:0.6rem;}
    .beg .mod-topics li::before{color:var(--green);} .int .mod-topics li::before{color:var(--cyan);} .adv .mod-topics li::before{color:var(--magenta);}
    .mod-wide{grid-column:1/-1;display:grid;grid-template-columns:auto 1fr;gap:20px;align-items:center;}

    /* ── INDICATORS ── */
    .ind-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
    .ind{background:var(--card);border:1px solid var(--border);padding:18px;transition:.3s;position:relative;overflow:hidden;}
    .ind:hover{border-color:var(--border2);box-shadow:0 4px 24px rgba(0,200,255,0.08);transform:translateY(-2px);}
    .ind::after{content:'';position:absolute;bottom:0;right:0;width:50px;height:50px;border-top:1px solid rgba(0,200,255,0.08);border-left:1px solid rgba(0,200,255,0.08);}
    .ind-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
    .ind-name{font-family:var(--head);font-size:1.1rem;font-weight:900;color:var(--cyan);text-shadow:0 0 10px rgba(0,200,255,0.3);}
    .ind-type{font-family:var(--mono);font-size:0.55rem;letter-spacing:2px;color:var(--purple);border:1px solid rgba(112,64,255,0.3);padding:2px 6px;}
    .ind-desc{font-size:0.82rem;color:var(--muted);line-height:1.55;margin-bottom:10px;}
    .ind-set{font-family:var(--mono);font-size:0.7rem;color:var(--yellow);background:rgba(255,208,96,0.05);border:1px solid rgba(255,208,96,0.12);padding:6px 10px;}

    /* ── PATTERNS ── */
    .pat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;}
    .pat{background:var(--card);border:1px solid var(--border);padding:16px;text-align:center;transition:.3s;}
    .pat:hover{transform:translateY(-3px);border-color:var(--border2);}
    .pat.bull{border-top:2px solid var(--green);} .pat.bear{border-top:2px solid var(--red);} .pat.cont{border-top:2px solid var(--yellow);}
    .pat-sig{font-family:var(--mono);font-size:0.55rem;letter-spacing:3px;text-transform:uppercase;margin-bottom:6px;}
    .bull .pat-sig{color:var(--green);} .bear .pat-sig{color:var(--red);} .cont .pat-sig{color:var(--yellow);}
    .pat-chart{height:75px;display:flex;align-items:flex-end;justify-content:center;gap:2px;margin:10px 0;}
    .c{width:7px;border-radius:1px;}
    .pat-name{font-family:var(--head);font-size:0.8rem;font-weight:700;color:#fff;margin-bottom:5px;}
    .pat p{font-size:0.78rem;color:var(--muted);line-height:1.4;}

    /* ── RESOURCES ── */
    .res-tabs{display:flex;gap:0;margin-bottom:28px;border-bottom:1px solid var(--border);}
    .rtab{
      font-family:var(--mono);font-size:0.65rem;letter-spacing:2px;text-transform:uppercase;
      padding:10px 20px;background:transparent;border:none;color:var(--muted);cursor:pointer;transition:.2s;
      border-bottom:2px solid transparent;margin-bottom:-1px;
    }
    .rtab.on,.rtab:hover{color:var(--cyan);border-bottom-color:var(--cyan);}
    .tab{display:none;} .tab.on{display:block;}

    .res-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
    .res{
      background:var(--card);border:1px solid var(--border);
      padding:16px;display:flex;gap:12px;align-items:flex-start;
      transition:.3s;text-decoration:none;
    }
    .res:hover{border-color:var(--border2);transform:translateX(3px);box-shadow:0 4px 20px rgba(0,200,255,0.06);}
    .res-ico{width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;border:1px solid var(--border);background:var(--cyan-dim);flex-shrink:0;}
    .res-name{font-family:var(--head);font-size:0.8rem;font-weight:700;color:#fff;margin-bottom:3px;}
    .res-type{font-family:var(--mono);font-size:0.55rem;letter-spacing:2px;color:var(--purple);margin-bottom:6px;text-transform:uppercase;}
    .res-desc{font-size:0.8rem;color:var(--muted);line-height:1.5;}
    .lvl{font-family:var(--mono);font-size:0.55rem;letter-spacing:1px;padding:2px 7px;margin-top:6px;display:inline-block;}
    .lvl.b{background:rgba(0,255,136,0.07);color:var(--green);border:1px solid rgba(0,255,136,0.2);}
    .lvl.i{background:rgba(0,200,255,0.07);color:var(--cyan);border:1px solid rgba(0,200,255,0.2);}
    .lvl.a{background:rgba(255,0,128,0.07);color:var(--magenta);border:1px solid rgba(255,0,128,0.2);}
    .lvl.all{background:rgba(255,208,96,0.07);color:var(--yellow);border:1px solid rgba(255,208,96,0.2);}

    /* ── CALCULATOR ── */
    .calc-wrap{
      max-width:680px;margin:0 auto;
      background:var(--card);border:1px solid var(--border2);
      padding:36px;position:relative;overflow:hidden;
    }
    .calc-wrap::before{content:'';position:absolute;top:0;left:0;width:100%;height:3px;background:linear-gradient(90deg,var(--cyan),var(--purple),var(--magenta));}
    .calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;}
    .cfield label{display:block;font-family:var(--mono);font-size:0.6rem;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:6px;}
    .cfield input{
      width:100%;background:rgba(0,200,255,0.04);border:1px solid var(--border);
      color:var(--cyan);font-family:var(--mono);font-size:0.95rem;
      padding:10px 14px;outline:none;transition:.2s;
    }
    .cfield input:focus{border-color:var(--cyan);box-shadow:0 0 15px rgba(0,200,255,0.12);}
    .calc-btn{
      width:100%;font-family:var(--head);font-size:0.75rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;
      padding:14px;background:linear-gradient(90deg,var(--cyan),var(--purple));
      border:none;color:#000;cursor:pointer;transition:.2s;margin-top:4px;
    }
    .calc-btn:hover{opacity:.85;box-shadow:0 0 30px rgba(0,200,255,0.3);}
    .calc-out{
      background:rgba(0,200,255,0.04);border:1px solid rgba(0,200,255,0.2);
      padding:20px;text-align:center;margin-top:18px;display:none;
    }
    .calc-out-lbl{font-family:var(--mono);font-size:0.6rem;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:6px;}
    .calc-out-val{font-family:var(--head);font-size:2.2rem;font-weight:900;color:var(--cyan);text-shadow:0 0 20px rgba(0,200,255,0.4);}
    .calc-out-sub{font-size:0.82rem;color:var(--muted);margin-top:6px;}

    /* ── QUIZ ── */
    .quiz-wrap{
      max-width:680px;margin:0 auto;
      background:var(--card);border:1px solid var(--border);
      padding:32px;position:relative;
    }
    .quiz-q{font-family:var(--head);font-size:0.95rem;font-weight:700;color:#fff;margin-bottom:20px;line-height:1.4;}
    .quiz-opts{display:grid;gap:8px;}
    .qopt{
      background:rgba(255,255,255,0.03);border:1px solid var(--border);
      padding:12px 18px;font-family:var(--sans);font-size:0.9rem;color:var(--muted);
      cursor:pointer;transition:.2s;text-align:left;
    }
    .qopt:hover{border-color:rgba(0,200,255,0.35);color:var(--cyan);background:var(--cyan-dim);}
    .qopt.ok{border-color:rgba(0,255,136,0.5)!important;background:rgba(0,255,136,0.08)!important;color:var(--green)!important;}
    .qopt.no{border-color:rgba(255,64,96,0.5)!important;background:rgba(255,64,96,0.07)!important;color:var(--red)!important;}
    .qfeed{margin-top:14px;padding:12px 16px;font-family:var(--mono);font-size:0.72rem;display:none;line-height:1.6;}
    .qfeed.show{display:block;}
    .qfeed.ok{background:rgba(0,255,136,0.06);border:1px solid rgba(0,255,136,0.25);color:var(--green);}
    .qfeed.no{background:rgba(255,64,96,0.06);border:1px solid rgba(255,64,96,0.25);color:var(--red);}
    .quiz-nav{display:flex;justify-content:space-between;align-items:center;margin-top:20px;}
    .quiz-prog{font-family:var(--mono);font-size:0.65rem;color:var(--muted);letter-spacing:2px;}

    /* ── GLOSSARY ── */
    .glos-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
    .glos{background:var(--card);border:1px solid var(--border);padding:14px;transition:.2s;}
    .glos:hover{border-color:var(--border2);}
    .glos-term{font-family:var(--mono);font-size:0.75rem;color:var(--cyan);text-shadow:0 0 8px rgba(0,200,255,0.3);margin-bottom:6px;font-weight:700;}
    .glos-def{font-size:0.8rem;color:var(--muted);line-height:1.5;}

    /* ── FOOTER ── */
    footer{
      max-width:var(--max);margin:60px auto 0;padding:30px 24px 48px;
      border-top:1px solid var(--border);
      display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px;
      color:var(--muted);font-size:0.8rem;position:relative;z-index:2;
    }
    .foot-logo{font-family:var(--head);font-size:0.9rem;font-weight:900;color:var(--cyan);text-shadow:0 0 15px rgba(0,200,255,0.4);}
    .foot-links{display:flex;gap:20px;}
    .foot-links a{font-family:var(--mono);font-size:0.62rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);transition:.2s;}
    .foot-links a:hover{color:var(--cyan);}

    /* ── TERMINAL ── */
    .terminal{background:#000;border:1px solid rgba(0,200,255,0.25);padding:18px;position:relative;box-shadow:0 0 20px rgba(0,200,255,0.05);margin:28px 0;}
    .terminal::before{content:'● ● ●';position:absolute;top:.7rem;left:1rem;font-size:.45rem;color:var(--muted);letter-spacing:4px;}
    .term-body{margin-top:.5rem;line-height:2;}
    .tp{color:var(--cyan);} .tc{color:var(--green);} .to{color:var(--muted);padding-left:1rem;}

    /* ── FADE ── */
    .fi{opacity:0;transform:translateY(18px);transition:opacity .5s ease,transform .5s ease;}
    .fi.vis{opacity:1;transform:none;}

    /* ── RESPONSIVE ── */
    @media(max-width:900px){
      .path-grid,.mods-grid,.ind-grid,.pat-grid,.res-grid,.glos-grid{grid-template-columns:1fr;}
      .calc-grid{grid-template-columns:1fr;}
      .navlinks{display:none;}
      .hamburger{display:flex;}
      .pat-grid{grid-template-columns:repeat(2,1fr);}
      .hero-stats{gap:1.5rem;}
    }
  </style>
</head>
