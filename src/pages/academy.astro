      </div>

      <div class="pat bull fi">
        <div class="pat-sig">▲ Bullish</div>
        <div class="pat-chart">
          <div class="c" style="height:18px;background:var(--green)"></div>
          <div class="c" style="height:26px;background:var(--green)"></div>
          <div class="c" style="height:34px;background:var(--green)"></div>
