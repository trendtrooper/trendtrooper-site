---
// TrendTrooper Academy — src/pages/academy.astro
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>TrendTrooper Academy — Learn to Trade Systematically</title>
  <meta name="description" content="Master technical analysis, risk management, and systematic trading. Free education from TrendTrooper." />
  <meta name="theme-color" content="#0b1220" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root{
      --bg:#070e1c;
      --surface:#0c1526;
      --card:#0f1b33;
      --card2:#111e38;
      --muted:#7a96bb;
      --muted2:#4a6490;
      --text:#ddeeff;
      --text2:#b8d0ee;
      --accent:#6ee7ff;
      --accent2:#a78bfa;
      --green:#22d673;
      --red:#ff5c6a;
      --amber:#f59e0b;
      --border:rgba(110,231,255,.10);
      --border2:rgba(255,255,255,.06);
      --shadow:0 24px 80px rgba(0,0,0,.55);
      --r:16px;
      --max:1160px;
      --mono:'JetBrains Mono',ui-monospace,monospace;
      --sans:'Space Grotesk',ui-sans-serif,system-ui,sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{
      font-family:var(--sans);
      color:var(--text);
      background:var(--bg);
      line-height:1.5;
      min-height:100vh;
    }
    a{color:inherit;text-decoration:none}
    header{
      position:sticky;top:0;z-index:100;
      background:rgba(7,14,28,.88);
      backdrop-filter:blur(16px);
      border-bottom:1px solid var(--border2);
    }
    .nav{
      max-width:var(--max);margin:0 auto;padding:14px 24px;
      display:flex;align-items:center;justify-content:space-between;gap:20px;
    }
    .brand{display:flex;align-items:center;gap:12px;font-weight:700;font-size:15px}
    .logo{
      width:32px;height:32px;border-radius:10px;flex:0 0 auto;
      background:linear-gradient(135deg,var(--accent),var(--accent2));
      position:relative;
    }
    .logo:after{
      content:"";position:absolute;inset:8px;
      border:1.5px solid rgba(255,255,255,.5);border-radius:7px;transform:rotate(8deg);
    }
    .brand-sub{font-size:11px;color:var(--muted);font-weight:500;letter-spacing:.3px}
    .navlinks{display:flex;gap:22px;color:var(--muted);font-size:13.5px;font-weight:500}
    .navlinks a:hover{color:var(--text)}
    .navlinks a.active{color:var(--accent)}
    .btn{
      display:inline-flex;align-items:center;justify-content:center;gap:8px;
      padding:9px 18px;border-radius:12px;font-weight:600;font-size:13.5px;
      border:1px solid var(--border2);background:rgba(255,255,255,.05);
      color:var(--text);cursor:pointer;transition:.15s;font-family:var(--sans);
    }
    .btn:hover{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.12)}
    .btn.primary{
      background:linear-gradient(135deg,var(--accent),var(--accent2));
      border:none;color:#070e1c;font-weight:700;
      box-shadow:0 8px 30px rgba(110,231,255,.18);
    }
    .btn.primary:hover{filter:brightness(1.06)}
    .hero-wrap{
      position:relative;overflow:hidden;
      padding:80px 24px 60px;
      max-width:var(--max);margin:0 auto;
      text-align:center;
    }
    .hero-glow{
      position:absolute;
      top:-120px;left:50%;transform:translateX(-50%);
      width:900px;height:500px;
      background:radial-gradient(ellipse, rgba(110,231,255,.12) 0%, rgba(167,139,250,.08) 45%, transparent 70%);
      pointer-events:none;
    }
    .badge{
      display:inline-flex;align-items:center;gap:8px;
      padding:6px 14px;border-radius:999px;
      border:1px solid rgba(110,231,255,.25);
      background:rgba(110,231,255,.07);
      color:var(--accent);font-size:12.5px;font-weight:600;
      margin-bottom:22px;letter-spacing:.3px;
    }
    .badge .pulse{
      width:7px;height:7px;border-radius:50%;
      background:var(--green);
      box-shadow:0 0 12px rgba(34,214,115,.6);
      animation:pulse 2s ease-in-out infinite;
    }
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
    h1{
      font-size:clamp(36px,5vw,62px);
      font-weight:700;line-height:1.05;letter-spacing:-.8px;
      margin-bottom:18px;
    }
    h1 .grad{
      background:linear-gradient(90deg,var(--accent),var(--accent2));
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    }
    .hero-sub{
      color:var(--muted);font-size:17px;max-width:58ch;margin:0 auto 32px;line-height:1.6;
    }
    .hero-cta{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
    .stats{
      max-width:var(--max);margin:0 auto 10px;padding:0 24px;
      display:grid;grid-template-columns:repeat(4,1fr);gap:14px;
    }
    .stat-card{
      padding:18px 20px;border-radius:var(--r);
      border:1px solid var(--border2);
      background:var(--card);
      text-align:center;
    }
    .stat-card .val{font-size:26px;font-weight:700;color:var(--accent);line-height:1}
    .stat-card .lbl{font-size:12px;color:var(--muted);margin-top:5px;font-weight:500}
    .section{max-width:var(--max);margin:0 auto;padding:48px 24px 0}
    .sec-head{
      display:flex;align-items:baseline;justify-content:space-between;
      margin-bottom:20px;gap:16px;
    }
    .sec-head h2{font-size:20px;font-weight:700}
    .sec-head .sec-sub{color:var(--muted);font-size:13.5px}
    .tag-line{display:flex;align-items:center;gap:10px;margin-bottom:10px}
    .tag-line span{width:28px;height:2px;border-radius:1px;background:linear-gradient(90deg,var(--accent),var(--accent2))}
    .modules{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .mod-card{
      border-radius:var(--r);border:1px solid var(--border2);
      background:var(--card);padding:22px;
      position:relative;overflow:hidden;
      transition:.2s;cursor:pointer;
    }
    .mod-card:hover{transform:translateY(-3px);border-color:rgba(110,231,255,.25);box-shadow:0 16px 50px rgba(0,0,0,.4)}
    .mod-card::before{
      content:"";position:absolute;top:0;left:0;right:0;height:2px;
      background:linear-gradient(90deg,var(--accent),var(--accent2));
      opacity:0;transition:.2s;
    }
    .mod-card:hover::before{opacity:1}
    .mod-num{font-size:11px;font-weight:700;color:var(--accent);letter-spacing:1px;margin-bottom:12px;font-family:var(--mono)}
    .mod-icon{
      width:42px;height:42px;border-radius:12px;
      background:rgba(110,231,255,.10);border:1px solid rgba(110,231,255,.18);
      display:flex;align-items:center;justify-content:center;
      margin-bottom:14px;font-size:20px;
    }
    .mod-card h3{font-size:15.5px;font-weight:700;margin-bottom:8px}
    .mod-card p{color:var(--muted);font-size:13px;line-height:1.55}
    .mod-meta{display:flex;gap:12px;margin-top:14px}
    .mod-pill{
      font-size:11px;font-weight:600;padding:4px 10px;border-radius:999px;
      border:1px solid var(--border2);color:var(--muted2);font-family:var(--mono);
    }
    .mod-pill.green{border-color:rgba(34,214,115,.25);color:var(--green);background:rgba(34,214,115,.07)}
    .mod-pill.blue{border-color:rgba(110,231,255,.25);color:var(--accent);background:rgba(110,231,255,.07)}
    .indicator-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
    .ind-card{
      border-radius:var(--r);border:1px solid var(--border2);
      background:var(--card);padding:18px 20px;
      display:grid;grid-template-columns:auto 1fr auto;gap:14px;align-items:start;
    }
    .ind-icon{
      width:38px;height:38px;border-radius:10px;flex:0 0 auto;
      display:flex;align-items:center;justify-content:center;font-size:17px;
    }
    .ind-icon.mo{background:rgba(110,231,255,.10);border:1px solid rgba(110,231,255,.18)}
    .ind-icon.os{background:rgba(167,139,250,.10);border:1px solid rgba(167,139,250,.18)}
    .ind-icon.vl{background:rgba(34,214,115,.10);border:1px solid rgba(34,214,115,.18)}
    .ind-icon.tr{background:rgba(245,158,11,.10);border:1px solid rgba(245,158,11,.18)}
    .ind-name{font-size:14.5px;font-weight:700;margin-bottom:4px}
    .ind-desc{color:var(--muted);font-size:12.5px;line-height:1.5}
    .ind-signal{display:flex;flex-direction:column;gap:5px;align-items:flex-end}
    .signal-bull{font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px;background:rgba(34,214,115,.12);color:var(--green);border:1px solid rgba(34,214,115,.25)}
    .signal-bear{font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px;background:rgba(255,92,106,.12);color:var(--red);border:1px solid rgba(255,92,106,.25)}
    .signal-neut{font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px;background:rgba(245,158,11,.10);color:var(--amber);border:1px solid rgba(245,158,11,.25)}
    .chart-section{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);overflow:hidden}
    .chart-head{
      padding:16px 20px;border-bottom:1px solid var(--border2);
      display:flex;align-items:center;justify-content:space-between;
    }
    .chart-head h3{font-size:14.5px;font-weight:700}
    .chart-body{padding:20px}
    .chart-tabs{display:flex;gap:6px;margin-bottom:18px;flex-wrap:wrap}
    .ctab{
      padding:7px 14px;border-radius:10px;font-size:12.5px;font-weight:600;
      border:1px solid var(--border2);color:var(--muted);cursor:pointer;
      background:transparent;font-family:var(--sans);transition:.15s;
    }
    .ctab:hover{color:var(--text);background:rgba(255,255,255,.05)}
    .ctab.active{background:rgba(110,231,255,.12);border-color:rgba(110,231,255,.30);color:var(--accent)}
    .patterns{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
    .pat-card{
      border-radius:var(--r);border:1px solid var(--border2);
      background:var(--card);padding:16px;text-align:center;
      transition:.2s;cursor:pointer;
    }
    .pat-card:hover{border-color:rgba(110,231,255,.3);transform:translateY(-2px)}
    .pat-img{
      width:100%;aspect-ratio:16/9;border-radius:10px;
      background:var(--card2);margin-bottom:10px;
      display:flex;align-items:center;justify-content:center;overflow:hidden;
    }
    .pat-card h4{font-size:13px;font-weight:700;margin-bottom:4px}
    .pat-card p{font-size:11.5px;color:var(--muted)}
    .candle-demo{width:100%;height:80px}
    .glossary{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    .gloss-item{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);padding:16px}
    .gloss-term{font-family:var(--mono);font-size:12px;font-weight:600;color:var(--accent);margin-bottom:6px}
    .gloss-def{color:var(--muted);font-size:12.5px;line-height:1.5}
    .risk-calc{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);overflow:hidden}
    .calc-head{padding:14px 20px;border-bottom:1px solid var(--border2);font-size:14px;font-weight:700;display:flex;align-items:center;gap:10px}
    .calc-body{padding:20px;display:grid;grid-template-columns:1fr 1fr;gap:16px}
    .inp-group label{display:block;font-size:12px;color:var(--muted);margin-bottom:6px;font-weight:600;letter-spacing:.3px}
    .inp-group input{
      width:100%;padding:10px 14px;border-radius:10px;
      border:1px solid var(--border2);background:rgba(255,255,255,.04);
      color:var(--text);font-size:14px;font-family:var(--sans);outline:none;transition:.15s;
    }
    .inp-group input:focus{border-color:rgba(110,231,255,.4);background:rgba(110,231,255,.04)}
    .calc-result{
      grid-column:1/-1;padding:14px 16px;border-radius:10px;
      background:rgba(110,231,255,.07);border:1px solid rgba(110,231,255,.2);
      display:flex;justify-content:space-between;align-items:center;
    }
    .calc-result .res-label{font-size:12.5px;color:var(--muted);font-weight:600}
    .calc-result .res-val{font-size:20px;font-weight:700;color:var(--accent);font-family:var(--mono)}
    .ma-compare{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px}
    .ma-box{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);padding:18px}
    .ma-box h4{font-size:13.5px;font-weight:700;margin-bottom:8px}
    .ma-box p{color:var(--muted);font-size:12.5px;line-height:1.55;margin-bottom:10px}
    .ma-tag{display:inline-block;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700}
    .ma-tag.fast{background:rgba(110,231,255,.10);color:var(--accent);border:1px solid rgba(110,231,255,.25)}
    .ma-tag.slow{background:rgba(167,139,250,.10);color:var(--accent2);border:1px solid rgba(167,139,250,.25)}
    .quiz{border-radius:var(--r);border:1px solid var(--border2);background:var(--card);padding:24px}
    .quiz h3{font-size:15px;font-weight:700;margin-bottom:16px}
    .quiz-q{font-size:14px;color:var(--text2);margin-bottom:14px;line-height:1.55}
    .quiz-opts{display:grid;gap:8px}
    .quiz-opt{
      padding:12px 16px;border-radius:10px;border:1px solid var(--border2);
      background:rgba(255,255,255,.03);cursor:pointer;font-size:13.5px;
      transition:.15s;color:var(--text2);font-family:var(--sans);text-align:left;width:100%;
    }
    .quiz-opt:hover{border-color:rgba(110,231,255,.3);background:rgba(110,231,255,.05);color:var(--text)}
    .quiz-opt.correct{border-color:rgba(34,214,115,.5)!important;background:rgba(34,214,115,.10)!important;color:var(--green)!important}
    .quiz-opt.wrong{border-color:rgba(255,92,106,.5)!important;background:rgba(255,92,106,.08)!important;color:var(--red)!important}
    .quiz-feedback{margin-top:14px;padding:12px 16px;border-radius:10px;font-size:13px;display:none}
    .quiz-feedback.show{display:block}
    .quiz-feedback.ok{background:rgba(34,214,115,.08);border:1px solid rgba(34,214,115,.25);color:var(--green)}
    .quiz-feedback.no{background:rgba(255,92,106,.08);border:1px solid rgba(255,92,106,.25);color:var(--red)}
    .chart-container{position:relative;width:100%;height:220px}
    footer{
      max-width:var(--max);margin:60px auto 0;padding:30px 24px 48px;
      border-top:1px solid var(--border2);
      display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px;
      color:var(--muted2);font-size:13px;
    }
    .foot-links{display:flex;gap:18px}
    .foot-links a:hover{color:var(--muted)}
    @keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}
    .fade-in{animation:fadeUp .5s ease both}
    .fade-in-2{animation:fadeUp .5s ease .1s both}
    .fade-in-3{animation:fadeUp .5s ease .2s both}
    @media(max-width:900px){
      .modules,.indicator-grid,.patterns,.glossary{grid-template-columns:1fr}
      .stats{grid-template-columns:repeat(2,1fr)}
      .ma-compare,.calc-body{grid-template-columns:1fr}
      .navlinks{display:none}
      .patterns{grid-template-columns:repeat(2,1fr)}
    }
  </style>
</head>
<body>

<header>
  <div class="nav">
    <div class="brand">
      <div class="logo" aria-hidden="true"></div>
      <div>
        <div>TrendTrooper</div>
        <div class="brand-sub">ACADEMY</div>
      </div>
    </div>
    <nav class="navlinks" aria-label="Primary">
      <a href="/">Home</a>
      <a href="#modules" class="active">Modules</a>
      <a href="#indicators">Indicators</a>
      <a href="#patterns">Patterns</a>
      <a href="#tools">Tools</a>
      <a href="#glossary">Glossary</a>
    </nav>
    <div style="display:flex;gap:10px;align-items:center">
      <a class="btn" href="/">← Back to HQ</a>
      <a class="btn primary" href="#modules">Start Learning</a>
    </div>
  </div>
</header>

<main>
  <div class="hero-wrap">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="badge fade-in"><span class="pulse"></span> 7 Free Modules • No Account Required</div>
    <h1 class="fade-in-2">Trade with <span class="grad">structure</span>.<br>Not hope.</h1>
    <p class="hero-sub fade-in-3">From reading a candlestick to sizing a position — every concept you need to trade systematically, built into TrendTrooper's pipeline.</p>
    <div class="hero-cta fade-in-3">
      <a class="btn primary" href="#modules">Begin Module 1</a>
      <a class="btn" href="#tools">Jump to Risk Calculator</a>
    </div>
  </div>

  <div class="stats">
    <div class="stat-card"><div class="val">7</div><div class="lbl">Learning Modules</div></div>
    <div class="stat-card"><div class="val">24+</div><div class="lbl">Indicators Covered</div></div>
    <div class="stat-card"><div class="val">12</div><div class="lbl">Chart Patterns</div></div>
    <div class="stat-card"><div class="val">Free</div><div class="lbl">Forever. No Paywall.</div></div>
  </div>

  <div class="section" id="modules">
    <div class="tag-line"><span></span></div>
    <div class="sec-head">
      <h2>Learning Modules</h2>
      <span class="sec-sub">Work through these in order for best results</span>
    </div>
    <div class="modules">
      <div class="mod-card">
        <div class="mod-num">MODULE 01</div>
        <div class="mod-icon">📊</div>
        <h3>Market Structure Basics</h3>
        <p>Understand how markets move: order flow, price action, support & resistance, and the mechanics behind every candle.</p>
        <div class="mod-meta"><span class="mod-pill blue">9 topics</span><span class="mod-pill green">Beginner</span></div>
      </div>
      <div class="mod-card">
        <div class="mod-num">MODULE 02</div>
        <div class="mod-icon">📈</div>
        <h3>Technical Analysis</h3>
        <p>Read charts with precision. Identify trends, interpret Japanese candlesticks, and understand chart patterns used by professionals.</p>
        <div class="mod-meta"><span class="mod-pill blue">6 topics</span><span class="mod-pill green">Beginner</span></div>
      </div>
      <div class="mod-card">
        <div class="mod-num">MODULE 03</div>
        <div class="mod-icon">🛡️</div>
        <h3>Risk & Money Management</h3>
        <p>Protect your capital first. Learn position sizing, max daily loss rules, ATR-based stops, and drawdown control.</p>
        <div class="mod-meta"><span class="mod-pill blue">6 topics</span><span class="mod-pill" style="border-color:rgba(245,158,11,.3);color:var(--amber)">Intermediate</span></div>
      </div>
      <div class="mod-card">
        <div class="mod-num">MODULE 04</div>
        <div class="mod-icon">⚙️</div>
        <h3>Strategy Development</h3>
        <p>Build repeatable edge. Combine indicators, define entry/exit rules, backtest your logic, and avoid common pitfalls.</p>
        <div class="mod-meta"><span class="mod-pill blue">9 topics</span><span class="mod-pill" style="border-color:rgba(245,158,11,.3);color:var(--amber)">Intermediate</span></div>
      </div>
      <div class="mod-card">
        <div class="mod-num">MODULE 05</div>
        <div class="mod-icon">🧠</div>
        <h3>Trader Psychology</h3>
        <p>Your edge means nothing if your emotions override it. Learn to control fear, greed, and overtrading before they control you.</p>
        <div class="mod-meta"><span class="mod-pill blue">6 topics</span><span class="mod-pill" style="border-color:rgba(245,158,11,.3);color:var(--amber)">Intermediate</span></div>
      </div>
      <div class="mod-card">
        <div class="mod-num">MODULE 06</div>
        <div class="mod-icon">🤖</div>
        <h3>Automation & Signals</h3>
        <p>Connect TradingView alerts to execution. Understand webhooks, signal validation, and how TrendTrooper's pipeline works end-to-end.</p>
        <div class="mod-meta"><span class="mod-pill blue">8 topics</span><span class="mod-pill" style="border-color:rgba(255,92,106,.3);color:var(--red)">Advanced</span></div>
      </div>
      <div class="mod-card" style="grid-column:1/-1;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:20px;min-height:auto">
        <div style="display:flex;align-items:center;gap:14px">
          <div class="mod-icon" style="margin:0">💡</div>
          <div>
            <div class="mod-num" style="margin-bottom:4px">MODULE 07</div>
            <h3 style="margin-bottom:6px">Tips from Systematic Traders</h3>
            <p>Concrete lessons from real trading systems: what works, what blows accounts, and how to build sustainable discipline.</p>
          </div>
        </div>
        <div class="mod-meta" style="justify-content:flex-end">
          <span class="mod-pill blue">14 topics</span>
          <span class="mod-pill green">All Levels</span>
        </div>
      </div>
    </div>
  </div>

  <div class="section" id="indicators">
    <div class="tag-line"><span></span></div>
    <div class="sec-head">
      <h2>Technical Indicator Reference</h2>
      <span class="sec-sub">Key indicators used inside TrendTrooper strategies</span>
    </div>
    <div class="indicator-grid">
      <div class="ind-card">
        <div class="ind-icon mo">📊</div>
        <div>
          <div class="ind-name">EMA — Exponential Moving Average</div>
          <div class="ind-desc">Weights recent prices more heavily. Reacts faster to price changes. Common settings: EMA 9, 20, 50, 200. Used for trend direction and crossover signals.</div>
        </div>
        <div class="ind-signal"><span class="signal-bull">Trend</span></div>
      </div>
      <div class="ind-card">
        <div class="ind-icon os">📉</div>
        <div>
          <div class="ind-name">RSI — Relative Strength Index</div>
          <div class="ind-desc">Oscillates 0–100. Above 70 = overbought, below 30 = oversold. Default period: 14. TrendTrooper uses RSI to filter trades against exhausted momentum.</div>
        </div>
        <div class="ind-signal"><span class="signal-bear">Oscillator</span></div>
      </div>
      <div class="ind-card">
        <div class="ind-icon vl">📦</div>
        <div>
          <div class="ind-name">VWAP — Volume Weighted Avg Price</div>
          <div class="ind-desc">Average price weighted by volume for the session. Institutional benchmark. Price above VWAP = bullish bias. Resets daily. Critical for intraday signals.</div>
        </div>
        <div class="ind-signal"><span class="signal-bull">Intraday</span></div>
      </div>
      <div class="ind-card">
        <div class="ind-icon tr">🔥</div>
        <div>
          <div class="ind-name">ATR — Average True Range</div>
          <div class="ind-desc">Measures volatility, not direction. Used to calculate stop-loss distances and position size. TrendTrooper multiplies ATR × 1.5–2.5 for dynamic stops.</div>
        </div>
        <div class="ind-signal"><span class="signal-neut">Volatility</span></div>
      </div>
      <div class="ind-card">
        <div class="ind-icon mo" style="background:rgba(34,214,115,.1);border-color:rgba(34,214,115,.2)">〰️</div>
        <div>
          <div class="ind-name">MACD — Moving Average Convergence Divergence</div>
          <div class="ind-desc">Shows relationship between two EMAs (typically 12 and 26). Signal line = 9-period EMA of MACD. Histogram shows momentum strength and direction.</div>
        </div>
        <div class="ind-signal"><span class="signal-bull">Momentum</span></div>
      </div>
      <div class="ind-card">
        <div class="ind-icon os" style="background:rgba(255,92,106,.08);border-color:rgba(255,92,106,.2)">🎯</div>
        <div>
          <div class="ind-name">Bollinger Bands</div>
          <div class="ind-desc">20-period SMA with ±2 standard deviation bands. Price touching upper = extended. Lower = oversold. Band squeeze signals a volatility breakout ahead.</div>
        </div>
        <div class="ind-signal"><span class="signal-neut">Volatility</span></div>
      </div>
    </div>
  </div>

