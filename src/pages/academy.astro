<script>
document.addEventListener('DOMContentLoaded', function() {

  // ── YEAR ──
  document.getElementById('yr').textContent = new Date().getFullYear();

  // ── MOBILE MENU CLOSE ON LINK CLICK ──
  document.querySelectorAll('#ttMob a').forEach(function(a) {
    a.addEventListener('click', function() {
      document.getElementById('ttMob').classList.remove('open');
      document.getElementById('ttBurger').classList.remove('open');
    });
  });

  // ── TAB SWITCHER ──
  window.switchTab = function(id, btn) {
    document.querySelectorAll('.tab').forEach(function(t){ t.classList.remove('on'); });
    document.querySelectorAll('.rtab').forEach(function(b){ b.classList.remove('on'); });
    document.getElementById('tab-'+id).classList.add('on');
    btn.classList.add('on');
  };

  // ── POSITION CALCULATOR ──
  window.doCalc = function() {
    var acc=parseFloat(document.getElementById('acc').value);
    var riskPct=parseFloat(document.getElementById('risk').value);
    var entry=parseFloat(document.getElementById('entry').value);
    var stop=parseFloat(document.getElementById('stop').value);
    if(!acc||!riskPct||!entry||!stop){alert('Please fill in all fields.');return;}
    var riskAmt=acc*(riskPct/100);
    var dist=Math.abs(entry-stop);
    if(dist===0){alert('Entry and stop cannot be the same.');return;}
    var shares=Math.floor(riskAmt/dist);
    var actualRisk=(shares*dist).toFixed(2);
    var cost=(shares*entry).toLocaleString('en-US',{style:'currency',currency:'USD'});
    var el=document.getElementById('calcOut');
    el.style.display='block';
    document.getElementById('calcShares').textContent=shares.toLocaleString()+' shares';
    document.getElementById('calcInfo').textContent='Dollar risk: $'+actualRisk+' ('+riskPct+'%)  |  Position cost: '+cost+'  |  Stop distance: $'+dist.toFixed(2)+'/share';
  };

  // ── COUNTER ANIMATION ──
  function animateNum(el) {
    var target=parseInt(el.dataset.target);
    if(!target)return;
    var cur=0;var inc=target/50;
    var t=setInterval(function(){cur=Math.min(cur+inc,target);el.textContent=Math.round(cur);if(cur>=target)clearInterval(t);},30);
  }
  var heroObs=new IntersectionObserver(function(entries){
    if(entries[0].isIntersecting)document.querySelectorAll('[data-target]').forEach(animateNum);
  },{threshold:.5});
  var heroStats=document.querySelector('.hero-stats');
  if(heroStats)heroObs.observe(heroStats);

  // ── FADE-IN ON SCROLL ──
  var fadeObs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){if(e.isIntersecting)e.target.classList.add('vis');});
  },{threshold:.08});
  document.querySelectorAll('.fi').forEach(function(el){fadeObs.observe(el);});

  // ── COPY INDICATOR SETTINGS ──
  window.copyIndSetting = function(btn, text) {
    navigator.clipboard.writeText(text).then(function() {
      btn.textContent = '✓ Copied!';
      btn.classList.add('copied');
      setTimeout(function(){ btn.textContent = '📋 Copy'; btn.classList.remove('copied'); }, 1800);
    }).catch(function() {
      btn.textContent = '✓ Copied!';
      setTimeout(function(){ btn.textContent = '📋 Copy'; }, 1800);
    });
  };

  // ── MODULE PROGRESS TRACKING ──
  var TOTAL_MODS = 7;
  var completed = [];
  try { completed = JSON.parse(localStorage.getItem('tt_academy_progress') || '[]'); } catch(e){ completed=[]; }

  function saveProgress() {
    localStorage.setItem('tt_academy_progress', JSON.stringify(completed));
  }

  function updateProgressUI() {
    var n = completed.length;
    var pct = Math.round((n / TOTAL_MODS) * 100);
    // progress bar in modules section
    var lbl = document.getElementById('modProgressLabel');
    var fill = document.getElementById('modProgressFill');
    if(lbl) lbl.textContent = n + ' of ' + TOTAL_MODS + ' modules completed';
    if(fill) fill.style.width = pct + '%';
    // certificate section
    var certProg = document.getElementById('certProgText');
    var certFill = document.getElementById('certProgFill');
    if(certProg) certProg.textContent = n + ' / ' + TOTAL_MODS + ' modules complete';
    if(certFill) certFill.style.width = pct + '%';
    // unlock cert
    var certCard = document.getElementById('certCard');
    if(certCard) {
      if(n >= TOTAL_MODS) certCard.classList.add('unlocked');
      else certCard.classList.remove('unlocked');
    }
    // progress ring
    updateProgressRing(pct);
    // rank locked badges
    updateRankLocks();
  }

  function updateProgressRing(pct) {
    var ring = document.getElementById('heroRingFill');
    var ringPct = document.getElementById('heroRingPct');
    if(!ring) return;
    var circumference = 238.76;
    var offset = circumference - (pct / 100) * circumference;
    ring.style.strokeDashoffset = offset;
    if(ringPct) ringPct.textContent = pct + '%';
  }

  function updateRankLocks() {
    var n = completed.length;
    // Rank 2 locked if fewer than 2 completed
    var l2 = document.getElementById('rankLock2');
    if(l2) l2.style.display = n < 2 ? 'inline-block' : 'none';
    // Rank 3 locked if fewer than 4 completed
    var l3 = document.getElementById('rankLock3');
    if(l3) l3.style.display = n < 4 ? 'inline-block' : 'none';
    // Rank 4 locked if fewer than 6 completed
    var l4 = document.getElementById('rankLock4');
    if(l4) l4.style.display = n < 6 ? 'inline-block' : 'none';
  }

  function applyModuleStates() {
    for(var i = 1; i <= TOTAL_MODS; i++) {
      var modEl = document.getElementById('mod-'+i);
      var btn = modEl ? modEl.querySelector('.mark-complete-btn') : null;
      if(!modEl) continue;
      var isDone = completed.indexOf(i) !== -1;
      if(btn) {
        btn.textContent = isDone ? '✓ Completed' : 'Mark Complete ✓';
        if(isDone) btn.classList.add('done'); else btn.classList.remove('done');
      }
      // prerequisite lock visual (for adv/int modules, dim if fewer than 2 prior done)
      var badge = modEl.querySelector('.mod-badge');
      var level = badge ? badge.textContent.trim() : '';
      var isAdvanced = level === 'Advanced' || level === 'Intermediate';
      if(isAdvanced && completed.length < 2 && !isDone) {
        modEl.classList.add('locked');
      } else {
        modEl.classList.remove('locked');
      }
    }
  }

  window.toggleComplete = function(modNum) {
    var idx = completed.indexOf(modNum);
    if(idx === -1) completed.push(modNum); else completed.splice(idx, 1);
    saveProgress();
    applyModuleStates();
    updateProgressUI();
  };

  // init
  applyModuleStates();
  updateProgressUI();

  // ── GLOSSARY SEARCH ──
  var glossInput = document.getElementById('glossSearch');
  if(glossInput) {
    glossInput.addEventListener('input', function() {
      var val = this.value.toLowerCase().trim();
      document.querySelectorAll('#glosGrid .glos').forEach(function(g) {
        var term = (g.querySelector('.glos-term')||{}).textContent || '';
        var def  = (g.querySelector('.glos-def')||{}).textContent  || '';
        if(!val || term.toLowerCase().indexOf(val) !== -1 || def.toLowerCase().indexOf(val) !== -1) {
          g.classList.remove('hidden');
        } else {
          g.classList.add('hidden');
        }
      });
    });
  }

  // ── CERTIFICATE MODAL ──
  window.openCertModal = function() {
    document.getElementById('certDate').textContent = new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
    document.getElementById('certModalBg').classList.add('open');
  };
  window.closeCertModal = function() {
    document.getElementById('certModalBg').classList.remove('open');
  };

  // ── QUIZ ──
  var QS=[
    {q:"What does a higher high (HH) followed by a higher low (HL) indicate?",opts:["A downtrend","Sideways market","An uptrend","A reversal pattern"],ans:2,ex:"Higher highs and higher lows define an uptrend — buyers are in control and making consistent progress to the upside."},
    {q:"Account: $10,000. Risk: 1%. Entry: $50. Stop: $48. How many shares?",opts:["50 shares","100 shares","200 shares","500 shares"],ans:0,ex:"1% of $10,000 = $100 risk. Stop distance = $2. Shares = $100 ÷ $2 = 50 shares."},
    {q:"RSI reading of 28 on a daily chart typically suggests the asset is:",opts:["Overbought — consider shorting","Oversold — look for reversal signals","In a strong uptrend","At fair value"],ans:1,ex:"RSI below 30 = oversold conditions. Look for bullish divergence or reversal candles to confirm a potential bounce."},
    {q:"What is the primary purpose of the ATR indicator?",opts:["Identify trend direction","Measure momentum","Set dynamic stops based on volatility","Find divergences"],ans:2,ex:"ATR measures volatility. Multiplied by 1.5–2.5× it gives stop distances that adapt to current market conditions."},
    {q:"VWAP is most useful for which type of trader?",opts:["Long-term position traders","Swing traders holding weeks","Day traders and intraday traders","Crypto investors only"],ans:2,ex:"VWAP resets each day — it's the institutional intraday benchmark. Most relevant for day traders judging intraday bias."},
    {q:"A Head & Shoulders pattern signals:",opts:["Bullish continuation","Bearish reversal","Breakout to the upside","Neutral consolidation"],ans:1,ex:"Head & Shoulders is a bearish reversal pattern. Neckline break = confirmed reversal. Measure the head for price target."},
    {q:"Win rate: 45%. Average win: 2× average loss. Your system's expectancy is:",opts:["Negative — stop trading it","Breakeven","Positive — this is a valid edge","Impossible to determine"],ans:2,ex:"Expectancy = (0.45×2) − (0.55×1) = 0.90 − 0.55 = +0.35R. Positive over many trades = real edge."},
    {q:"'Thinking in probabilities' in trading psychology means:",opts:["Using only probabilistic indicators","Any single trade can lose while the edge plays out over many trades","Predicting direction with statistics","Trading only high-probability setups"],ans:1,ex:"Mark Douglas: even a 70% system loses 3 in 10. You cannot know which trades will win. Execute consistently and let statistics work."},
    {q:"Bollinger Band 'squeeze' signals:",opts:["A trend is ending","Volatility is contracting — big move incoming","The asset is overbought","Price at fair value"],ans:1,ex:"When bands tighten, volatility is contracting. This often precedes a significant move — though direction is not predetermined."},
    {q:"A 50% drawdown requires what % gain to return to breakeven?",opts:["50%","75%","100%","150%"],ans:2,ex:"$10,000 drops 50% = $5,000. Need 100% gain on $5,000 to return to $10,000. This is why capital preservation comes first."}
  ];

  var curQ=0, answered=false, quizScore=0;
  // restore saved score
  try { quizScore = parseInt(localStorage.getItem('tt_quiz_score')||'0')||0; } catch(e){}

  function updateScoreBar() {
    var bar = document.getElementById('quizScoreBar');
    if(bar && curQ > 0) bar.textContent = 'Score: ' + quizScore + ' / ' + curQ + ' correct';
    else if(bar) bar.textContent = '';
  }

  function loadQ() {
    var q=QS[curQ];
    document.getElementById('quizQ').textContent='Q'+(curQ+1)+'. '+q.q;
    document.getElementById('quizProg').textContent=(curQ+1)+' / '+QS.length;
    document.getElementById('quizNext').style.display='none';
    var feed=document.getElementById('quizFeed');
    feed.className='qfeed';feed.style.display='none';
    answered=false;
    var opts=document.getElementById('quizOpts');
    opts.innerHTML='';
    q.opts.forEach(function(o,i){
      var btn=document.createElement('button');
      btn.className='qopt';btn.textContent=o;
      btn.onclick=function(){selectA(i);};
      opts.appendChild(btn);
    });
    updateScoreBar();
  }

  function selectA(idx) {
    if(answered)return;
    answered=true;
    var q=QS[curQ];
    var opts=document.querySelectorAll('.qopt');
    var feed=document.getElementById('quizFeed');
    var correct = idx===q.ans;
    if(correct) quizScore++;
    opts[q.ans].classList.add('ok');
    if(!correct)opts[idx].classList.add('no');
    feed.textContent=(correct?'✓ Correct! ':'✗ Incorrect. ')+q.ex;
    feed.className='qfeed show '+(correct?'ok':'no');
    feed.style.display='block';
    document.getElementById('quizNext').style.display='inline-block';
    updateScoreBar();
    localStorage.setItem('tt_quiz_score', quizScore);
  }

  window.nextQ = function() {
    curQ++;
    if(curQ>=QS.length){
      localStorage.setItem('tt_quiz_score', quizScore);
      document.getElementById('quizContainer').innerHTML=
        '<div style="text-align:center;padding:2rem">'+
        '<div style="font-family:var(--head);font-size:1.8rem;color:var(--cyan);text-shadow:0 0 20px rgba(0,200,255,0.5);margin-bottom:1rem">DEBRIEF COMPLETE</div>'+
        '<div style="font-family:var(--mono);font-size:1rem;color:var(--green);margin-bottom:1rem">Score: '+quizScore+' / '+QS.length+' correct</div>'+
        '<p style="color:var(--muted);margin-bottom:2rem">Review weak areas in the modules above, then retake to sharpen your edge.</p>'+
        '<button class="btn btn-primary" onclick="window._quizRestart()" style="clip-path:none">🔁 Retake Quiz</button>'+
        '</div>';
      return;
    }
    loadQ();
  };

  window._quizRestart = function() {
    curQ=0; quizScore=0;
    document.getElementById('quizContainer').innerHTML=
      '<div class="quiz-score-bar" id="quizScoreBar"></div>'+
      '<div class="quiz-q" id="quizQ"></div>'+
      '<div class="quiz-opts" id="quizOpts"></div>'+
      '<div class="qfeed" id="quizFeed"></div>'+
      '<div class="quiz-nav">'+
      '<span class="quiz-prog" id="quizProg"></span>'+
      '<button class="btn btn-primary" id="quizNext" onclick="nextQ()" style="display:none;clip-path:none;padding:10px 24px">NEXT →</button>'+
      '</div>';
    loadQ();
  };

  loadQ();

}); // end DOMContentLoaded
</script>
<script>
  (function(){var t=localStorage.getItem('tt_dev_access'),s=localStorage.getItem('tt_sub_token');if(t!=='tt-ironclad-2026'&&!s){sessionStorage.setItem('tt_redirect',window.location.pathname);window.location.replace('/subscribe');}})();
</script>
<LogoutBar />
</body>
</html>
